<%#
  views/auth/change-password.ejs

  Change Password — current + new + confirm. Verified server-side against the
  account's stored hash; pages/account.js adds show/hide + a match check.
  Renders in the admin shell.

  Used: Controllers/AuthController.changePasswordPage.
-%>
<div class="ly">

    <div class="ly__head">
        <div>
            <h2 class="ly__title">🔒 Change Password</h2>
            <p class="ly__sub">Update the password you use to sign in</p>
        </div>
    </div>

    <section class="card ly-card">
        <form id="change-password-form" method="post" action="/change-password" class="ly-grid">
            <div class="ly-field lc-full">
                <label for="cp-current">Current password</label>
                <div class="pw-field">
                    <input id="cp-current" type="password" name="current_password" autocomplete="current-password" required>
                    <button type="button" class="pw-toggle" data-action="toggle-pw" data-target="cp-current" aria-label="Show password" aria-pressed="false">
                        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/></svg>
                    </button>
                </div>
            </div>
            <div class="ly-field">
                <label for="cp-new">New password</label>
                <div class="pw-field">
                    <input id="cp-new" type="password" name="new_password" minlength="6" autocomplete="new-password" required>
                    <button type="button" class="pw-toggle" data-action="toggle-pw" data-target="cp-new" aria-label="Show password" aria-pressed="false">
                        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/></svg>
                    </button>
                </div>
            </div>
            <div class="ly-field">
                <label for="cp-confirm">Confirm new password</label>
                <div class="pw-field">
                    <input id="cp-confirm" type="password" name="confirm_password" minlength="6" autocomplete="new-password" required>
                    <button type="button" class="pw-toggle" data-action="toggle-pw" data-target="cp-confirm" aria-label="Show password" aria-pressed="false">
                        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/></svg>
                    </button>
                </div>
            </div>
            <p class="ly-pw-error" data-pw-error hidden></p>
            <div class="ly-field ly-field--action lc-full">
                <button type="submit" class="ly-btn ly-btn--primary">Change password</button>
            </div>
        </form>
    </section>
</div>
