<%#
  partials/home-product-row.ejs

  One admin-featured PRODUCT row: heading = the restaurant name (links to that
  restaurant), cards = its chosen dishes in a horizontal carousel. Each card
  opens the existing product modal (data-action="open-product"). `row` =
  { type:'product', title, restaurantSlug, products:[{id,name,price,image,veg}] }.

  Used: views/site/index.ejs (loops `home_feed`).
-%>
<%
    var sym = (typeof brand !== 'undefined' && brand && brand.currencySymbol) ? brand.currencySymbol : '£';
%>
<% if (row && row.products && row.products.length) { %>
<section class="home-row home-row--product" aria-label="<%= row.title %>">
    <div class="hv2-head">
        <h2 class="hv2-head__title"><%= row.title %></h2>
        <a href="/?restaurant=<%= encodeURIComponent(row.restaurantSlug) %>" class="hv2-head__link" data-action="pick-restaurant">View all</a>
    </div>
    <div class="rail-wrap home-rail-wrap" data-rail-wrap>
        <button type="button" class="rail-arrow rail-arrow--prev" data-rail-prev aria-label="Scroll left" hidden>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>
        </button>
        <ul class="home-rail home-rail--product" role="list" data-rail>
            <% row.products.forEach(function (p) { %>
            <li>
                <button type="button" class="hp-card" data-action="open-product" data-rest="<%= row.restaurantSlug %>" data-item="<%= p.id %>">
                    <span class="hp-card__media">
                        <% if (p.image) { %><img src="<%= p.image %>" alt="" loading="lazy"><% } else { %><span class="hp-card__ph" aria-hidden="true">🍽️</span><% } %>
                        <% if (p.veg) { %><span class="hp-card__veg" title="Vegetarian" aria-label="Vegetarian"></span><% } %>
                    </span>
                    <span class="hp-card__body">
                        <span class="hp-card__name"><%= p.name %></span>
                        <span class="hp-card__price"><%= sym %><%= Number(p.price || 0).toFixed(2) %></span>
                    </span>
                </button>
            </li>
            <% }); %>
        </ul>
        <button type="button" class="rail-arrow rail-arrow--next" data-rail-next aria-label="Scroll right" hidden>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
        </button>
    </div>
</section>
<% } %>
