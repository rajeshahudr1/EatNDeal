<%#
  views/partials/header.ejs

  What:  Top navigation bar shown on every page. Composition by viewport:
           Mobile  → logo (compact) · two-line location · bell · hamburger
           Desktop → logo · two-line location · primary nav · bell · auth
  Why:   Matches the food-delivery convention seen in the user's mockup
         (Zomato / Swiggy / Foodhub):
           • Two-line location: bold label on top with a chevron-down +
             smaller address underneath. Most prominent header element
             since picking the area is the user's primary lever.
           • Notification bell with red badge on the right.
         Login is a quiet entry point in the top-right on desktop; on
         mobile it lives inside the slide-out drawer (toggled by the
         hamburger) — never a barrier to browsing.
  Used:  Included from views/_layout.ejs.

  Brand: logo + alt text are dynamic — pulled from res.locals.brand
         (api/brand.config.js is the single source of truth).
-%>
<%
    // Split the saved location label into a bold TITLE (the first
    // comma-separated chunk) and a quieter SUB-line (everything else).
    // Examples:
    //   "London"                        → title "London",   sub ""
    //   "Lonemore, IV21 2DB"            → title "Lonemore", sub "IV21 2DB"
    //   "10 Downing Street, London"     → title "10 Downing Street",
    //                                     sub "London"
    // When no location is set yet the chip shows a single-line prompt.
    var locTitle = '';
    var locSub   = '';
    if (user_location && user_location.label) {
        var locParts = user_location.label.split(',').map(function (s) { return s.trim(); }).filter(Boolean);
        locTitle = locParts[0] || user_location.label;
        locSub   = locParts.slice(1).join(', ');
        if (!locSub && user_location.postcode) {
            locSub = user_location.postcode;
        }
    }
    // Placeholder unread-notifications count. Wire to a real backed
    // count once the notifications API lands; for now a small static
    // hint makes the badge visually meaningful.
    var notifCount = 0;
    // First initial for the signed-in avatar (shown instead of the
    // hamburger on mobile once logged in).
    var avatarInitial = user_session ? (user_session.firstname || user_session.email || '?').charAt(0).toUpperCase() : '';
%>
<header class="site-header" role="banner">
    <div class="site-header__inner">

        <%# Logo (hidden on mobile by CSS — the mockup uses the freed
            space for the two-line location). Cache-busted via
            ?v=ASSET_VERSION so a logo file swap propagates after a
            server restart. %>
        <a class="site-header__brand" href="/" aria-label="<%= brand.name %> home">
            <img
                class="site-header__logo"
                src="<%= brand.logoUrl %>?v=<%= ASSET_VERSION %>"
                alt="<%= brand.name %>"
            >
        </a>

        <%# Two-line location chip. Click → opens the full-screen
            location modal. If no location is set yet the modal also
            opens automatically on DOM-ready (see /js/app.js +
            data-has-location on <body>). %>
        <button
            type="button"
            class="site-header__location <%= user_location ? 'has-location' : '' %>"
            data-action="open-location-modal"
            aria-label="Change delivery location"
        >
            <%# Pin icon — solid red drop-pin, brand red. %>
            <svg class="site-header__location-pin" aria-hidden="true" width="20" height="20" viewBox="0 0 24 24">
                <path d="M12 2C7.6 2 4 5.6 4 10c0 5.5 8 12 8 12s8-6.5 8-12c0-4.4-3.6-8-8-8z" fill="#E5252A"/>
                <circle cx="12" cy="10" r="2.8" fill="#FFFFFF"/>
            </svg>

            <span class="site-header__location-stack">
                <span class="site-header__location-title">
                    <span class="site-header__location-name">
                        <% if (locTitle) { %>
                            <%= locTitle %>
                        <% } else { %>
                            Set your location
                        <% } %>
                    </span>
                    <%# Chevron-down ▼ — matches the mockup; indicates
                        "tap to change". %>
                    <svg class="site-header__location-arrow" aria-hidden="true" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="6 9 12 15 18 9"/>
                    </svg>
                </span>
                <% if (locSub) { %>
                    <span class="site-header__location-sub"><%= locSub %></span>
                <% } %>
            </span>
        </button>

        <%# Search box — DESKTOP only (mobile renders its own full-width
            search row below the header). Live-filters the cuisine row,
            "For you" dishes and "Popular near you" restaurants as the
            user types. The data-search-scope attribute lets us toggle
            search behaviour later (page-filter vs results-overlay).
            Removed from this slot earlier: Restaurants / Offers / Help
            links — the user asked to drop them; same content is still
            reachable from the mobile drawer + footer.

            Gated on `show_search` — only the browse surfaces (home feed,
            all-restaurants / all-cuisines grids, search results, a single
            restaurant's menu) render it. On every other page (cart,
            account, orders, merchant, offers, product detail, static
            pages) there is nothing to search, so the box is omitted.
            The local is always defined (defaults to false in
            web/index.js), so no typeof guard is needed. %>
        <% if (show_search) { %>
        <form class="site-header__search" role="search" data-no-loader>
            <svg class="site-header__search-icon" aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="11" cy="11" r="7"/>
                <line x1="21" y1="21" x2="16.65" y2="16.65"/>
            </svg>
            <input
                type="search"
                class="site-header__search-input"
                id="site-search"
                placeholder="Search for restaurants, dishes and cuisines"
                autocomplete="off"
                spellcheck="false"
                data-search-scope="home"
            >
        </form>
        <% } %>

        <%# Delivery / Pickup segmented toggle — sits in the header
            beside the quick-links / Order Now, matching the Uber-Eats
            top-bar control. Pure-CSS radio toggle (the :checked label
            paints the active segment) so no JS is needed. Default
            = Delivery. Persisted/handled server-side later. %>
        <%# Reflect the mode the user chose on the location page
            (stored on user_location.mode). Defaults to delivery. %>
        <% var orderMode = (user_location && user_location.mode === 'pickup') ? 'pickup' : 'delivery'; %>
        <div class="mode-toggle" role="radiogroup" aria-label="Delivery or pickup">
            <input type="radio" name="order-mode" id="mode-delivery" value="delivery" <%= orderMode === 'delivery' ? 'checked' : '' %>>
            <label for="mode-delivery">Delivery</label>
            <input type="radio" name="order-mode" id="mode-pickup" value="pickup" <%= orderMode === 'pickup' ? 'checked' : '' %>>
            <label for="mode-pickup">Pickup</label>
        </div>

        <%# Quick-access cluster (desktop) — Rewards · Orders · Cart,
            matching the mockup. Icon + label stacked. Cart carries a
            count badge. These are nav entry points; the destination
            pages are stubs for now. Hidden on mobile (the drawer +
            bottom-nav cover the same ground). %>
        <%# Rewards + Orders moved into the account menu / sidebar — the
            header keeps an Offers quick-link beside the Cart. %>
        <nav class="header-quick" aria-label="Quick links">
            <a href="/offers" class="header-quick__item">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20.6 13.4 12 22l-9-9V3h10l7.6 7.6a2 2 0 0 1 0 2.8z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>
                <span>Offers</span>
            </a>
            <a href="/cart" class="header-quick__item header-quick__cart">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
                <%# data-cart-count is always rendered so client JS can flip
                    the badge without re-rendering after an add/remove. -%>
                <% var cartCount = (typeof cart_count !== 'undefined' && cart_count) ? cart_count : 0; %>
                <span class="header-quick__badge" data-cart-count aria-hidden="true"<%= cartCount > 0 ? '' : ' hidden' %>><%= cartCount > 99 ? '99+' : (cartCount || 0) %></span>
                <span>Cart</span>
            </a>
        </nav>

        <%# Auth area — desktop only. Hidden on mobile (the drawer
            below carries the same options).
              • Logged out → single "Sign in" CTA (OTP flow handles both
                new + returning so no separate Sign up button).
              • Logged in  → click the name chip to open a dropdown with
                "My profile" + "Log out". The dropdown is toggled by
                /js/ui/account-menu.js — keyboard accessible, Esc closes,
                outside-click closes. %>
        <div class="site-header__auth">
            <% if (user_session) { %>
                <div class="account-menu" data-account-menu>
                    <button
                        type="button"
                        class="account-menu__trigger"
                        data-action="toggle-account-menu"
                        aria-haspopup="menu"
                        aria-expanded="false"
                        aria-controls="account-menu-panel"
                    >
                        <span class="account-menu__avatar" aria-hidden="true">
                            <% if (user_session.image) { %><img src="<%= user_session.image %>" alt="" data-img-fallback><% } else { %><%= (user_session.firstname || '?').charAt(0).toUpperCase() %><% } %>
                        </span>
                        <span class="account-menu__name">
                            <%= user_session.firstname || 'Account' %>
                        </span>
                        <svg class="account-menu__caret" aria-hidden="true" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round">
                            <polyline points="6 9 12 15 18 9"/>
                        </svg>
                    </button>

                    <div
                        id="account-menu-panel"
                        class="account-menu__panel"
                        role="menu"
                        aria-labelledby="account-menu-trigger"
                        hidden
                    >
                        <%# Header inside the panel — name + masked phone
                            so the user can confirm they're in the right
                            account before tapping My profile. %>
                        <div class="account-menu__head">
                            <p class="account-menu__head-name">
                                <%= [user_session.firstname, user_session.lastname].filter(Boolean).join(' ') || 'My account' %>
                            </p>
                            <% if (user_session.contact_no) { %>
                                <p class="account-menu__head-phone">
                                    +<%= user_session.country_code %> <%= user_session.contact_no %>
                                </p>
                            <% } %>
                        </div>

                        <a href="/account" class="account-menu__item" role="menuitem">
                            <svg class="account-menu__item-icon" aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="4"/><path d="M4 21c0-4 4-6 8-6s8 2 8 6"/></svg>
                            <span>My profile</span>
                        </a>
                        <%# Same account sections as the sidebar — one click
                            opens that screen with its tab selected. %>
                        <a href="/account?tab=addresses" class="account-menu__item" role="menuitem">
                            <svg class="account-menu__item-icon" aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s7-7.5 7-13a7 7 0 0 0-14 0c0 5.5 7 13 7 13z"/><circle cx="12" cy="9" r="2.5"/></svg>
                            <span>Addresses</span>
                        </a>
                        <a href="/account?tab=payment" class="account-menu__item" role="menuitem">
                            <svg class="account-menu__item-icon" aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="5" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/></svg>
                            <span>Payment Methods</span>
                        </a>
                        <a href="/account?tab=orders" class="account-menu__item" role="menuitem">
                            <svg class="account-menu__item-icon" aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 3H6a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V5a2 2 0 0 0-2-2h-3"/><rect x="9" y="2" width="6" height="4" rx="1"/><line x1="8" y1="11" x2="16" y2="11"/></svg>
                            <span>My Orders</span>
                        </a>
                        <a href="/account?tab=favourites" class="account-menu__item" role="menuitem">
                            <svg class="account-menu__item-icon" aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.8 4.6a5.5 5.5 0 0 0-7.8 0L12 5.7l-1-1.1a5.5 5.5 0 0 0-7.8 7.8l1 1.1L12 21l7.8-7.5 1-1.1a5.5 5.5 0 0 0 0-7.8z"/></svg>
                            <span>Favourites</span>
                        </a>
                        <a href="/account?tab=rewards" class="account-menu__item" role="menuitem">
                            <svg class="account-menu__item-icon" aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="8" width="18" height="13" rx="1"/><path d="M3 12h18M12 8v13"/></svg>
                            <span>Rewards</span>
                        </a>
                        <a href="/account?tab=notifications" class="account-menu__item" role="menuitem">
                            <svg class="account-menu__item-icon" aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8a6 6 0 0 0-12 0c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.7 21a2 2 0 0 1-3.4 0"/></svg>
                            <span>Notifications</span>
                        </a>
                        <a href="/help" class="account-menu__item" role="menuitem">
                            <svg class="account-menu__item-icon" aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M9.1 9a3 3 0 0 1 5.8 1c0 2-3 2.5-3 2.5"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                            <span>Help &amp; Support</span>
                        </a>
                        <a href="/account?tab=settings" class="account-menu__item" role="menuitem">
                            <svg class="account-menu__item-icon" aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09a1.65 1.65 0 0 0-1-1.51 1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09a1.65 1.65 0 0 0 1.51-1 1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
                            <span>Settings</span>
                        </a>

                        <div class="account-menu__sep" role="separator"></div>

                        <%# Logout — POST so it can't be triggered by a
                            crafted link / image / accidental hover. %>
                        <form method="post" action="/logout" class="account-menu__logout-form">
                            <button type="submit" class="account-menu__item account-menu__item--danger" role="menuitem">
                                <svg class="account-menu__item-icon" aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
                                    <polyline points="16 17 21 12 16 7"/>
                                    <line x1="21" y1="12" x2="9" y2="12"/>
                                </svg>
                                <span>Log out</span>
                            </button>
                        </form>
                    </div>
                </div>
            <% } else { %>
                <a href="/signin" class="btn btn--primary btn--sm site-header__signin">Sign in</a>
            <% } %>
        </div>

        <%# Mobile-only menu trigger. Opens the slide-out drawer
            (handled in /js/app.js). Signed in → show the user's avatar
            (initial) instead of the 3-line hamburger; signed out → the
            hamburger. Either way it opens the drawer. %>
        <button
            type="button"
            class="site-header__menu-btn <%= user_session ? 'site-header__menu-btn--avatar' : '' %>"
            data-action="toggle-mobile-menu"
            aria-label="Open menu"
            aria-expanded="false"
        >
            <% if (user_session) { %>
                <span class="site-header__avatar" aria-hidden="true"><% if (user_session.image) { %><img src="<%= user_session.image %>" alt="" data-img-fallback><% } else { %><%= avatarInitial %><% } %></span>
            <% } else { %>
                <svg aria-hidden="true" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="3"  y1="6"  x2="21" y2="6"/>
                    <line x1="3"  y1="12" x2="21" y2="12"/>
                    <line x1="3"  y1="18" x2="21" y2="18"/>
                </svg>
            <% } %>
        </button>

    </div>
</header>
