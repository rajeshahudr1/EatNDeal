<%#
  partials/chatbot.ejs — floating help-chatbot widget (global).

  A bottom-right FAB opens a chat panel. Messages + quick-reply chips are
  driven by /js/ui/chatbot.js which posts to /chatbot/ask. No inline JS/CSS
  (CSP-safe). Answers personalise for the signed-in customer (orders / cashback
  / offers); guests get FAQ + a sign-in nudge.
-%>
<div class="chatbot" data-chatbot>
    <button type="button" class="chatbot__fab" data-action="chatbot-toggle" aria-label="Open help assistant" title="Need help?">
        <svg class="chatbot__fab-open" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
        <svg class="chatbot__fab-close" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>

    <div class="chatbot__panel" data-chatbot-panel hidden>
        <header class="chatbot__head">
            <span class="chatbot__title">🍔 EatNDeal Assistant</span>
            <button type="button" class="chatbot__x" data-action="chatbot-toggle" aria-label="Close chat">✕</button>
        </header>
        <div class="chatbot__body" data-chatbot-body>
            <div class="chatbot__msg chatbot__msg--bot">Hi! 👋 I can help with your orders, cashback, offers — or how EatNDeal works. Ask me anything.</div>
        </div>
        <div class="chatbot__chips" data-chatbot-chips></div>
        <form class="chatbot__form" data-chatbot-form>
            <input type="text" class="chatbot__input" data-chatbot-input placeholder="Type a message…" autocomplete="off" aria-label="Message">
            <button type="submit" class="chatbot__send" aria-label="Send">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
            </button>
        </form>
    </div>
</div>
