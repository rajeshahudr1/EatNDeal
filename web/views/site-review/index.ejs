<%#
  views/site-review/index.ejs — /reviews

  Reviews of EATNDEAL ITSELF (the marketplace), not of a restaurant. Public to
  read; writing needs a sign-in.

  A review is saved PENDING and reaches OTHER people only once the super admin
  publishes it in the admin Reviews screen. The author is never told that: the
  api merges their own pending review into the list (and the average) for them
  alone, so this page just renders whatever came back — there is deliberately
  no "awaiting approval" note here.

  Used: Controllers/SiteReviewController.page
-%>
<%
    function starRow(value, cls) {
        var v = Math.round((Number(value) || 0) * 2) / 2;
        var out = '';
        for (var i = 1; i <= 5; i++) {
            if (v >= i) { out += '<span class="sr-star is-full">★</span>'; }
            else if (v >= i - 0.5) { out += '<span class="sr-star is-half">★</span>'; }
            else { out += '<span class="sr-star">★</span>'; }
        }
        return '<span class="sr-stars ' + (cls || '') + '">' + out + '</span>';
    }
    function dmy(v) {
        var d = new Date(v);
        if (isNaN(d.getTime())) { return ''; }
        return d.toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' });
    }
%>
<div class="sr">

    <header class="sr__head">
        <h1 class="sr__title">Reviews</h1>
        <p class="sr__sub">What customers say about <%= brand.name %></p>
    </header>

    <% if (load_error) { %>
        <p class="sr__error"><%= load_error %></p>
    <% } else { %>

        <% if (total > 0) { %>
        <section class="sr__summary" aria-label="Average rating">
            <span class="sr__avg"><%= Number(average).toFixed(1) %></span>
            <span class="sr__avgstars"><%- starRow(average) %></span>
            <span class="sr__count"><%= total %> review<%= total === 1 ? '' : 's' %></span>
        </section>
        <% } %>

        <%# Two columns on desktop (write | everyone else's), one on mobile. %>
        <div class="sr__cols">

        <%# Write / edit. Signed out → a sign-in nudge instead of a dead form. %>
        <section class="sr__write" aria-label="Write a review">
            <% if (!signed_in) { %>
                <p class="sr__signin">
                    <a href="/signin?next=%2Freviews" class="sr__signin-btn">Sign in</a> to leave a review.
                </p>
            <% } else { %>
                <h2 class="sr__write-t"><%= mine ? 'Your review' : 'Write a review' %></h2>

                <form class="sr__form" data-sr-form>
                    <div class="sr__rate" data-sr-rate role="radiogroup" aria-label="Your rating">
                        <% for (var s = 1; s <= 5; s++) { %>
                        <button type="button" class="sr__ratestar<%= (mine && mine.rating >= s) ? ' is-on' : '' %>"
                                data-sr-star="<%= s %>" role="radio"
                                aria-checked="<%= (mine && mine.rating === s) ? 'true' : 'false' %>"
                                aria-label="<%= s %> star<%= s === 1 ? '' : 's' %>">★</button>
                        <% } %>
                        <input type="hidden" name="rating" value="<%= mine ? mine.rating : 0 %>" data-sr-rating>
                    </div>

                    <textarea class="sr__text" name="review" rows="3" maxlength="2000"
                              placeholder="Tell others about your experience…"><%= mine ? mine.review : '' %></textarea>

                    <div class="sr__actions">
                        <button type="submit" class="sr__submit" data-sr-submit><%= mine ? 'Update review' : 'Submit review' %></button>
                    </div>
                </form>

                <% if (mine && mine.reply) { %>
                <p class="sr__reply"><strong><%= brand.name %> replied:</strong> <%= mine.reply %></p>
                <% } %>
            <% } %>
        </section>

        <div class="sr__listwrap">
        <% if (!reviews.length) { %>
            <p class="sr__empty">No reviews yet — be the first.</p>
        <% } else { %>
        <ul class="sr__list" data-sr-list>
            <% reviews.forEach(function (r) { %>
            <li class="sr__item">
                <div class="sr__item-head">
                    <span class="sr__name"><%= r.name %></span>
                    <span class="sr__date"><%= dmy(r.created_at) %></span>
                </div>
                <%- starRow(r.rating, 'sr-stars--sm') %>
                <% if (r.review) { %><p class="sr__body"><%= r.review %></p><% } %>
                <% if (r.reply) { %>
                <p class="sr__reply"><strong><%= brand.name %> replied:</strong> <%= r.reply %></p>
                <% } %>
            </li>
            <% }); %>
        </ul>

        <%# "View more" — rendered only when the api says another page exists.
            data-offset is where the NEXT batch starts; the JS bumps it as it
            appends, and removes the button when the api stops saying hasMore.
            A button, not a link: there's no offset URL to fall back to, and
            this page already needs JS for the star picker. %>
        <% if (has_more) { %>
        <div class="sr__more">
            <%# data-brand: the appended cards render "<brand> replied:" the same
                way the server-rendered ones do, and the JS has no other source
                for the name. %>
            <button type="button" class="sr__more-btn" data-sr-more
                    data-offset="<%= next_offset %>" data-brand="<%= brand.name %>">View more</button>
        </div>
        <% } %>
        <% } %>
        </div><%# /.sr__listwrap %>

        </div><%# /.sr__cols %>
    <% } %>
</div>
