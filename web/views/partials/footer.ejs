<%#
  views/partials/footer.ejs

  What:  Site-wide footer with four content columns and a bottom row of
         legal links + copyright + social icons.
  Why:   Mandatory on every page; gives users access to help, legal pages,
         and contact channels without cluttering the header.
  Used:  Included from views/_layout.ejs.
-%>
<footer class="site-footer" role="contentinfo">
    <div class="site-footer__inner">

        <%# Brand column — logo + tagline + social. %>
        <div class="site-footer__col site-footer__col--brand">
            <a class="site-footer__brand" href="/" aria-label="<%= brand.name %> home">
                <%# Cache-busted with ASSET_VERSION (boot timestamp) so a
                    logo swap on disk + server restart propagates here too,
                    not just in the header. Without this the service worker
                    + browser disk cache keep serving the old file. -%>
                <img src="<%= brand.logoUrl %>?v=<%= ASSET_VERSION %>" alt="<%= brand.name %>" height="36">
            </a>
            <p class="site-footer__tagline"><%= brand.tagline %></p>

            <ul class="site-footer__social" aria-label="Social media">
                <li>
                    <a href="#" aria-label="Facebook">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M22 12.06C22 6.5 17.52 2 12 2S2 6.5 2 12.06c0 5.02 3.66 9.19 8.44 9.94v-7.03H7.9v-2.91h2.54V9.85c0-2.5 1.49-3.89 3.77-3.89 1.09 0 2.24.2 2.24.2v2.46h-1.26c-1.24 0-1.63.77-1.63 1.56v1.88h2.78l-.44 2.91h-2.34V22c4.78-.75 8.44-4.92 8.44-9.94z"/></svg>
                    </a>
                </li>
                <li>
                    <a href="#" aria-label="Instagram">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor"/></svg>
                    </a>
                </li>
                <li>
                    <a href="#" aria-label="X">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2H21l-6.52 7.46L22 22h-6.828l-4.69-6.137L4.86 22H2.103l6.97-7.97L2 2h6.96l4.24 5.61L18.244 2zm-2.39 18h1.66L7.22 4H5.5l10.354 16z"/></svg>
                    </a>
                </li>
            </ul>
        </div>

        <%# Company column %>
        <nav class="site-footer__col" aria-label="Company">
            <h4 class="site-footer__heading">Company</h4>
            <ul>
                <li><a href="/about">About</a></li>
                <li><a href="/careers">Careers</a></li>
                <li><a href="/blog">Blog</a></li>
                <li><a href="/contact">Contact us</a></li>
            </ul>
        </nav>

        <%# For Restaurants column %>
        <nav class="site-footer__col" aria-label="For restaurants">
            <h4 class="site-footer__heading">For restaurants</h4>
            <ul>
                <li><a href="/partner">Partner with us</a></li>
                <li><a href="/ride">Ride with us</a></li>
                <li><a href="/business">For business</a></li>
            </ul>
        </nav>

        <%# Help + legal column %>
        <nav class="site-footer__col" aria-label="Help and legal">
            <h4 class="site-footer__heading">Help</h4>
            <ul>
                <li><a href="/help">Help centre</a></li>
                <li><a href="<%= brand.termsUrl   || '/terms'   %>">Terms</a></li>
                <li><a href="<%= brand.privacyUrl || '/privacy' %>">Privacy</a></li>
                <% if (brand.supportEmail) { %>
                <li><a href="mailto:<%= brand.supportEmail %>"><%= brand.supportEmail %></a></li>
                <% } %>
            </ul>
        </nav>

    </div>

    <div class="site-footer__bottom">
        <p class="site-footer__copy"><%= brand.copyright %></p>
        <p class="site-footer__build">v<%= ASSET_VERSION.slice(-6) %></p>
    </div>
</footer>
