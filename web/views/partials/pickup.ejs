<%#
  views/partials/pickup.ejs

  What:  The Pickup surface — a split layout (Uber-Eats style):
           • left  = "Pickup nearby" heading + cuisine rail + a vertical
                     list of restaurant cards
           • right = a LOCAL stylized map that plots each restaurant by
                     its real position relative to the user (no street
                     tiles — fully local, CSP-safe). Markers show the
                     rating; tapping one opens a popup card; tapping a
                     card / popup opens that restaurant.
  Why:   The user asked for Uber-Eats-like Pickup: "map pe sare
         restaurant dikhana hai km wise … restaurant ke click pe us
         restaurant pe le jayega". Delivery keeps the normal feed.
  Data:  Each card carries data-* attributes (id / slug / lat / lng /
         rating / eta / dist / image / tint / initial). /js/pages/
         pickup.js reads those nodes to build the map markers + popups —
         no inline JSON, so the strict CSP holds.
  Used:  Included from views/site/index.ejs when order_mode === 'pickup'.
-%>
<% var __cards = (typeof featured !== 'undefined' && featured) ? featured : []; %>
<% var __sel   = (typeof selected_cuisine !== 'undefined' && selected_cuisine) ? String(selected_cuisine).toLowerCase() : ''; %>
<%# Pickup now shares the delivery home's filter rail: sidebar on the left,
    the split list + map on the right. Applying a filter full-reloads to
    /?mode=pickup&<filters> (pickup.js handles it — home.js isn't loaded here). %>
<%# home-shell--pickup: this page puts a heading ABOVE the cuisine rail, unlike
    home. The collapsed Filters tile is pinned to the top of the content, so
    without the modifier it sits on top of that heading — see home-v2.css. %>
<div class="home-shell home-shell--pickup">

    <%- include('filter-sidebar') -%>

    <div class="home-shell__content">
        <button type="button" class="filters-show" data-action="toggle-filters" aria-label="Show filters" title="Show filters">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"/></svg>
            <span>Filters</span>
        </button>

<div class="pickup" data-pickup>

    <%# ── Left: list ──────────────────────────────────────────────── %>
    <div class="pickup__list" data-pickup-list>
        <div class="pickup__head">
            <h1 class="pickup__title">Pickup nearby</h1>
            <%# Mobile-only control to bring up the full-screen map. On
                desktop the map is always visible beside the list. %>
            <button type="button" class="pickup__map-btn" data-action="pickup-open-map">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="1 6 1 22 8 18 16 22 23 18 23 2 16 6 8 2 1 6"/><line x1="8" y1="2" x2="8" y2="18"/><line x1="16" y1="6" x2="16" y2="22"/></svg>
                <span>Map</span>
            </button>
        </div>

        <%# Cuisine rail — links carry &mode=pickup so a tap re-filters
            the pickup map (full navigation; home.js is not loaded here). %>
        <% if (typeof cuisines !== 'undefined' && cuisines && cuisines.length > 0) { %>
        <section class="rail-wrap" data-rail-wrap aria-label="Browse cuisines">
            <button type="button" class="rail-arrow rail-arrow--prev" data-rail-prev aria-label="Scroll left" hidden>
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>
            </button>
            <ul class="cuisine-rail" role="list" data-rail>
                <% cuisines.forEach(function (c) { var key = c.searchName || (c.name||'').toLowerCase(); %>
                    <li class="cuisine-rail__item<%= (__sel && __sel === String(key).toLowerCase()) ? ' is-active-filter' : '' %>">
                        <a class="cuisine-rail__link" href="/?mode=pickup&cuisine=<%= encodeURIComponent(key) %>">
                            <span class="cuisine-rail__disc">
                                <% if (c.icon) { %><img src="<%= c.icon %>" alt="" loading="lazy" data-img-fallback><% } else { %><%= c.initial || '🍽️' %><% } %>
                            </span>
                            <span class="cuisine-rail__name"><%= c.name %></span>
                        </a>
                    </li>
                <% }); %>
            </ul>
            <button type="button" class="rail-arrow rail-arrow--next" data-rail-next aria-label="Scroll right" hidden>
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
            </button>
        </section>
        <% } %>

        <%# Restaurant cards %>
        <% if (__cards.length > 0) { %>
        <ul class="pickup-cards" role="list" data-pickup-cards>
            <% __cards.forEach(function (r) {
                // Pickup view → show the PICKUP time everywhere (cards,
                // map markers, popups). Fall back to deliveryMinutes
                // when the merchant hasn't set a separate pickup
                // baseline so the time chip still surfaces. %>
                <% var rTime = r.pickupMinutes || r.deliveryMinutes || ''; %>
                <li class="pickup-card"
                    data-id="<%= r.id %>"
                    data-slug="<%= r.slug || r.id %>"
                    data-lat="<%= (r.lat != null) ? r.lat : '' %>"
                    data-lng="<%= (r.lng != null) ? r.lng : '' %>"
                    data-rating="<%= r.rating %>"
                    data-name="<%= r.name %>"
                    data-eta="<%= rTime %>"
                    data-dist="<%= (typeof r.distanceKm === 'number' && r.distanceKm >= 0) ? r.distanceKm.toFixed(1) : '' %>"
                    data-image="<%= r.image || '' %>"
                    data-tint="<%= r.tint %>"
                    data-initial="<%= r.initial %>">
                    <a class="pickup-card__link<%= r.isOpen ? '' : ' is-closed' %>" href="/?restaurant=<%= encodeURIComponent(r.slug || r.id) %>&mode=pickup">
                        <div class="pickup-card__media" data-tint="<%= r.tint %>">
                            <% if (r.image) { %><img src="<%= r.image %>" alt="" loading="lazy" data-img-fallback><% } else { %><span class="pickup-card__initial" aria-hidden="true"><%= r.initial %></span><% } %>
                            <% if (r.offer) { %><span class="pickup-card__badge"><%= r.offer %></span><% } %>
                        </div>
                        <div class="pickup-card__body">
                            <div class="pickup-card__row">
                                <span class="pickup-card__name"><%= r.name %></span>
                                <% if (r.rating) { %>
                                <span class="pickup-card__rating">
                                    <svg width="11" height="11" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                                    <%= r.rating %>
                                </span>
                                <% } %>
                            </div>
                            <% if ((r.cuisines || []).length) { %><p class="pickup-card__cuisines"><%= (r.cuisines || []).slice(0, 3).join(' · ') %></p><% } %>
                            <p class="pickup-card__meta">
                                <% if (rTime) { %><span><%= rTime %></span><% } %>
                            </p>
                        </div>
                    </a>
                </li>
            <% }); %>
        </ul>
        <% } else { %>
        <p class="pickup__empty">No restaurants available for pickup near you yet.</p>
        <% } %>
    </div>

    <%# ── Right: stylized map ─────────────────────────────────────── %>
    <div class="pickup__map" data-pickup-map
         data-center-lat="<%= (user_location && user_location.lat != null) ? user_location.lat : '' %>"
         data-center-lng="<%= (user_location && user_location.lng != null) ? user_location.lng : '' %>">
        <div class="pickup-map__plane" data-map-plane>
            <%# pickup.js injects the "you" dot + restaurant markers here %>
        </div>
        <div class="pickup-map__popup" data-map-popup hidden></div>
        <%# Toggle: desktop = hide/show the list; mobile = close the map. %>
        <button type="button" class="pickup-map__toggle" data-action="pickup-toggle">
            <span data-toggle-label>Hide list</span>
        </button>
        <%# Zoom controls — spread / cluster the markers (drag to pan). %>
        <div class="pickup-map__zoom">
            <button type="button" data-action="pickup-zoom-in" aria-label="Zoom in" title="Zoom in">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            </button>
            <button type="button" data-action="pickup-zoom-out" aria-label="Zoom out" title="Zoom out">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/></svg>
            </button>
        </div>
    </div>
</div>

    </div><%# /.home-shell__content %>
</div><%# /.home-shell %>
