<%#
  partials/topbar.ejs — admin top bar

  Hamburger (opens the off-canvas sidebar on mobile), the current page
  title, and the signed-in admin chip with a sign-out action.
-%>
<header class="admin-topbar">
    <button type="button" class="admin-topbar__burger" data-action="open-sidebar" aria-label="Open menu" aria-controls="admin-sidebar">
        <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
    </button>

    <h1 class="admin-topbar__title"><%= page_title || 'Dashboard' %></h1>

    <%# Company scope — super admins get a SEARCHABLE company switcher (there can
        be hundreds of companies); company logins see a static label of their own.
        Selecting an option submits the hidden form (/select-company). A native
        <select> in <noscript> keeps it working without JS. Driven by /js/app.js. %>
    <% var cc = (typeof company_ctx !== 'undefined' && company_ctx) ? company_ctx : { companies: [], isSuper: false, selectedCompany: null, selectedCompanyId: null }; %>
    <% if (cc.isSuper) { %>
        <div class="admin-company" data-company-switch>
            <button type="button" class="admin-company__btn" data-action="company-open" aria-haspopup="listbox" aria-expanded="false">
                <span class="admin-company__ic" aria-hidden="true">
                    <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21h18"/><path d="M5 21V7l8-4v18"/><path d="M19 21V11l-6-4"/></svg>
                </span>
                <span class="admin-company__current"><%= cc.selectedCompany ? cc.selectedCompany.business_name : 'All companies' %></span>
                <span class="admin-company__chev" aria-hidden="true">
                    <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
                </span>
            </button>

            <div class="admin-company__panel" data-company-panel hidden>
                <div class="admin-company__search">
                    <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="7"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                    <input type="text" class="admin-company__search-input" data-company-search placeholder="Search company…" autocomplete="off" spellcheck="false">
                </div>
                <ul class="admin-company__list" data-company-list role="listbox" aria-label="Companies">
                    <li><button type="button" class="admin-company__opt <%= cc.selectedCompanyId == null ? 'is-selected' : '' %>" data-company-id="">All companies</button></li>
                    <% (cc.companies || []).forEach(function (c) { %>
                    <li><button type="button" class="admin-company__opt <%= String(cc.selectedCompanyId) === String(c.id) ? 'is-selected' : '' %>" data-company-id="<%= c.id %>"><%= c.business_name || ('Company #' + c.id) %></button></li>
                    <% }); %>
                </ul>
                <p class="admin-company__empty" data-company-empty hidden>No companies match.</p>
            </div>

            <form method="post" action="/select-company" data-company-form hidden>
                <input type="hidden" name="company_id" data-company-input value="<%= cc.selectedCompanyId == null ? '' : cc.selectedCompanyId %>">
                <input type="hidden" name="next" value="<%= current_path %>">
            </form>

            <noscript>
                <form method="post" action="/select-company" class="admin-topbar__company">
                    <input type="hidden" name="next" value="<%= current_path %>">
                    <select name="company_id" class="admin-topbar__company-select" aria-label="Select company">
                        <option value="" <%= cc.selectedCompanyId == null ? 'selected' : '' %>>All companies</option>
                        <% (cc.companies || []).forEach(function (c) { %>
                        <option value="<%= c.id %>" <%= String(cc.selectedCompanyId) === String(c.id) ? 'selected' : '' %>><%= c.business_name || ('Company #' + c.id) %></option>
                        <% }); %>
                    </select>
                    <button type="submit" class="admin-topbar__company-go">Go</button>
                </form>
            </noscript>
        </div>
    <% } else if (cc.selectedCompany) { %>
        <span class="admin-topbar__company-label" title="<%= cc.selectedCompany.business_name %>">
            <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 21h18"/><path d="M5 21V7l8-4v18"/><path d="M19 21V11l-6-4"/></svg>
            <%= cc.selectedCompany.business_name || ('Company #' + cc.selectedCompany.id) %>
        </span>
    <% } %>

    <div class="admin-topbar__right">
        <% var who = (admin && (admin.name || admin.email)) ? (admin.name || admin.email) : 'Admin'; %>
        <div class="admin-menu" data-admin-menu>
            <button type="button" class="admin-menu__trigger" data-action="admin-menu-open" aria-haspopup="true" aria-expanded="false">
                <span class="admin-topbar__avatar" aria-hidden="true"><%= String(who).trim().charAt(0).toUpperCase() %></span>
                <span class="admin-topbar__uname"><%= who %></span>
                <svg class="admin-menu__chev" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
            </button>
            <div class="admin-menu__panel" data-admin-menu-panel role="menu" hidden>
                <a class="admin-menu__item" href="/profile" role="menuitem">
                    <svg viewBox="0 0 24 24" width="17" height="17" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="8" r="4"/><path d="M4 21c0-4 4-6 8-6s8 2 8 6"/></svg>
                    My Profile
                </a>
                <a class="admin-menu__item" href="/change-password" role="menuitem">
                    <svg viewBox="0 0 24 24" width="17" height="17" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                    Change Password
                </a>
                <a class="admin-menu__item" href="/store-settings" role="menuitem">
                    <svg viewBox="0 0 24 24" width="17" height="17" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 9l1-5h14l1 5"/><path d="M4 9v10a1 1 0 0 0 1 1h14a1 1 0 0 0 1-1V9"/><path d="M9 22V13h6v9"/></svg>
                    Store Settings
                </a>
                <div class="admin-menu__sep" aria-hidden="true"></div>
                <form method="post" action="/logout">
                    <button type="submit" class="admin-menu__item admin-menu__item--logout" role="menuitem">
                        <svg viewBox="0 0 24 24" width="17" height="17" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
                        Sign out
                    </button>
                </form>
            </div>
        </div>
    </div>
</header>
