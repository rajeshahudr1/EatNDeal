<%#
  views/featured/form.ejs

  Add / edit a featured / sponsored placement: pick a restaurant (autocomplete),
  priority, row label, start/end window, amount paid (record only), notes,
  status. `placement` = the row to edit (or null to add).

  Used: Controllers/FeaturedController.form.
-%>
<%
    var p = placement || {};
    var isEdit = !!(placement && placement.id);
    function dval(s) {   // ISO datetime → 'YYYY-MM-DD' for the date input.
        if (!s) { return ''; }
        var d = new Date(s);
        if (isNaN(d.getTime())) { return ''; }
        return d.toISOString().slice(0, 10);
    }
%>
<div class="ly">

    <div class="ly__head">
        <div>
            <h2 class="ly__title"><%= isEdit ? '✎ Edit Placement' : '➕ Add Featured Placement' %></h2>
            <p class="ly__sub"><%= isEdit ? (p.company_name || 'Placement') : 'Boost a paying restaurant into the Featured row' %></p>
        </div>
        <a href="/featured" class="ly-btn ly-btn--ghost ly-btn--sm">← Back to list</a>
    </div>

    <% if (load_error) { %>
        <div class="ly-empty"><span class="ly-empty__ic" aria-hidden="true">🏢</span><p class="ly-empty__msg"><%= load_error %></p></div>
    <% } else { %>

    <form method="post" action="/featured/save" class="pr-form feat-form" data-feat-form>
        <% if (isEdit) { %><input type="hidden" name="id" value="<%= p.id %>"><% } %>

        <section class="card ly-card">
            <h3 class="card__title">Restaurant</h3>
            <div class="ly-field">
                <label>Restaurant <span class="pr-req">*</span></label>
                <input type="hidden" name="company_id" value="<%= p.company_id || '' %>" data-feat-company>
                <div class="col-ac" data-feat-ac>
                    <span class="col-ac__ic" aria-hidden="true">🔍</span>
                    <input type="text" class="col-ac__input" value="<%= isEdit ? (p.company_name || '') : '' %>" placeholder="Search a restaurant…" autocomplete="off" data-ac-input>
                    <% if (isEdit && p.company_id) { %><button type="button" class="col-ac__clear" data-feat-clear aria-label="Clear">✕</button><% } %>
                    <div class="col-ac__panel" data-ac-panel hidden></div>
                </div>
            </div>
        </section>

        <section class="card ly-card">
            <h3 class="card__title">Placement</h3>
            <div class="ly-grid">
                <div class="ly-field">
                    <label for="feat-pri">Priority <span class="ly-field__hint">(higher = more to the front)</span></label>
                    <input id="feat-pri" type="number" name="priority" min="0" step="1" value="<%= isEdit ? (p.priority || 0) : 10 %>">
                </div>
                <div class="ly-field">
                    <label for="feat-label">Row label</label>
                    <select id="feat-label" name="label">
                        <option value="Featured" <%= (!isEdit || p.label === 'Featured') ? 'selected' : '' %>>Featured</option>
                        <option value="Sponsored" <%= (isEdit && p.label === 'Sponsored') ? 'selected' : '' %>>Sponsored</option>
                    </select>
                </div>
                <div class="ly-field">
                    <label for="feat-start">Starts on <span class="ly-field__hint">(blank = now)</span></label>
                    <input id="feat-start" type="date" name="starts_at" value="<%= dval(p.starts_at) %>">
                </div>
                <div class="ly-field">
                    <label for="feat-end">Ends on <span class="ly-field__hint">(blank = open-ended)</span></label>
                    <input id="feat-end" type="date" name="ends_at" value="<%= dval(p.ends_at) %>">
                </div>
                <div class="ly-field">
                    <label for="feat-amt">Amount paid <span class="ly-field__hint">(record only)</span></label>
                    <input id="feat-amt" type="number" name="amount_paid" min="0" step="0.01" value="<%= (isEdit && p.amount_paid != null) ? p.amount_paid : '' %>" placeholder="0.00">
                </div>
                <div class="ly-field">
                    <label for="feat-status">Status</label>
                    <select id="feat-status" name="status">
                        <option value="1" <%= (!isEdit || Number(p.status) === 1) ? 'selected' : '' %>>Active</option>
                        <option value="0" <%= (isEdit && Number(p.status) !== 1) ? 'selected' : '' %>>Inactive</option>
                    </select>
                </div>
                <div class="ly-field ly-field--full">
                    <label for="feat-notes">Notes <span class="ly-field__hint">(optional)</span></label>
                    <input id="feat-notes" type="text" name="notes" maxlength="255" value="<%= p.notes || '' %>" placeholder="e.g. Paid via bank transfer #123">
                </div>
            </div>
        </section>

        <div class="ly-saveall">
            <a href="/featured" class="ly-btn ly-btn--ghost">Cancel</a>
            <button type="submit" class="ly-btn ly-btn--primary ly-btn--lg"><%= isEdit ? 'Save changes' : 'Create placement' %></button>
        </div>
    </form>

    <% } %>
</div>
