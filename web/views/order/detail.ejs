<%#
  views/order/detail.ejs

  What:  Full marketplace order receipt + status page. Server-rendered
         from /api/v1/customer/order/:id (loadDetail), so a refresh
         shows the latest status without any client-side polling.

  Data:  OrderController.detailPage passes `order` (or null when not
         found / not this customer's).

  Design: PWA-responsive. Desktop: items left, summary right. Phone:
          stacked. Same primary-soft styling vocabulary as the cart.
-%>
<% if (!order) { %>
<section class="order-detail">
    <div class="order-detail__missing">
        <h1>Order not found</h1>
        <p>This order doesn't exist or isn't on your account.</p>
        <a class="btn btn--primary" href="/account?tab=orders">View my orders</a>
    </div>
</section>
<% } else { %>
<section class="order-detail">

    <%# Header — restaurant name + order number + status pill -%>
    <header class="order-detail__head" data-order-root data-order-id="<%= order.id %>" data-order-terminal="<%= order.progress && order.progress.isTerminal ? '1' : '0' %>">
        <div class="order-detail__head-text">
            <p class="order-detail__crumbs"><a href="/account?tab=orders">My orders</a> &rsaquo; <%= order.number || ('#' + order.id) %></p>
            <h1 class="order-detail__title"><%= order.restaurant.name || 'Order' %></h1>
            <% if (order.createdAt) { %>
            <p class="order-detail__sub">Placed <span data-utc="<%= order.createdAt %>"><%= new Date(order.createdAt).toLocaleString() %></span></p>
            <% } %>
        </div>
        <span class="order-detail__status order-detail__status--<%= order.statusClass %>" data-order-status-pill><%= order.statusLabel %></span>
    </header>

    <%# Live tracking timeline (mode-dependent, no Preparing stage):
          DELIVERY: Order placed → Confirmed → Out for delivery → Delivered
          PICKUP:   Order placed → Accepted  → Ready to collect → Collected
        Cancelled / refunded / voided replaces the whole block with a red
        strike. Polling refreshes the state classes + ETA every ~30s and
        stops once the order is completed/cancelled (see
        /js/ui/order-track.js). Stages come straight from order.progress
        (api/Helpers/orderStatus.js) so this markup never hard-codes them. -%>
    <% var prog = order.progress || { steps: [], isCancelled: false, isTerminal: false }; %>
    <section class="order-track" data-order-track aria-label="Order tracking">
        <% if (prog.isCancelled) { %>
            <div class="order-track__cancelled">
                <span class="order-track__cancelled-icon" aria-hidden="true">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
                </span>
                <% var __end = prog.currentLabel === 'Refunded' ? 'refunded'
                              : (prog.currentLabel === 'Void' ? 'voided' : 'cancelled'); %>
                <p>This order was <%= __end %>.</p>
            </div>
        <% } else { %>
            <header class="order-track__head">
                <h2 class="order-track__current" data-order-current><%= prog.currentLabel %></h2>
                <% if (prog.isTerminal) { %>
                    <p class="order-track__eta order-track__eta--done" data-order-eta-line>
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                        <%= order.serveType === 2 ? 'Picked up. Enjoy!' : 'Delivered. Enjoy!' %>
                    </p>
                <% } else if (order.etaMinutes != null) { %>
                    <p class="order-track__eta" data-order-eta-line>
                        <%= order.serveType === 2 ? 'Ready in' : 'Arriving in' %>
                        <strong data-order-eta data-eta-min="<%= order.etaMinutes %>">~<%= order.etaLabel || (order.etaMinutes + ' min') %></strong>
                    </p>
                <% } %>
            </header>

            <ol class="order-track__steps" role="list" data-order-steps>
                <% prog.steps.forEach(function (s, i) { %>
                <li class="order-track__step order-track__step--<%= s.state %>" data-step="<%= s.key %>">
                    <span class="order-track__dot" aria-hidden="true">
                        <% if (s.state === 'done') { %>
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                        <% } else { %>
                            <%= i + 1 %>
                        <% } %>
                    </span>
                    <span class="order-track__label"><%= s.label %></span>
                </li>
                <% }); %>
            </ol>
        <% } %>
    </section>

    <div class="order-detail__grid">

        <%# Left column — items + delivery/collection info -%>
        <div class="order-detail__main">

            <%# ETA / Schedule chip -%>
            <% if (order.scheduledTime && order.isPreOrder) { %>
            <div class="order-detail__chip order-detail__chip--info">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><polyline points="12 7 12 12 15 14"/></svg>
                Pre-order scheduled for <%= order.scheduledTime %>
            </div>
            <% } %>

            <%# Items list -%>
            <ol class="order-items" role="list" aria-label="Items in this order">
                <% order.items.forEach(function (it) { %>
                <li class="order-item">
                    <div class="order-item__body">
                        <p class="order-item__name"><%= it.qty %> × <%= it.name %></p>
                        <% if (it.modifiers && it.modifiers.length) { %>
                        <p class="order-item__mods"><%= it.modifiers.map(function (m) { return m.name; }).filter(Boolean).join(' · ') %></p>
                        <% } %>
                        <% if (it.remark) { %>
                        <p class="order-item__remark"><%= it.remark %></p>
                        <% } %>
                    </div>
                    <span class="order-item__price"><%= brand.currencySymbol %><%= (it.linePrice || 0).toFixed(2) %></span>
                </li>
                <% }); %>
            </ol>

            <%# Customer note -%>
            <% if (order.remark) { %>
            <p class="order-detail__note"><strong>Note:</strong> <%= order.remark %></p>
            <% } %>

            <%# Delivery / Collection info -%>
            <section class="order-detail__info">
                <h2 class="order-detail__section-title"><%= order.serveType === 2 ? 'Collection' : 'Delivery' %></h2>
                <% if (order.serveType === 2) { %>
                <p class="order-detail__line"><strong>Pick up from:</strong> <%= order.restaurant.address || order.restaurant.name %></p>
                <% if (order.restaurant.phone) { %><p class="order-detail__line"><strong>Phone:</strong> <%= order.restaurant.phone %></p><% } %>
                <% } else { %>
                <p class="order-detail__line"><strong>Deliver to:</strong> <%= order.deliveryAddress || '—' %></p>
                <% if (order.dropOffLabel) { %>
                <p class="order-detail__line"><strong>Drop-off:</strong> <%= order.dropOffLabel %></p>
                <% } %>
                <% if (order.driverInstructions) { %>
                <p class="order-detail__line"><strong>Instructions:</strong> <%= order.driverInstructions %></p>
                <% } %>
                <% } %>
                <% if (order.deliveryEstimatedTime) { %>
                <p class="order-detail__line"><strong>Estimated time:</strong> <%= order.deliveryEstimatedTime %><% if (order.advancedOrderWaitingTimeMin) { %> (+<%= order.advancedOrderWaitingTimeMin %> min queue)<% } %></p>
                <% } %>
            </section>

            <%# Customer info -%>
            <section class="order-detail__info">
                <h2 class="order-detail__section-title">Contact</h2>
                <% if (order.customerName)   { %><p class="order-detail__line"><strong>Name:</strong> <%= order.customerName %></p><% } %>
                <% if (order.customerEmail)  { %><p class="order-detail__line"><strong>Email:</strong> <%= order.customerEmail %></p><% } %>
                <% if (order.customerNumber) { %><p class="order-detail__line"><strong>Phone:</strong> <%= order.customerNumber %></p><% } %>
            </section>
        </div>

        <%# Right column — summary panel -%>
        <aside class="order-detail__summary" aria-label="Order summary">
            <h2 class="order-detail__section-title">Bill summary</h2>
            <dl class="order-detail__rows">
                <div class="order-detail__row"><dt>Subtotal</dt><dd><%= brand.currencySymbol %><%= order.subTotal.toFixed(2) %></dd></div>
                <% if (order.bagCharge > 0)     { %><div class="order-detail__row"><dt>Bag charge</dt><dd><%= brand.currencySymbol %><%= order.bagCharge.toFixed(2) %></dd></div><% } %>
                <% if (order.serviceCharge > 0) { %><div class="order-detail__row"><dt>Service charge</dt><dd><%= brand.currencySymbol %><%= order.serviceCharge.toFixed(2) %></dd></div><% } %>
                <% if (order.cardServiceCharge > 0) { %><div class="order-detail__row"><dt>Card service charge</dt><dd><%= brand.currencySymbol %><%= order.cardServiceCharge.toFixed(2) %></dd></div><% } %>
                <% if (order.charityAmount > 0) { %><div class="order-detail__row"><dt>Charity</dt><dd><%= brand.currencySymbol %><%= order.charityAmount.toFixed(2) %></dd></div><% } %>
                <% if (order.serveType === 3) { %>
                <div class="order-detail__row"><dt>Delivery</dt><dd><%= (order.freeDelivery || order.deliveryFees === 0) ? 'Free' : (brand.currencySymbol + order.deliveryFees.toFixed(2)) %></dd></div>
                <% } %>
                <% if (order.discount > 0) { %>
                <div class="order-detail__row order-detail__row--discount"><dt>Discount</dt><dd>−<%= brand.currencySymbol %><%= order.discount.toFixed(2) %></dd></div>
                <% } %>
                <div class="order-detail__row order-detail__row--total"><dt>Total</dt><dd><%= brand.currencySymbol %><%= order.grandTotal.toFixed(2) %></dd></div>
            </dl>

            <% if (order.payment) { %>
            <p class="order-detail__pay">
                <strong>Payment:</strong> <%= order.payment.method %>
                <span class="order-detail__pay-status order-detail__pay-status--<%= order.payment.status.toLowerCase() %>"><%= order.payment.status %></span>
            </p>
            <% } %>

            <%# Your existing review (if any) — a small stars summary. %>
            <% if (order.review) { %>
            <div class="order-detail__myreview" data-my-review>
                <span class="order-detail__myreview-label">Your review</span>
                <span class="order-detail__myreview-stars" data-my-review-stars aria-label="<%= order.review.rating %> out of 5">
                    <% for (var rs = 1; rs <= 5; rs++) { %><span class="<%= order.review.rating >= rs ? 'is-on' : '' %>">★</span><% } %>
                </span>
            </div>
            <% } %>

            <div class="order-detail__cta">
                <%# Reorder — clones THIS order's items into a fresh cart and
                    sends the customer to /cart (handled in /js/app.js). %>
                <button type="button" class="btn btn--primary" data-action="order-reorder" data-order-id="<%= order.id %>">Reorder</button>
                <% if (order.reviewable) { %>
                <button type="button" class="btn btn--ghost" data-action="open-review" data-review-btn><%= order.review ? 'Edit your review' : 'Rate & Review' %></button>
                <% } %>
                <% if (order.restaurant.slug) { %>
                <a class="btn btn--ghost" href="/?restaurant=<%= encodeURIComponent(order.restaurant.slug) %>">View restaurant</a>
                <% } %>
                <a class="btn btn--ghost" href="/account?tab=orders">All orders</a>
            </div>
        </aside>
    </div>

    <%# ── Rate & Review modal ─────────────────────────────────────────
        Stars + text + an OPTIONAL food photo, posted (multipart) to
        /order/:id/review via /js/ui/review.js. Pre-filled when the order
        already has a review (edit). Only rendered for reviewable orders. -%>
    <% if (order.reviewable) { %>
    <div class="review-modal" data-review-modal hidden aria-hidden="true">
        <div class="review-modal__backdrop" data-action="close-review"></div>
        <div class="review-modal__panel" role="dialog" aria-modal="true" aria-labelledby="review-modal-title">
            <button type="button" class="review-modal__close" data-action="close-review" aria-label="Close">&times;</button>
            <h2 class="review-modal__title" id="review-modal-title">Rate your order</h2>
            <p class="review-modal__sub"><%= order.restaurant.name %></p>

            <form class="review-form" data-review-form data-review-url="/order/<%= order.id %>/review" enctype="multipart/form-data" novalidate>
                <div class="review-stars" data-review-stars role="radiogroup" aria-label="Star rating">
                    <% for (var s = 1; s <= 5; s++) { %>
                    <button type="button" class="review-star<%= (order.review && order.review.rating >= s) ? ' is-on' : '' %>" data-star="<%= s %>" aria-label="<%= s %> star<%= s > 1 ? 's' : '' %>">&#9733;</button>
                    <% } %>
                </div>
                <input type="hidden" name="rating" value="<%= order.review ? order.review.rating : 0 %>" data-review-rating>

                <textarea class="review-form__text" name="review" rows="4" maxlength="1500" placeholder="Tell others about the food, packaging &amp; delivery…"><%= order.review ? order.review.review : '' %></textarea>

                <div class="review-form__photo">
                    <img class="review-form__preview" src="<%= (order.review && order.review.photo) ? order.review.photo : '' %>" alt="Your photo" data-review-preview<%= (order.review && order.review.photo) ? '' : ' hidden' %>>
                    <label class="review-form__photo-btn">
                        <input type="file" name="photo" accept="image/png,image/jpeg,image/webp,image/gif" data-review-photo hidden>
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>
                        <span><%= (order.review && order.review.photo) ? 'Change photo' : 'Add a food photo' %></span>
                    </label>
                </div>

                <button type="submit" class="btn btn--primary btn--block review-form__submit" data-review-submit><%= order.review ? 'Update review' : 'Submit review' %></button>
            </form>
        </div>
    </div>
    <% } %>

</section>
<% } %>
