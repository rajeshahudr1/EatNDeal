<%#
  views/site/location.ejs

  Dedicated location landing page (the no-location gate) matching the
  mockup. Header + footer come from the layout; NO promo strip.
    LEFT  : Step 1 of 3 · "Where do you want to order from?" ·
            Delivery/Pickup tabs · postcode search · "or" · use my
            current location.
    RIGHT : phone + map illustration (emoji placeholders).
    BELOW : "Or choose from popular cities" grid · "Why millions love
            us" feature row.

  Picker is wired by /js/pages/location-page.js, reusing the api:
    POST /api/v1/delivery/search-address   (suggestions)
    POST /api/v1/delivery/retrieve-address (resolve → coords)
    POST /location/save                    (session) → reload into feed.
-%>
<section class="locpage">
    <div class="locpage__hero">

        <%# ── LEFT: copy + picker ──────────────────────────────── %>
        <div class="locpage__copy">
            <span class="locpage__step">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2C7.6 2 4 5.6 4 10c0 5.5 8 12 8 12s8-6.5 8-12c0-4.4-3.6-8-8-8z"/><circle cx="12" cy="10" r="2.8" fill="#fff"/></svg>
                STEP 1 OF 3
            </span>
            <h1 class="locpage__title">Where do you<br><em>want to order from?</em></h1>
            <p class="locpage__subtitle">Enter your postcode or share your location and we will show every restaurant that delivers to you.</p>

            <%# Delivery / Pickup tabs — visual; both use the same
                location flow. /js/pages/location-page.js toggles them. %>
            <div class="locpage__tabs" role="tablist" aria-label="Delivery or pickup">
                <button type="button" class="locpage__tab is-active" data-loc-tab role="tab" aria-selected="true">Delivery</button>
                <button type="button" class="locpage__tab" data-loc-tab role="tab" aria-selected="false">Pickup</button>
            </div>

            <div class="location-search locpage__search">
                <div class="location-search__field">
                    <svg class="location-search__icon" aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                    <input id="location-search-input" class="location-search__input" type="search" autocomplete="off" spellcheck="false"
                        placeholder="Enter your postcode or address"
                        aria-controls="location-search-suggestions" aria-expanded="false">
                </div>
                <ul id="location-search-suggestions" class="location-search__suggestions" role="listbox" hidden></ul>
                <p class="location-search__status" id="location-search-status" hidden></p>
            </div>

            <div class="locpage__or"><span>or</span></div>

            <button type="button" class="locpage__locate" data-action="use-current-location">
                <svg aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M12 2v3M12 19v3M2 12h3M19 12h3"/></svg>
                Use my current location
            </button>
        </div>

        <%# ── RIGHT: phone + map illustration (emoji placeholders) ─ %>
        <div class="locpage__art" aria-hidden="true">
            <div class="locpage__phone">
                <span class="locpage__map"></span>
                <span class="locpage__map-pin">📍</span>
                <span class="locpage__locate-btn">◎</span>
            </div>
            <span class="la la--scooter">🛵</span>
            <span class="la la--burger">🍔</span>
            <span class="la la--pizza">🍕</span>
            <span class="la la--drink">🥤</span>
            <span class="la la--pasta">🍝</span>
        </div>
    </div>

    <%# ── Popular cities ───────────────────────────────────────── %>
    <div class="locpage__cities">
        <h2 class="locpage__cities-title">Or choose from popular cities</h2>
        <ul class="city-grid" role="list">
            <%
              var cities = [
                { name: 'London',     count: '10,000+' },
                { name: 'Manchester', count: '7,500+'  },
                { name: 'Birmingham', count: '6,200+'  },
                { name: 'Leeds',      count: '4,800+'  },
                { name: 'Glasgow',    count: '4,200+'  },
                { name: 'Liverpool',  count: '3,900+'  }
              ];
            %>
            <% cities.forEach(function (c) { %>
                <li>
                    <button type="button" class="city-card" data-city="<%= c.name %>">
                        <span class="city-card__art" aria-hidden="true">🏛️</span>
                        <span class="city-card__name"><%= c.name %></span>
                        <span class="city-card__count"><%= c.count %> Restaurants</span>
                    </button>
                </li>
            <% }); %>
        </ul>
    </div>

    <%# ── Why love us ──────────────────────────────────────────── %>
    <div class="locpage__why">
        <h2 class="locpage__why-title">Why millions of users love ordering with <%= brand.name %>?</h2>
        <div class="feature-strip">
            <div class="feature-item feature-item--a"><span class="feature-item__icon">🛵</span><span><span class="feature-item__title">Fast Delivery</span><br><span class="feature-item__sub">Get your food in 20-30 minutes</span></span></div>
            <div class="feature-item feature-item--b"><span class="feature-item__icon">📍</span><span><span class="feature-item__title">Live Tracking</span><br><span class="feature-item__sub">Track your order in real-time</span></span></div>
            <div class="feature-item feature-item--c"><span class="feature-item__icon">🛡️</span><span><span class="feature-item__title">Safe Payments</span><br><span class="feature-item__sub">100% secure payment options</span></span></div>
            <div class="feature-item feature-item--d"><span class="feature-item__icon">🏷️</span><span><span class="feature-item__title">Best Offers</span><br><span class="feature-item__sub">Exclusive deals &amp; discounts</span></span></div>
        </div>
    </div>
</section>
