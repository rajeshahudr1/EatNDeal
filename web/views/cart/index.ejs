<%#
  views/cart/index.ejs

  What:  Uber Eats-style checkout page. Two-column on desktop, stacked
         on mobile.

           LEFT:
             • Delivery details card — mode toggle (Delivery / Pickup),
               address row with Edit pill (opens address popup), schedule
               row with Edit pill (opens schedule popup).
             • Payment card — saved-card row with Edit pill OR an
               "Add payment method" placeholder. Edit/Add opens the
               payment popup (saved-card picker + Stripe Elements
               new-card form + Cash radio).

           RIGHT:
             • Restaurant info chip — banner + name + address; links to
               the restaurant page.
             • Soft warnings (cart_warnings) — surfaced inline.
             • Big dark "Continue to payment" CTA — fires the existing
               data-action="cart-checkout" handler.
             • Basket summary disclosure — collapsed-by-default list of
               line items with the existing stepper / remove controls.
             • Promotions row — applied chip OR "Add a promo code" with
               Edit pill (opens promo popup).
             • Order total breakdown — Subtotal / Bag / Service /
               Charity / Delivery / Discount / Total.
             • Legal disclaimer.

  Reuse: ALL the existing data-action hooks (cart-set-mode, cart-set-
         address, cart-sched-*, cart-apply-coupon, cart-remove-coupon,
         cart-set-pay, cart-qty-*, cart-remove, cart-clear, cart-checkout,
         cart-save-card, stripe-mount, etc.) move into popups but keep
         their behaviour — /js/ui/cart.js handlers are unchanged.
         New popup open/close lives in /js/ui/checkout-popups.js.

  Data:  cart, cart_warnings, cart_addresses (existing), plus the new
         cart_payment_methods and cart_restaurant locals from
         CartController.buildCartLocals().
-%>
<%# sym now arrives as a local from CartController.buildCartLocals() %>
<%# addrList now arrives as a local from CartController.buildCartLocals() %>
<%# payList now arrives as a local from CartController.buildCartLocals() %>
<%# rest (derived from cart_restaurant) is now computed inside
    partials/cart/main.ejs and partials/cart/side.ejs — both columns use it. %>
<%# promoList now arrives as a local from CartController.buildCartLocals() %>

<%# Empty-cart layout: a single centred card instead of the two-column
    grid. Both states render the SAME region wrappers (data-cart-region)
    so an AJAX swap always has somewhere to land — an emptied cart is just
    another fragment response, not a special "reload the page" case. The
    empty-state markup itself lives in partials/cart/side.ejs (rendered
    into the "side" region); partials/cart/main.ejs and
    partials/checkout-popups.ejs render nothing for an empty cart. %>
<% var isEmptyCart = !cart || !cart.items || !cart.items.length; %>
<section class="cart-page" data-cart-root data-cart-guest="<%= (typeof cart_is_guest !== 'undefined' && cart_is_guest) ? '1' : '0' %>">

    <%# selected, schedDefault, schedMin, stripeOn now arrive as locals
        from CartController.buildCartLocals() — see that function for the
        derivation (moved verbatim, unchanged logic). %>

    <div class="cart-page__grid<%= isEmptyCart ? ' cart-page__grid--empty' : '' %>">

        <%# ════════════════════ LEFT COLUMN ════════════════════ %>
        <div class="cart-page__main-wrap" data-cart-region="main">
            <%- include('../partials/cart/main', Object.assign({}, locals)) %>
        </div>

        <%# ════════════════════ RIGHT COLUMN ════════════════════
             (also renders the empty-state card + the mobile sticky CTA —
             see partials/cart/side.ejs) %>
        <div class="cart-page__side-wrap" data-cart-region="side">
            <%- include('../partials/cart/side', Object.assign({}, locals)) %>
        </div>

    </div>

    <div data-cart-region="popups">
        <%- include('../partials/checkout-popups', {
            cart: cart,
            addrList: addrList,
            payList: payList,
            promoList: promoList,
            selected: selected,
            schedDefault: schedDefault,
            schedMin: schedMin,
            stripeOn: stripeOn,
            stripe_publishable_key: stripe_publishable_key
        }) %>
    </div>

</section>

<%# Stripe.js v3 — loaded once when configured. The new payment popup
    mounts Stripe Elements inside it (data-stripe-mount lives in the
    checkout-popups partial). -%>
<% if (stripe_publishable_key) { %>
<%# Pinned "dahlia" release (same as legacy eatndeal) — its Checkout Elements
    SDK (initCheckoutElementsSdk) needs Basil-or-newer; the evergreen /v3 build
    does not have it ("must upgrade to Basil" error). %>
<script src="https://js.stripe.com/dahlia/stripe.js"></script>
<% } %>
