<%#
  views/loyalty/review-claims.ejs

  Google / Facebook review claims approval queue. Filter by status / date /
  customer. Pending claims show Approve (grants the configured reward to the
  customer's wallet) + Reject (requires a reason, no reward). A super admin
  sees all companies; a company sees only its own.
  `rc` = { claims[], counts:{pending,approved,rejected} } or null.

  Used: Controllers/LoyaltyController.reviewClaims (shell layout).
-%>
<%
    var sym = fmt.currencySymbol(brand);
    var STATUSES = [['', 'All'], ['pending', 'Pending'], ['approved', 'Approved'], ['rejected', 'Rejected']];
    function money(n) { return sym + Number(n || 0).toFixed(2); }
%>
<div class="ly">

    <div class="ly__head">
        <div>
            <h2 class="ly__title">⭐ Cashback Review</h2>
            <p class="ly__sub">Approve or reject external review reward claims</p>
        </div>
    </div>

    <% if (load_error) { %>
        <div class="ly-empty"><span class="ly-empty__ic" aria-hidden="true">⚠️</span><p class="ly-empty__msg"><%= load_error %></p></div>
    <% } else if (rc) { %>

        <%# Filters — status tabs (one row) + search with a filter-icon popup %>
        <form method="get" action="/loyalty/review-claims" class="rc-filter" id="rc-filter">
            <input type="hidden" name="status" value="<%= filters.status %>">

            <div class="rc-tabs">
                <% STATUSES.forEach(function (s) { %>
                <button type="button" class="rc-tab<%= filters.status === s[0] ? ' is-on' : '' %>" data-rc-tab="<%= s[0] %>">
                    <%= s[1] %><% if (s[0] === 'pending' && rc.counts.pending) { %> · <%= rc.counts.pending %><% } %>
                </button>
                <% }); %>
            </div>

            <div class="rc-searchrow">
                <div class="rc-searchbox">
                    <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="7"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                    <input type="search" name="q" value="<%= filters.q %>" placeholder="Search customer…" maxlength="60" autocomplete="off" data-live-search>
                </div>
                <button type="button" class="rc-filterbtn<%= (filters.date_from || filters.date_to) ? ' is-on' : '' %>" data-action="rc-filter-open" aria-label="Filters">
                    <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"/></svg>
                </button>
            </div>

            <div class="rc-filterpop" data-rc-filterpop hidden>
                <div class="rc-filterpop__grid">
                    <label class="rc-filterpop__field"><span>From date</span><input type="date" name="date_from" value="<%= filters.date_from %>"></label>
                    <label class="rc-filterpop__field"><span>To date</span><input type="date" name="date_to" value="<%= filters.date_to %>"></label>
                </div>
                <div class="rc-filterpop__foot">
                    <a href="/loyalty/review-claims" class="ly-btn ly-btn--ghost ly-btn--sm">Clear all</a>
                    <button type="submit" class="ly-btn ly-btn--primary ly-btn--sm">Apply</button>
                </div>
            </div>
        </form>

        <% if (!rc.claims.length) { %>
            <p class="ly-none">No claims match these filters.</p>
        <% } else { %>
            <div class="rc-list">
                <% rc.claims.forEach(function (c) { %>
                <div class="rc-card rc-card--s<%= c.admin_status %>">
                    <div class="rc-card__head">
                        <div class="rc-who">
                            <span class="rc-name"><%= c.customer_name %></span>
                            <% if (c.contact_no) { %><span class="rc-meta"><%= c.contact_no %></span><% } %>
                        </div>
                        <span class="rc-badge rc-badge--s<%= c.admin_status %>"><%= c.status_label %></span>
                    </div>

                    <div class="rc-card__body">
                        <span class="ly-tier ly-tier--<%= c.review_type === 1 ? 'gold' : 'silver' %>"><%= c.type_label %></span>
                        <% if (c.reward > 0) { %><span class="rc-reward">Reward <strong><%= money(c.reward) %></strong></span><% } %>
                        <span class="rc-date"><%= new Date(c.review_date).toLocaleDateString() %></span>
                    </div>

                    <% if (c.notes) { %><p class="rc-notes">“<%= c.notes %>”</p><% } %>
                    <% if (c.review_photo_url) { %>
                    <div class="rc-shotwrap">
                        <button type="button" class="rc-shot" data-lightbox data-lightbox-src="<%= c.review_photo_url %>" title="View screenshot">
                            <img src="<%= c.review_photo_url %>" alt="Review screenshot" loading="lazy">
                            <span class="rc-shot__zoom">🔍</span>
                        </button>
                    </div>
                    <% } else if (c.review_photo) { %><p class="rc-photo">📷 Screenshot attached</p><% } %>
                    <% if (c.reject_reason) { %><p class="rc-reason">✕ <%= c.reject_reason %></p><% } %>

                    <% if (c.admin_status === 0) { %>
                        <div class="rc-actions">
                            <form method="post" action="/loyalty/review-claims/approve">
                                <input type="hidden" name="id" value="<%= c.id %>">
                                <button type="submit" class="ly-btn ly-btn--success ly-btn--sm">✓ Approve<% if (c.reward > 0) { %> · <%= money(c.reward) %><% } %></button>
                            </form>
                            <button type="button" class="ly-btn ly-btn--ghost ly-btn--sm" data-action="rc-reject-open" data-claim="<%= c.id %>">✕ Reject</button>
                        </div>
                        <form method="post" action="/loyalty/review-claims/reject" id="rc-reject-<%= c.id %>" class="rc-rejectform" hidden>
                            <input type="hidden" name="id" value="<%= c.id %>">
                            <input type="text" name="reject_reason" class="rc-input" placeholder="Reason for rejection (required)" maxlength="500" required>
                            <button type="submit" class="ly-btn ly-btn--danger ly-btn--sm">Confirm reject</button>
                            <button type="button" class="ly-btn ly-btn--ghost ly-btn--sm" data-action="rc-reject-cancel" data-claim="<%= c.id %>">Cancel</button>
                        </form>
                    <% } %>
                </div>
                <% }); %>
            </div>
        <% } %>

    <% } %>
</div>
