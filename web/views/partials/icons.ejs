<%
// views/partials/icons.ejs
// One reusable inline-SVG icon so a glyph's path lives in ONE place. Stroke
// icons on a 0 0 24 24 box (currentColor), matching the set used across the UI.
// Include it with the path relative to the CALLING file's folder, e.g. from a
// file in views/partials/ use 'icons', from views/account/ use '../partials/icons'.
// Locals: icon ('chevron'|'close'|'search'), w/h (size, default 18),
//         sw (stroke-width, default '2.4'), cls (optional extra class on the svg).
var _w = (typeof w !== 'undefined') ? w : 18;
var _h = (typeof h !== 'undefined') ? h : 18;
var _sw = (typeof sw !== 'undefined') ? sw : '2.4';
var _cls = (typeof cls !== 'undefined' && cls) ? (' class="' + cls + '"') : '';
var _paths = {
    chevron: '<polyline points="6 9 12 15 18 9"/>',
    close:   '<line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>',
    search:  '<circle cx="11" cy="11" r="7"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>'
};
-%><svg<%- _cls %> width="<%= _w %>" height="<%= _h %>" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="<%= _sw %>" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><%- _paths[icon] %></svg>