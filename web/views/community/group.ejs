<%#
  views/community/group.ejs

  One COMMUNITY group — Facebook-group style. A wide cover banner, a title /
  meta bar (Share), then a two-column body on desktop (feed + an "About this
  group" sidebar) that collapses to a single compact column on mobile. The
  composer + every post interaction is wired by /js/pages/community.js.

  Inputs: group, posts[], total, has_more, next_offset, can_post, user_session.
-%>
<section class="cgroup" data-community-group="<%= group.id %>" data-can-post="<%= can_post ? '1' : '0' %>"
    data-me-id="<%= user_session ? user_session.id : 0 %>"
    data-me-name="<%= user_session ? [user_session.firstname, user_session.lastname].filter(Boolean).join(' ') : '' %>"
    data-me-initial="<%= (user_session && user_session.firstname) ? user_session.firstname.charAt(0).toUpperCase() : 'Y' %>"
    data-me-tint="<%= (user_session && user_session.id) ? (Number(user_session.id) % 7) : 0 %>">

    <%# ── Cover banner ─────────────────────────────────────────── %>
    <header class="cgroup-cover <%= group.image_url ? 'has-cover' : ('cgroup-cover--t' + (Number(group.id) % 7)) %>">
        <% if (group.image_url) { %><img class="cgroup-cover__img" src="<%= group.image_url %>" alt=""><% } %>
        <a href="/community" class="cgroup-cover__back" aria-label="Back to community">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
        </a>
    </header>

    <%# ── Title / meta bar ─────────────────────────────────────── %>
    <div class="cgroup-bar">
        <div class="cgroup-bar__main">
            <h1 class="cgroup-bar__name"><%= group.name %></h1>
            <p class="cgroup-bar__meta">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M3 12h18M12 3a14 14 0 0 1 0 18 14 14 0 0 1 0-18z"/></svg>
                Public group · <%= total %> post<%= Number(total) === 1 ? '' : 's' %>
            </p>
        </div>
        <button type="button" class="cgroup-bar__share" data-action="share-group">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.6" y1="13.5" x2="15.4" y2="17.5"/><line x1="15.4" y1="6.5" x2="8.6" y2="10.5"/></svg>
            <span>Share</span>
        </button>
    </div>

    <%# ── Body: feed (left) + About sidebar (right, desktop) ───── %>
    <div class="cgroup-body">

        <main class="cfeed">

            <% if (can_post) { %>
                <form class="ccompose ccompose--post" data-post-form>
                    <div class="ccompose__top">
                        <span class="cavatar cavatar--t<%= (user_session && user_session.id ? (Number(user_session.id) % 7) : 0) %>" aria-hidden="true"><%= (user_session && user_session.firstname ? user_session.firstname.charAt(0).toUpperCase() : '?') %></span>
                        <textarea class="ccompose__text" name="body" rows="1" placeholder="Share something with the group…" maxlength="5000"></textarea>
                    </div>
                    <div class="ccompose__preview" data-photo-preview hidden>
                        <img alt="" data-photo-img>
                        <button type="button" class="ccompose__preview-x" data-action="remove-photo" aria-label="Remove photo">✕</button>
                    </div>
                    <div class="ccompose__bar">
                        <label class="ccompose__photo">
                            <input type="file" name="image" accept="image/png,image/jpeg,image/webp,image/gif" hidden data-photo-input>
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.8"/><path d="M21 15l-5-5L5 21"/></svg>
                            <span>Photo</span>
                        </label>
                        <button type="submit" class="btn btn--primary btn--sm ccompose__submit" data-post-submit>Post</button>
                    </div>
                </form>
            <% } else { %>
                <div class="cfeed__signin">
                    <p>Join the conversation — <a href="/signin?next=<%= encodeURIComponent('/community/g/' + group.id) %>">sign in</a> to post, like and comment.</p>
                </div>
            <% } %>

            <div class="cfeed__list" data-feed-list>
                <% posts.forEach(function (post) { %>
                    <%- include('../partials/community-post', { post: post, can_post: can_post, my_id: (user_session ? user_session.id : 0) }) %>
                <% }); %>
            </div>

            <% if (!posts.length) { %>
                <div class="cfeed__empty" data-feed-empty>
                    <span class="cfeed__empty-ic" aria-hidden="true">💬</span>
                    <p>No posts yet. <% if (can_post) { %>Be the first to share something!<% } else { %>Check back soon.<% } %></p>
                </div>
            <% } %>

            <div class="cfeed__more" data-more-wrap<%= has_more ? '' : ' hidden' %>>
                <button type="button" class="btn btn--ghost btn--lg" data-action="load-more" data-next-offset="<%= next_offset %>">Load more posts</button>
            </div>

        </main>

        <%# About sidebar — desktop only (CSS hides it on mobile). %>
        <aside class="cgroup-side">
            <div class="cside-card">
                <h2 class="cside-card__title">About</h2>
                <% if (group.description) { %><p class="cside-card__desc"><%= group.description %></p><% } %>
                <ul class="cside-card__rows">
                    <li>
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M3 12h18M12 3a14 14 0 0 1 0 18 14 14 0 0 1 0-18z"/></svg>
                        <span><strong>Public</strong>Anyone can see who’s in the group and what they post.</span>
                    </li>
                    <li>
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7-10-7-10-7z"/><circle cx="12" cy="12" r="3"/></svg>
                        <span><strong>Visible</strong>Anyone can find this group.</span>
                    </li>
                    <li>
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/></svg>
                        <span><strong><%= group.type === 'restaurant' ? 'Restaurants & customers' : 'Customers' %></strong><%= total %> post<%= Number(total) === 1 ? '' : 's' %> so far.</span>
                    </li>
                </ul>
            </div>
        </aside>

    </div>
</section>
