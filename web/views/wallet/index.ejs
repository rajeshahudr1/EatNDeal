<%#
  views/wallet/index.ejs

  Loyalty Wallet — a MULTI-restaurant wallet (vs the legacy single one):
    • wallet totals (available / earned / redeemed / expired)
    • a card per restaurant the customer has earned at (click → filter history)
    • a filterable, paginated transaction history (the customer_rewards ledger)
  `wallet` = { cards[], totals{}, transactions[], total_count, enabled }.
  Used: Controllers/WalletController.walletPage.
-%>
<%
    var w   = wallet || { cards: [], totals: {}, transactions: [], total_count: 0 };
    var tt  = w.totals || {};
    var sym = fmt.currencySymbol(brand);
    var money = fmt.money;
    var fmtDate = fmt.fmtDate;
    var STATUS = { earned: ['✓', 'Earned'], redeemed: ['↗', 'Redeemed'], expired: ['⏰', 'Expired'], reversed: ['✕', 'Reversed'] };
    var esc = fmt.esc;
    // One history row (kept in sync with the markup built in pages/wallet.js).
    function txRow(tx) {
        var st = STATUS[tx.status] || STATUS.earned;
        var amt = '';
        if (Number(tx.earned) > 0) { amt += '<span class="wh-amt wh-amt--earn">+' + sym + money(tx.earned) + '</span>'; }
        if (Number(tx.used) > 0)   { amt += '<span class="wh-amt wh-amt--used">−' + sym + money(tx.used) + '</span>'; }
        // LOCKED stamp rows — the legacy "🔒 Reward Locked" badge + the
        // journey note ("1/5 stamp orders completed · 4 more needed").
        var lockHtml = '';
        if (tx.locked) {
            lockHtml += '<span class="wh-lock">🔒 Reward Locked</span>';
            if (tx.stamp && Number(tx.stamp.required) > 0) {
                lockHtml += '<span class="wh-lock__note">' + tx.stamp.completed + ' / ' + tx.stamp.required + ' stamp orders completed</span>';
                if (Number(tx.stamp.remaining) > 0) {
                    lockHtml += '<span class="wh-lock__note wh-lock__note--todo">' + tx.stamp.remaining + ' more order' + (tx.stamp.remaining === 1 ? '' : 's') + ' needed to unlock</span>';
                }
            }
        }
        return '<div class="wh-row wh-row--' + tx.status + '">'
            + '<span class="wh-row__ic wh-row__ic--' + tx.status + '" aria-hidden="true">' + st[0] + '</span>'
            + '<div class="wh-row__main"><span class="wh-row__title">' + esc(tx.restaurant) + '</span>'
            + '<span class="wh-row__meta">' + esc(tx.type_label || 'Reward') + ' · ' + fmtDate(tx.date)
            + (tx.expiry_date && tx.status === 'earned' ? ' · valid till ' + fmtDate(tx.expiry_date) : '') + '</span>'
            + lockHtml + '</div>'
            + '<div class="wh-row__amt">' + amt + '<span class="wh-badge wh-badge--' + tx.status + '">' + st[1] + '</span></div>'
            + '</div>';
    }
    // The selected restaurant card (when ?company= is active) — its stamp
    // journey + earned split render as extra detail tiles, legacy-style.
    var selCard = null;
    if (wallet_company) {
        selCard = (w.cards || []).find(function (c) { return String(c.companyId) === String(wallet_company); }) || null;
    }
    // Preserve the OTHER active filter when building a tab/card link.
    var companyQS = wallet_company ? ('&company=' + encodeURIComponent(wallet_company)) : '';
    var filterQS  = wallet_filter ? ('&filter=' + encodeURIComponent(wallet_filter)) : '';
    var FILTERS = [['', 'All'], ['earned', 'Earned'], ['redeemed', 'Redeemed'], ['expired', 'Expired']];
%>
<section class="acct">

    <%# Mobile-only top bar — focused app screen (sidebar hidden on phones),
        matching the account dashboard. %>
    <header class="acct-mobilebar">
        <a class="acct-mobilebar__back" href="/account" aria-label="Back">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
        </a>
        <h1 class="acct-mobilebar__title">Loyalty Wallet</h1>
    </header>

    <%- include('../partials/account-nav', { nav_active: 'wallet' }) %>

    <div class="acct-main">
    <main class="wallet">

    <header class="wallet__head">
        <h1 class="wallet__title">My <span>Loyalty Wallet</span></h1>
        <p class="wallet__sub">Cashback you’ve earned across your favourite restaurants</p>
    </header>

    <%# Wallet totals %>
    <section class="wallet__totals">
        <div class="wt-card wt-card--balance">
            <span class="wt-card__lbl">Available Balance</span>
            <span class="wt-card__val"><%= sym %><%= money(tt.available) %></span>
            <span class="wt-card__sub">Ready to use on orders</span>
        </div>
        <div class="wt-card">
            <span class="wt-card__lbl">Total Earned</span>
            <span class="wt-card__val"><%= sym %><%= money(tt.earned) %></span>
            <%# Legacy note: stamp-card money is NOT part of the earned figure —
                it shows here separately ("+ £X stamp rewards earned"), scoped
                to the selected card when one is open. %>
            <% var __stampEarned = selCard ? Number(selCard.stampEarned) : Number(tt.stampEarned || 0); %>
            <% if (__stampEarned > 0) { %>
            <span class="wt-card__sub wt-card__sub--stamp">+ <%= sym %><%= money(__stampEarned) %> stamp rewards earned</span>
            <% } %>
        </div>
        <%# Stamp Reward Journey — the legacy tile, shown for the SELECTED
            restaurant card (multi-card wallet → per-card detail on click). %>
        <% if (selCard && selCard.stamp && Number(selCard.stamp.required) > 0) { var sj = selCard.stamp; %>
        <div class="wt-card wt-card--stamp">
            <span class="wt-card__lbl">Stamp Reward Journey</span>
            <span class="wt-card__val"><%= sj.completed %>/<%= sj.required %></span>
            <span class="wt-card__sub">Stamp orders completed</span>
            <% if (sj.remaining > 0 && Number(sj.lockedAmount) > 0) { %>
            <span class="wt-card__sub wt-card__sub--strong"><%= sj.remaining %> more order<%= sj.remaining === 1 ? '' : 's' %> to unlock reward of
                <b class="wt-stamp-pill"><%= sym %><%= money(sj.lockedAmount) %></b></span>
            <% } else if (Number(sj.unlockedAmount) > 0) { %>
            <span class="wt-card__sub wt-card__sub--strong"><b class="wt-stamp-pill"><%= sym %><%= money(sj.unlockedAmount) %></b> stamp reward unlocked — use it on your next order</span>
            <% } %>
        </div>
        <% } %>
        <div class="wt-card">
            <span class="wt-card__lbl">Total Redeemed</span>
            <span class="wt-card__val"><%= sym %><%= money(tt.used) %></span>
        </div>
        <div class="wt-card">
            <span class="wt-card__lbl">Total Expired</span>
            <span class="wt-card__val"><%= sym %><%= money(tt.expired) %></span>
        </div>
    </section>

    <%# ══ DISABLED 2026-07-17 (user request) ══════════════════════════
        The MARKETPLACE's own wallet card (company_id = 0, "EatNDeal") is not
        shown. Only that card is filtered out — the restaurants' cards below are
        untouched, and so is the data behind it (nothing is deleted, the api
        still returns it).

        Matched on companyId, NEVER on the name: company 1 is a real restaurant
        that is ALSO called "EatNDeal", so a name match would hide it too. (The
        earn page filters the same thing on the api's `isMarketplace` flag; this
        payload — cardsFor — doesn't carry that flag, only companyId.)

        RESTORE: drop this one filter and render w.cards directly again. %>
    <% var wCards = (w.cards || []).filter(function (c) { return String(c.companyId) !== '0'; }); %>

    <%# Per-restaurant wallet cards (the "multi card") %>
    <% if (wCards.length) { %>
    <section class="wallet__cards">
        <div class="wallet__cards-head">
            <h2>Your restaurant wallets</h2>
            <% if (wallet_company) { %><a class="wallet__clear" href="/wallet<%= wallet_filter ? '?filter=' + wallet_filter : '' %>">← All restaurants</a><% } %>
        </div>
        <div class="wallet-cardgrid">
            <% wCards.forEach(function (c) { var on = String(wallet_company) === String(c.companyId); %>
            <a class="rwcard<%= on ? ' is-on' : '' %>" href="/wallet?company=<%= encodeURIComponent(c.companyId) %><%= filterQS %>" style="--tint: <%= c.tint %>">
                <span class="rwcard__badge"><%= c.initial %></span>
                <span class="rwcard__name"><%= c.name %></span>
                <span class="rwcard__bal"><%= sym %><%= money(c.balance) %></span>
                <%# cashEarned, not earned — legacy counts ONLY plain cashback in
                    the earned figure; stamp money shows on the stamp line below. %>
                <span class="rwcard__foot">Earned <%= sym %><%= money(c.cashEarned != null ? c.cashEarned : c.earned) %> · Used <%= sym %><%= money(c.used) %></span>
                <%# Stamp-card progress hint (restaurants with a stamp rule) —
                    click the card for the full journey tile above. %>
                <% if (c.stamp && Number(c.stamp.required) > 0) { %>
                <span class="rwcard__stamp">🎟️ Stamp card <%= c.stamp.completed %>/<%= c.stamp.required %><% if (Number(c.stamp.lockedAmount) > 0) { %> · <%= sym %><%= money(c.stamp.lockedAmount) %> locked<% } %></span>
                <% } %>
            </a>
            <% }); %>
        </div>
    </section>
    <% } %>

    <%# Transaction history %>
    <section class="wallet__history">
        <div class="wh-head">
            <%# wCards, not w.cards — the marketplace card is filtered out above,
                so its name must not surface as a history scope label either. %>
            <h2>History<% if (wallet_company && wCards.length) { var cc = wCards.find(function (c) { return String(c.companyId) === String(wallet_company); }); if (cc) { %> · <span class="wh-scope"><%= cc.name %></span><% } } %></h2>
            <div class="wh-tabs" role="tablist">
                <% FILTERS.forEach(function (f) { %>
                <a class="wh-tab<%= String(wallet_filter || '') === f[0] ? ' is-on' : '' %>" href="/wallet?filter=<%= f[0] %><%= companyQS %>"><%= f[1] %></a>
                <% }); %>
            </div>
        </div>

        <% if (w.transactions && w.transactions.length) { %>
        <div class="wh-list" data-wh-list data-offset="<%= w.transactions.length %>" data-total="<%= w.total_count %>" data-filter="<%= wallet_filter || '' %>" data-company="<%= wallet_company || '' %>" data-sym="<%= sym %>">
            <% w.transactions.forEach(function (tx) { %><%- txRow(tx) %><% }); %>
        </div>
        <% if (w.transactions.length < w.total_count) { %>
        <div class="wh-more"><button type="button" class="wh-more__btn" data-wh-more>Load more</button></div>
        <% } %>
        <% } else { %>
        <div class="wh-empty"><span class="wh-empty__ic" aria-hidden="true">💰</span><p>No transactions yet — order from a restaurant to start earning cashback.</p></div>
        <% } %>
    </section>

    </main>
    </div>
</section>
