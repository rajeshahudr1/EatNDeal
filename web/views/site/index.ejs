<%#
  views/site/index.ejs

  Landing page rebuilt to the EatNDeal mockup (top → bottom):
    Default home (no view mode):
      home-shell = filter sidebar (left)  +  content column (right):
        hero · cuisine rail · top restaurants · best offers ·
        popular cuisines · feature strip · app CTA
    View modes (?view= / ?restaurant=) keep a focused single-section
    layout with a back-to-home bar.

  Dynamic data: cuisines + featured restaurants come from the api
  (SiteController). Offers / popular-cuisine art / features / app CTA
  are static markup until their endpoints land — per the user's
  "implement what we have, static-HTML the rest" instruction.

  Controller passes extra_js: '/js/pages/home.js'.
-%>
<% var __viewMode = (typeof view_mode !== 'undefined' && view_mode) ? view_mode : ''; %>
<% var __order   = (typeof order_mode !== 'undefined' && order_mode) ? order_mode : 'delivery'; %>
<% var __pickup  = (__order === 'pickup' && !__viewMode); %>
<% var __browseActive = (typeof browse_active !== 'undefined' && browse_active); %>

<% if (__pickup) { %>
<%# ══════════════════════════════════════════════════════════════════
    PICKUP — split list + local stylized map
   ══════════════════════════════════════════════════════════════════ %>
<%- include('../partials/pickup') -%>

<% } else if (!__viewMode) { %>
<%# ══════════════════════════════════════════════════════════════════
    DEFAULT HOME — full mockup design
   ══════════════════════════════════════════════════════════════════ %>
<div class="home-shell">

    <%# Left filter sidebar (desktop ≥ 1024 px; mobile uses bottom-sheet) %>
    <%- include('../partials/filter-sidebar') -%>

    <div class="home-shell__content">

        <%# Compact "show filters" icon — only visible when the sidebar
            is collapsed (CSS gates it on .home-shell.is-filters-collapsed).
            Clicking it re-opens the sidebar. The HIDE control lives on
            the sidebar header itself (see filter-sidebar.ejs). %>
        <button type="button" class="filters-show" data-action="toggle-filters" aria-label="Show filters" title="Show filters">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"/></svg>
            <span>Filters</span>
        </button>

        <%# HERO removed per user — the home now opens straight at the
            categories. Location is set via the header chip. %>

        <%# ── CUISINE RAIL (slider only, with prev/next arrows) ──── %>
        <%# Heading text + "View all" intentionally omitted per the
            user — just the horizontal category slider. The arrows
            scroll the rail; /js/pages/home.js wires them and hides
            an arrow when there's nothing more to scroll that way. %>
        <%# Browse mode — a "back to home" bar above the filtered set. %>
        <% if (__browseActive) { %>
        <a href="/" class="browse-back" data-action="view-home">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
            Back to home
        </a>
        <% } %>

        <% if (!__browseActive && cuisines && cuisines.length > 0) { %>
        <section aria-label="Browse cuisines" class="rail-wrap" data-rail-wrap>
            <button type="button" class="rail-arrow rail-arrow--prev" data-rail-prev aria-label="Scroll left" hidden>
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>
            </button>
            <ul class="cuisine-rail" role="list" data-rail>
                <% cuisines.forEach(function (c) { %>
                    <li class="cuisine-rail__item" data-search-name="<%= c.searchName || (c.name||'').toLowerCase() %>">
                        <a class="cuisine-rail__link" href="/?cuisine=<%= encodeURIComponent(c.searchName || (c.name||'').toLowerCase()) %>" data-action="pick-cuisine">
                            <span class="cuisine-rail__disc">
                                <% if (c.icon) { %><img src="<%= c.icon %>" alt="" loading="lazy" data-img-fallback><% } else { %><%= c.initial || '🍽️' %><% } %>
                            </span>
                            <span class="cuisine-rail__name"><%= c.name %></span>
                        </a>
                    </li>
                <% }); %>
            </ul>
            <button type="button" class="rail-arrow rail-arrow--next" data-rail-next aria-label="Scroll right" hidden>
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
            </button>
        </section>
        <% } %>

        <%# ── WELCOME STRIP (super-admin configured) ───────────────
            Shown right under the category rail, OUTSIDE the feed-swap region
            so a cuisine filter doesn't drop it. Text mode = gradient hero
            (title + subtitle); image mode = a full-width banner. Only ONE
            renders (per the admin's content_type). Hidden in browse mode. %>
        <%# Welcome strip (LEFT) + desktop "get the app" card (RIGHT) on ONE line.
            On mobile only the welcome strip shows (the app card is desktop-only).
            Hidden entirely in browse mode. %>
        <% if (!__browseActive) { %>
        <div class="home-topline">
            <% if (typeof welcome_banner !== 'undefined' && welcome_banner) { %>
                <% var wb = welcome_banner; var wbImage = Number(wb.type) === 2; %>
                <section class="welcome-strip welcome-strip--<%= wbImage ? 'image' : 'text' %>" aria-label="Welcome">
                    <% if (wb.link) { %><a class="welcome-strip__link" href="<%= wb.link %>"><% } %>
                        <% if (wbImage && wb.image_url) { %>
                            <img class="welcome-strip__img" src="<%= wb.image_url %>" alt="<%= wb.title || 'Welcome' %>" loading="lazy">
                        <% } else { %>
                            <span class="welcome-strip__ic" aria-hidden="true">👋</span>
                            <span class="welcome-strip__body">
                                <% if (wb.title) { %><h2 class="welcome-strip__title"><%= wb.title %></h2><% } %>
                                <% if (wb.subtitle) { %><p class="welcome-strip__sub"><%= wb.subtitle %></p><% } %>
                            </span>
                        <% } %>
                    <% if (wb.link) { %></a><% } %>
                </section>
            <% } %>
            <%# Get-the-app card — DESKTOP-ONLY (hidden on mobile via CSS). iOS /
                Android tabs (pure-CSS radios) switch the QR. Each QR encodes
                <site>/app?platform=… which the /app route redirects to the store. %>
            <aside class="app-mini" aria-label="Download the <%= brand.name %> app">
                <%# Default = Android (checked); tabs sit at the TOP of the body so it's
                    obvious you PICK a platform, then scan the QR that swaps in below. %>
                <input type="radio" name="app-plat" id="app-android" class="app-mini__radio" checked>
                <input type="radio" name="app-plat" id="app-ios" class="app-mini__radio">
                <div class="app-mini__qr">
                    <img class="app-mini__img app-mini__img--ios" src="/img/app-qr-ios.svg?v=<%= ASSET_VERSION %>" alt="Scan to install on iOS" loading="lazy">
                    <img class="app-mini__img app-mini__img--android" src="/img/app-qr-android.svg?v=<%= ASSET_VERSION %>" alt="Scan to install on Android" loading="lazy">
                </div>
                <div class="app-mini__body">
                    <div class="app-mini__tabs" role="tablist" aria-label="Choose your platform">
                        <label for="app-android" class="app-mini__tab">
                            <svg class="app-mini__tab-ic" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M6 18c0 .55.45 1 1 1h1v3.5a1.5 1.5 0 0 0 3 0V19h2v3.5a1.5 1.5 0 0 0 3 0V19h1c.55 0 1-.45 1-1V8H6v10zM3.5 8A1.5 1.5 0 0 0 2 9.5v7a1.5 1.5 0 0 0 3 0v-7A1.5 1.5 0 0 0 3.5 8zm17 0a1.5 1.5 0 0 0-1.5 1.5v7a1.5 1.5 0 0 0 3 0v-7A1.5 1.5 0 0 0 20.5 8zm-4.97-5.84 1.3-1.3a.5.5 0 0 0-.71-.71l-1.48 1.48A6.9 6.9 0 0 0 12 1c-.96 0-1.86.23-2.66.63L7.85.15a.5.5 0 1 0-.71.71l1.31 1.31A6.98 6.98 0 0 0 6 7h12c0-1.99-.97-3.75-2.44-4.84zM10 5H9V4h1v1zm5 0h-1V4h1v1z"/></svg>
                            <span>Android</span>
                        </label>
                        <label for="app-ios" class="app-mini__tab">
                            <svg class="app-mini__tab-ic" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.05 20.28c-.98.95-2.05.8-3.08.35-1.09-.46-2.09-.48-3.24 0-1.44.62-2.2.44-3.06-.35C2.79 15.25 3.51 7.59 9.05 7.31c1.35.07 2.29.74 3.08.8 1.18-.24 2.31-.93 3.57-.84 1.51.12 2.65.72 3.4 1.8-3.12 1.87-2.38 5.98.48 7.13-.57 1.5-1.31 2.99-2.54 4.09zM12.03 7.25c-.15-2.23 1.66-4.07 3.74-4.25.29 2.58-2.34 4.5-3.74 4.25z"/></svg>
                            <span>iOS</span>
                        </label>
                    </div>
                    <p class="app-mini__title">Get the <%= brand.name %> app</p>
                    <p class="app-mini__sub">Tap a store above, then scan to install</p>
                </div>
            </aside>
        </div>

        <%# Offer-banner carousel — super-admin promo slider under the category
            rail. Each card links to its own filtered restaurant grid (href built
            by the api from the banner rule). Hidden when no active banners. %>
        <% if (typeof offer_banners !== 'undefined' && offer_banners && offer_banners.length) { %>
            <%- include('../partials/offer-banner-row', { offer_banners: offer_banners }) %>
        <% } %>
        <% } %>

        <%# ── TOP RESTAURANTS ──────────────────────────────────── %>
        <%# data-home-feed: the ONLY region swapped on an in-place
            cuisine filter. The cuisine rail + filter sidebar above stay
            physically in the DOM (no flicker, no scroll reset); only
            this restaurant list reloads. Always rendered (even when
            empty) so the partial-swap target is always present. %>
        <div data-home-feed>
        <% if (typeof cuisine_no_match !== 'undefined' && cuisine_no_match && selected_cuisine) { %>
            <p class="feed-note">No restaurants serving “<%= selected_cuisine.charAt(0).toUpperCase() + selected_cuisine.slice(1) %>” near you yet — here’s what else is available.</p>
        <% } %>

        <%# ── HOME SECTIONS — rendered in the admin-configured Feed Order (all
            6 sections, incl. My Favourites + Top restaurants). On a filtered /
            cuisine view home_feed_order is absent → the DEFAULT order applies
            (favourites → curated(empty) → restaurants), so the filtered page
            looks unchanged. My Favourites cards are stripped from `featured`
            in the controller so they never duplicate. %>
        <%
            var DEFAULT_FEED_ORDER = [
                { key: 'favourites', status: 1 }, { key: 'order-again', status: 1 }, { key: 'featured', status: 1 }, { key: 'sponsored', status: 1 },
                { key: 'collections', status: 1 }, { key: 'products', status: 1 }, { key: 'restaurants', status: 1 }
            ];
            var feedOrder = (typeof home_feed_order !== 'undefined' && home_feed_order && home_feed_order.length) ? home_feed_order : DEFAULT_FEED_ORDER;
            var __feed = (typeof home_feed !== 'undefined' && home_feed) ? home_feed : [];
            var rowsBySection = {};
            __feed.forEach(function (row) { var k = row.section || row.type; (rowsBySection[k] = rowsBySection[k] || []).push(row); });
            var myFavs = (typeof my_favourites !== 'undefined' && my_favourites) ? my_favourites : [];
            var orderAgainList = (typeof order_again !== 'undefined' && order_again) ? order_again : [];
        %>
        <% feedOrder.forEach(function (sec) { %>
            <% if (Number(sec.status) === 0) { return; } %>

            <% if (sec.key === 'favourites') { %>
                <% if (user_session && myFavs.length > 0) { %>
                <section aria-labelledby="my-fav-rail-title" data-rail-wrap>
                    <div class="hv2-head">
                        <h2 id="my-fav-rail-title" class="hv2-head__title">
                            <svg class="hv2-head__title-icon" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
                            My Favourites
                        </h2>
                        <div class="hv2-head__actions">
                            <a href="/account?tab=favourites" class="hv2-head__link" data-action="view-favourites">View all</a>
                            <div class="hv2-head__nav">
                                <button type="button" class="rail-arrow rail-arrow--prev" data-rail-prev aria-label="Scroll left" disabled>
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>
                                </button>
                                <button type="button" class="rail-arrow rail-arrow--next" data-rail-next aria-label="Scroll right" disabled>
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
                                </button>
                            </div>
                        </div>
                    </div>
                    <div class="rail-wrap home-rail-wrap">
                        <ul class="home-rail" role="list" data-rail>
                            <% myFavs.forEach(function (r) { %>
                                <%- include('../partials/restaurant-card', { r: r, forceFavourite: true }) %>
                            <% }); %>
                        </ul>
                    </div>
                </section>
                <% } %>

            <% } else if (sec.key === 'order-again') { %>
                <% if (user_session && orderAgainList.length > 0) { %>
                <section aria-labelledby="order-again-title" data-rail-wrap>
                    <div class="hv2-head">
                        <h2 id="order-again-title" class="hv2-head__title">
                            <svg class="hv2-head__title-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/></svg>
                            Order again
                        </h2>
                        <div class="hv2-head__actions">
                            <div class="hv2-head__nav">
                                <button type="button" class="rail-arrow rail-arrow--prev" data-rail-prev aria-label="Scroll left" disabled>
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>
                                </button>
                                <button type="button" class="rail-arrow rail-arrow--next" data-rail-next aria-label="Scroll right" disabled>
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
                                </button>
                            </div>
                        </div>
                    </div>
                    <div class="rail-wrap home-rail-wrap">
                        <ul class="home-rail" role="list" data-rail>
                            <% orderAgainList.forEach(function (r) { %>
                                <%- include('../partials/restaurant-card', { r: r, showOffer: true, metaIcons: true, showDelivery: true }) %>
                            <% }); %>
                        </ul>
                    </div>
                </section>
                <% } %>

            <% } else if (sec.key === 'restaurants') { %>
                <% if (featured && featured.length > 0) { %>
                <section aria-labelledby="resto-rail-title">
                    <div class="hv2-head">
                        <h2 id="resto-rail-title" class="hv2-head__title"><% if (__browseActive) { %><%= browse_label %><% } else if (typeof cuisine_no_match !== 'undefined' && cuisine_no_match) { %>More restaurants near you<% } else if (typeof selected_cuisine_label !== 'undefined' && selected_cuisine_label) { %><%= selected_cuisine_label %> restaurants near you<% } else { %>Top restaurants near you<% } %></h2>
                        <% if (!__browseActive) { %><a href="/?view=restaurants" class="hv2-head__link" data-action="view-all">View all</a><% } %>
                    </div>
                    <ul class="resto-rail" role="list" data-load-target>
                        <% featured.forEach(function (r) { %>
                            <%- include('../partials/restaurant-card', { r: r, showOffer: true, metaIcons: true, showDelivery: true }) %>
                        <% }); %>
                    </ul>
                    <%# Home shows the top ~24; the rest live behind "View all". %>
                    <% if (typeof featured_more !== 'undefined' && featured_more) { %>
                        <div class="section__loadmore">
                            <a href="/?view=restaurants" class="btn btn--ghost btn--lg" data-action="view-all">View all restaurants</a>
                        </div>
                    <% } %>
                </section>
                <% } else if (__browseActive) { %>
                <p class="feed-note">No restaurants in this selection right now.</p>
                <% } %>

            <% } else { %>
                <%# Curated section: featured / sponsored / collections / products. %>
                <% (rowsBySection[sec.key] || []).forEach(function (row) { %>
                    <% if (row.type === 'product') { %>
                        <%- include('../partials/home-product-row', { row: row }) %>
                    <% } else { %>
                        <%- include('../partials/home-row', { row: row }) %>
                    <% } %>
                <% }); %>
            <% } %>

        <% }); %>
        </div><%# /[data-home-feed] %>

        <%# "Best offers for you" + "Popular cuisines" sections removed per request. %>

        <%# ── FEATURE STRIP (static) ───────────────────────────── %>
        <section aria-label="Why EatNDeal">
            <div class="feature-strip">
                <div class="feature-item feature-item--a"><span class="feature-item__icon">🛵</span><span><span class="feature-item__title">Fast Delivery</span><br><span class="feature-item__sub">Get your food in 20-30 minutes</span></span></div>
                <div class="feature-item feature-item--b"><span class="feature-item__icon">📍</span><span><span class="feature-item__title">Live Tracking</span><br><span class="feature-item__sub">Track your order in real-time</span></span></div>
                <div class="feature-item feature-item--c"><span class="feature-item__icon">🛡️</span><span><span class="feature-item__title">Safe Payments</span><br><span class="feature-item__sub">100% secure payment options</span></span></div>
                <div class="feature-item feature-item--d"><span class="feature-item__icon">🏷️</span><span><span class="feature-item__title">Best Offers</span><br><span class="feature-item__sub">Exclusive deals &amp; discounts</span></span></div>
            </div>
        </section>

        <%# The big "app CTA" section was replaced by the compact desktop-only
            .app-mini card at the TOP of the home (see above). Mobile shows no
            app-download prompt — you're already on a phone. %>

    </div><%# /.home-shell__content %>
</div><%# /.home-shell %>

<% } else if (__viewMode === 'restaurant') { %>
<%# ══════════════════════════════════════════════════════════════════
    RESTAURANT — full detail page (left menu · center · right info)
   ══════════════════════════════════════════════════════════════════ %>
<%- include('../partials/restaurant-detail') -%>

<% } else if (__viewMode === 'product') { %>
<%# ══════════════════════════════════════════════════════════════════
    PRODUCT — detail page with selectable options (size / toppings / qty)
   ══════════════════════════════════════════════════════════════════ %>
<%- include('../partials/product-detail') -%>

<% } else { %>
<%# ══════════════════════════════════════════════════════════════════
    VIEW MODES — focused single-section layouts (cuisines / restaurants)
   ══════════════════════════════════════════════════════════════════ %>
<nav class="view-mode-bar" aria-label="Back to home">
    <a class="view-mode-bar__back" href="/" data-action="view-home">
        <svg aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
        <span>Back to home</span>
    </a>
    <h1 class="view-mode-bar__title">
        <% if (__viewMode === 'cuisines') { %>All cuisines<% } %>
        <% if (__viewMode === 'restaurants') { %>All restaurants<% } %>
        <% if (__viewMode === 'restaurant') { %><%= selected_restaurant ? selected_restaurant.name : 'Restaurant' %><% } %>
    </h1>
</nav>

<%# View=cuisines → full cuisine grid %>
<% if (__viewMode === 'cuisines' && cuisines && cuisines.length > 0) { %>
<section class="section">
    <ul class="cuisine-grid" role="list">
        <% cuisines.forEach(function (c) { %>
            <li class="cuisine-grid__item" data-search-name="<%= c.searchName || (c.name||'').toLowerCase() %>">
                <a class="cuisine-pill" href="/?cuisine=<%= encodeURIComponent(c.searchName || (c.name||'').toLowerCase()) %>" data-action="pick-cuisine">
                    <span class="cuisine-pill__icon cuisine-pill__icon--placeholder" data-tint="<%= c.tint %>" aria-hidden="true">
                        <span class="cuisine-pill__initial"><%= c.initial || '' %></span>
                        <% if (c.icon) { %><img class="cuisine-pill__photo" src="<%= c.icon %>" alt="" width="48" height="48" loading="lazy" data-img-fallback><% } %>
                    </span>
                    <span class="cuisine-pill__name"><%= c.name %></span>
                </a>
            </li>
        <% }); %>
    </ul>
</section>
<% } %>

<%# View=restaurants → full restaurant grid (paginated) %>
<% if (__viewMode === 'restaurants' && featured && featured.length > 0) { %>
<section class="section" data-paginate-section="featured">
    <ul class="resto-rail resto-rail--grid" role="list" data-load-target>
        <% featured.forEach(function (r) { %>
            <%- include('../partials/restaurant-card', { r: r, showOffer: true }) %>
        <% }); %>
    </ul>
    <% if (typeof featured_more !== 'undefined' && featured_more) { %>
        <div class="section__loadmore" data-load-more="featured" data-offset="<%= featured.length %>">
            <button type="button" class="btn btn--ghost btn--lg section__loadmore-btn">See more</button>
        </div>
    <% } %>
</section>
<% } %>

<% } %>
