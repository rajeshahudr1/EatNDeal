<%#
  views/loyalty/config.ejs

  Loyalty Configuration — ONE page, ONE form, ONE "Save All Settings" (legacy
  single-form concept). Header config + per-section on/off toggles + all 10
  sections post together to /loyalty/save-all. Multi-row sections (cashback,
  product, streak, BOGO, special) are inline-editable rows with add/remove;
  removing a row drops it from the POST (the api soft-deletes it).
  `d` = { company, cashback, tiers, referral, challenges, events,
  reviewRewards, product, bogof, special }.

  LAYOUT = a 1:1 copy of the legacy POS page
  (backend/modules/pos/views/loyalty-configuration/index.php): same section
  titles, sub-lines, COLUMN HEADERS, column order, dropdown option lists and
  units. The client works off that page daily, so anything renamed or
  re-ordered here reads as a bug to them.

  Two structural notes, both forced by constraints we may not change:
   • Add-able sections can't use <table>/<tr>: public/js/pages/loyalty.js clones
     [data-row-template] via `div.innerHTML = tpl.innerHTML`, and the HTML
     parser DROPS a bare <tr> inside a <div>. So those sections use a CSS-grid
     "table" (.ly-tbl) whose head row carries the legacy column names and whose
     rows keep the existing [data-erow] hooks. Fixed sections (1/3/6/9/10) have
     no template and use a real <table>.
   • Only the sections in SHOW (below) are rendered, and the api writes ONLY
     what the form sends — an absent field/section is left untouched, never
     zeroed. So hidden sections need no carry-over inputs.

  Used: Controllers/LoyaltyController.loyaltyConfig (shell layout).
-%>
<%
    var sym = fmt.currencySymbol(brand);
    var co = d.company, cb = d.cashback, tc = d.tiers, rs = d.referral,
        ch = d.challenges, ev = d.events, rr = d.reviewRewards,
        pc = d.product, bg = d.bogof, so = d.special;
    var isSuper = (typeof company_ctx !== 'undefined' && company_ctx) ? company_ctx.isSuper : false;
    var soToday = new Date().toISOString().slice(0, 10);
    // Bronze / Silver / Gold — exactly what the legacy POS Tier dropdown offers
    // (common/config/params.php $tierList). There is NO "All tiers": the stamp
    // card is per-tier by design, and adding that option let a rule be saved
    // with tier_type = '', which the earn engine (Helpers/loyalty
    // earnStampCashback) can never match to a customer's tier.
    var cashTierList = [['bronze', 'Bronze'], ['silver', 'Silver'], ['gold', 'Gold']];
    var tierRows = [['bronze', 'Bronze'], ['silver', 'Silver'], ['gold', 'Gold']];
    // Legacy $loyalty_smart_campaign — these three, in this order, with these
    // labels. most_orders / most_reviews exist in our api's CAMPAIGN_TYPES but
    // the legacy page has never shown them (see the hidden carry-overs below).
    var campRows = [['most_referrals', 'Most Referrals (Count)'], ['top_spenders', 'Top Spenders (Count)'], ['inactive', 'Inactive (Days)']];
    function esc(s) { return String(s == null ? '' : s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;'); }
    function mSelect(name, opts, selected) {
        var sel = {}; (selected || []).forEach(function (id) { sel[String(id)] = true; });
        var h = '<select multiple size="4" name="' + name + '" class="ly-mselect">';
        opts.forEach(function (o) { h += '<option value="' + o.id + '"' + (sel[String(o.id)] ? ' selected' : '') + '>' + esc(o.name) + '</option>'; });
        return h + '</select>';
    }
    function tog(name, on) {
        // The hidden __present marker tells the api this section WAS rendered.
        // An unchecked checkbox posts nothing, exactly like a section that isn't
        // on the form at all — without the marker the api can't tell 'switch it
        // off' from 'not my section' and would switch off every hidden one.
        return '<input type="hidden" name="' + name + '__present" value="1">'
            + '<label class="ly-switch ly-switch--inline"><input type="checkbox" name="' + name + '" value="1"' + (on ? ' checked' : '') + '><span class="ly-switch__ui" aria-hidden="true"></span></label>';
    }

    /*
     * WHICH SECTIONS THIS PAGE SHOWS.
     *
     * The marketplace only runs Referral Reward + Community Rewards for now, so
     * the other eight are hidden rather than deleted: the api still accepts them
     * and legacy restaurants still use every rule type, so ripping the markup
     * out would only mean rewriting it later.
     *
     * HIDDEN ≠ SWITCHED OFF ≠ WIPED. A hidden section posts NOTHING, and Save
     * All overwrites whatever it receives — so each hidden section keeps a
     * hidden input carrying its CURRENT value (see below). Without that, one
     * save would blank every rule the section owns.
     *
     * To bring a section back: flip it to true here. Nothing else to change.
     */
    var SHOW = {
        events:   false,   // 1. Tell Us About You reward
        cashback: false,   // 2. Digital Stamp Card
        referral: true,    // 3. Referral Reward      ← keep
        product:  false,   // 4. Product Perks
        streak:   false,   // 5. Streak Bonus
        reviews:  true,    // 6. Community Rewards    ← keep
        bogof:    false,   // 7. Buy X Get Y (BOGO)
        special:  false,   // 8. Celebration Reward
        tiers:    false,   // 9. Membership Tiers
        campaign: false,   // 10. Performance Plus Reward
    };
%>
<div class="ly">

    <% if (load_error) { %>
        <div class="ly__head"><div><h2 class="ly__title">🎁 Loyalty Configuration</h2></div></div>
        <div class="ly-empty"><span class="ly-empty__ic" aria-hidden="true">🏢</span><p class="ly-empty__msg"><%= load_error %></p></div>
    <% } else { %>

    <form id="ly-config-form" method="post" action="/loyalty/save-all">

        <div class="ly__head ly-cfg-head">
            <div>
                <h2 class="ly__title">🎁 Loyalty Configuration</h2>
                <p class="ly__sub">Configure all loyalty program rules and cashback</p>
            </div>
            <div class="ly-card__headact">
                <%# The master ON/OFF for this scope. Legacy's POS page has no such
                    switch (a restaurant's loyalty is enabled elsewhere), but the
                    MARKETPLACE has nowhere else to turn its own programme on —
                    and with it off, loadConfig() returns null and every earn
                    silently does nothing: a Cashback Review can be approved and
                    the customer still never paid. It has to be reachable here. %>
                <% if (co && isSuper) { %>
                <label class="ly-switch-form">
                    <span class="ly-switch-form__lbl">Loyalty enabled</span>
                    <%# __present, NOT the usual hidden-0 + checkbox-1 pair: that
                        posts BOTH values under one name and Express hands the api
                        an array ['0','1'], which Number() reads as NaN — the
                        switch would save as OFF every time. The marker says "this
                        control was on the form"; an unchecked box then simply
                        sends nothing. %>
                    <input type="hidden" name="loyalty_status__present" value="1">
                    <span class="ly-switch">
                        <input type="checkbox" name="loyalty_status" value="1" <%= co.loyaltyOn ? 'checked' : '' %>>
                        <span class="ly-switch__ui" aria-hidden="true"></span>
                    </span>
                </label>
                <% } %>
                <button type="submit" class="ly-btn ly-btn--primary">💾 Save All Settings</button>
            </div>
        </div>

        <%# ── Program + wallet header ── %>
        <section class="card ly-card">
            <%# The top bar carries EXACTLY the 5 fields the legacy POS page has
                (admin/pos/loyalty-configuration/index), in its order and with
                its labels. Nothing else belongs here — the earlier version had
                6 boxes with invented names ("Base cashback (Cash King) %",
                "Remind before (days)"…), which didn't match what the client
                already knows from the POS. %>
            <div class="ly-grid ly-grid--top">
                <div class="ly-field">
                    <label for="cf-expiry">Expiry Duration (Days) <span class="ly-info" tabindex="0" role="img" aria-label="Cashback earned on a particular day must be used within these days, otherwise it will expire automatically." data-tip="Cashback earned on a particular day must be used within these days, otherwise it will expire automatically.">i</span></label>
                    <input id="cf-expiry" type="number" name="expiry_duration_days" min="0" value="<%= cb ? cb.config.expiry_duration_days : 0 %>" required>
                </div>
                <div class="ly-field">
                    <label for="cf-notify">Notify Before (Days)</label>
                    <input id="cf-notify" type="number" name="notify_before_days" min="0" value="<%= cb ? cb.config.notify_before_days : 0 %>" required>
                </div>
                <%# Maximum Cashback (use_max_cashback) removed on request. The
                    redeem cap is taken from whichever company the order is
                    placed at; the marketplace pool doesn't need its own flat cap.
                    NOT posted here, so Save All leaves the column untouched (the
                    api writes only the fields it receives) — no data is wiped,
                    the field is just no longer editable from this page. %>
                <%# Cash Reward / Pickup Reward are the ORDER-cashback knobs, and
                    those sections are hidden for now — so the boxes are gone but
                    the values must still POST. Save All overwrites the whole
                    company_loyalty row, so omitting them would zero cash_king /
                    collection_cashback on the first save. %>

                <%# Commission + the two toggles are NOT on the legacy top bar, so
                    they're not shown — but they must still POST, or this form
                    would save them as blank and silently wipe the commission
                    skim (Helpers/loyalty award()) and the phone-order rule.
                    Carried as hidden inputs at their current values. %>
            </div>
        </section>

        <%# ── 1. Tell Us About You reward (events) ── %>
        <% if (ev && SHOW.events) { %>
        <section class="card ly-card">
            <div class="ly-card__head"><div class="ly-card__headtxt"><h3 class="card__title">1. Tell Us About You reward</h3><p class="ly-card__sub">Cashback on user actions</p></div><%- tog('on_event', ev.masterOn) %></div>
            <%# Legacy shows ONE event row — Account Completion (event_type = 2).
                Sign-up (1) and Google review (3) rows were ours, not theirs, and
                the client rejected them. They still exist in the api's
                EVENT_TYPES loop, so their current values ride along as hidden
                inputs — drop them and Save All would zero those rows. %>
            <table class="ly-ftbl">
                <thead><tr><th>Event</th><th>Cashback</th></tr></thead>
                <tbody>
                    <% var ev2 = ev.events[2] || { cashback: 0 }; %>
                    <tr>
                        <td>
                            <%# Single-option select = the legacy control, verbatim.
                                It carries no name: the api keys events by its fixed
                                EVENT_TYPES list, so there's nothing to post. %>
                            <select aria-label="Event"><option value="2">Account Completion</option></select>
                        </td>
                        <td>
                            <div class="ly-money ly-money--suffix">
                                <input id="ev2-c" type="number" name="event_2_cashback" step="0.01" min="0" value="<%= ev2.cashback %>">
                                <span class="ly-money__sym"><%= sym %></span>
                            </div>
                        </td>
                    </tr>
                </tbody>
            </table>
        </section>
        <% } %>

        <%# ── 2. Digital Stamp Card (multi-row, %) ── %>
        <% if (cb && SHOW.cashback) { %>
        <section class="card ly-card">
            <div class="ly-card__head"><div class="ly-card__headtxt"><h3 class="card__title">2. Digital Stamp Card</h3><p class="ly-card__sub">Set cashback based on the minimum amount of every order.</p></div><div class="ly-card__headact"><%- tog('on_cashback', cb.masterOn) %><button type="button" class="ly-btn ly-btn--primary ly-btn--sm" data-action="ly-row-add" data-rows="cashback">+ Add</button></div></div>
            <%# Legacy column order: Min Order Amount | Cashback (%) | Tier |
                Order Count | Action. Order Count was missing entirely — the
                column exists on loyalty_cashback_rule and the earn engine
                reads it (earnStampCashback: every `order_count` stamps
                unlock), so without it the admin couldn't set how many stamps
                a card needs. %>
            <div class="ly-tbl ly-tbl--stamp">
                <div class="ly-tbl__head" aria-hidden="true"><span>Min Order Amount</span><span>Cashback</span><span>Tier</span><span>Order Count</span><span>Action</span></div>
                <div class="ly-erows" data-rows-body="cashback" data-next="<%= cb.rules.length %>">
                    <% cb.rules.forEach(function (r, i) { %>
                    <div class="ly-erow" data-erow>
                        <input type="hidden" name="cashback[<%= i %>][id]" value="<%= r.id %>">
                        <div class="ly-field"><label>Min Order Amount</label><input type="number" name="cashback[<%= i %>][min_order_amount]" step="0.01" min="0" value="<%= r.min_order_amount %>"></div>
                        <div class="ly-field"><label>Cashback</label><div class="ly-money ly-money--suffix"><input type="number" name="cashback[<%= i %>][cashback]" step="0.01" min="0" max="100" value="<%= r.cashback %>"><span class="ly-money__sym">%</span></div></div>
                        <div class="ly-field"><label>Tier</label><select name="cashback[<%= i %>][tier_type]"><% cashTierList.forEach(function (t) { %><option value="<%= t[0] %>" <%= (r.tier_type || '') === t[0] ? 'selected' : '' %>><%= t[1] %></option><% }); %></select></div>
                        <div class="ly-field"><label>Order Count</label><input type="number" name="cashback[<%= i %>][order_count]" min="1" step="1" value="<%= r.order_count || 1 %>"></div>
                        <button type="button" class="ly-iconbtn ly-iconbtn--danger ly-erow__del" data-action="ly-row-del" aria-label="Remove">🗑</button>
                    </div>
                    <% }); %>
                </div>
            </div>
            <p class="ly-none" data-rows-empty <%= cb.rules.length ? 'hidden' : '' %>>No cashback rules — click “+ Add”.</p>
            <%# Same column order as the rendered row above — a "+ Add" row that
                didn't match would save different fields than an existing one. %>
            <template data-row-template="cashback"><div class="ly-erow" data-erow><input type="hidden" name="cashback[__IDX__][id]" value=""><div class="ly-field"><label>Min Order Amount</label><input type="number" name="cashback[__IDX__][min_order_amount]" step="0.01" min="0" value=""></div><div class="ly-field"><label>Cashback</label><div class="ly-money ly-money--suffix"><input type="number" name="cashback[__IDX__][cashback]" step="0.01" min="0" max="100" value=""><span class="ly-money__sym">%</span></div></div><div class="ly-field"><label>Tier</label><select name="cashback[__IDX__][tier_type]"><% cashTierList.forEach(function (t) { %><option value="<%= t[0] %>"><%= t[1] %></option><% }); %></select></div><div class="ly-field"><label>Order Count</label><input type="number" name="cashback[__IDX__][order_count]" min="1" step="1" value="1"></div><button type="button" class="ly-iconbtn ly-iconbtn--danger ly-erow__del" data-action="ly-row-del" aria-label="Remove">🗑</button></div></template>
        </section>
        <% } %>

        <%# ── 3. Referral Reward (single, £) ── %>
        <% if (rs && SHOW.referral) { %>
        <section class="card ly-card">
            <div class="ly-card__head"><div class="ly-card__headtxt"><h3 class="card__title">3. Referral Reward</h3><p class="ly-card__sub">Cashback referrer &amp; referee</p></div><%- tog('on_referral', rs.masterReferral) %></div>
            <%# Legacy columns: Trigger | Referrer Cashback | Referee Cashback |
                Type. The Trigger dropdown has ONE live option there — "First
                Order" (2); "Signup" is commented out in the legacy view — so
                offering "Friend signs up" here let an admin pick a trigger the
                POS can't. Type is the read-only £ box (value_type is forced to
                £ by the api, so it posts nothing). %>
            <table class="ly-ftbl">
                <thead><tr><th>Trigger</th><th>Referrer Cashback</th><th>Referee Cashback</th><th>Type</th></tr></thead>
                <tbody>
                    <tr>
                        <td><select id="rf-tr" name="trigger" aria-label="Trigger"><option value="2">First Order</option></select></td>
                        <td><input id="rf-rr" type="number" name="referrer_cashback" step="0.01" min="0" value="<%= rs.referral.referrer_cashback %>" aria-label="Referrer Cashback"></td>
                        <td><input id="rf-re" type="number" name="referee_cashback" step="0.01" min="0" value="<%= rs.referral.referee_cashback %>" aria-label="Referee Cashback"></td>
                        <%# Type is always £ (value_type is forced flat by the api).
                            Was a full readonly input showing a lone "£", which
                            read as a broken empty box. Just the symbol now. %>
                        <td><span class="ly-unit"><%= sym %></span></td>
                    </tr>
                </tbody>
            </table>
        </section>
        <% } %>

        <%# ── 4. Product Perks (multi-row, £) ── %>
        <% if (pc && SHOW.product) { %>
        <section class="card ly-card">
            <div class="ly-card__head"><div class="ly-card__headtxt"><h3 class="card__title">4. Product Perks</h3><p class="ly-card__sub">Cashback on low selling items</p></div><div class="ly-card__headact"><%- tog('on_product', pc.masterOn) %><% if (pc.products.length) { %><button type="button" class="ly-btn ly-btn--primary ly-btn--sm" data-action="ly-row-add" data-rows="product">+ Add</button><% } %></div></div>
            <% if (!pc.products.length) { %><p class="ly-none">No products found for this store yet.</p><% } else { %>
            <p class="ly-hint">Cashback can’t exceed the lowest selected product’s price. Ctrl/Cmd-click to pick multiple products.</p>
            <%# Legacy column order: Product | Cashback | Action (Product FIRST —
                ours had Cashback first). %>
            <div class="ly-tbl ly-tbl--product">
                <div class="ly-tbl__head" aria-hidden="true"><span>Product</span><span>Cashback</span><span>Action</span></div>
                <div class="ly-erows" data-rows-body="product" data-next="<%= pc.rules.length %>">
                    <% pc.rules.forEach(function (r, i) { %>
                    <div class="ly-erow ly-erow--wide" data-erow>
                        <input type="hidden" name="product[<%= i %>][id]" value="<%= r.id %>">
                        <div class="ly-field ly-field--grow"><label>Product</label><%- mSelect('product[' + i + '][product_ids][]', pc.products, r.product_ids) %></div>
                        <div class="ly-field"><label>Cashback</label><div class="ly-money ly-money--suffix"><input type="number" name="product[<%= i %>][cashback]" step="0.01" min="0" value="<%= r.cashback %>"><span class="ly-money__sym"><%= sym %></span></div></div>
                        <button type="button" class="ly-iconbtn ly-iconbtn--danger ly-erow__del" data-action="ly-row-del" aria-label="Remove">🗑</button>
                    </div>
                    <% }); %>
                </div>
            </div>
            <p class="ly-none" data-rows-empty <%= pc.rules.length ? 'hidden' : '' %>>No product cashback rules — click “+ Add”.</p>
            <template data-row-template="product"><div class="ly-erow ly-erow--wide" data-erow><input type="hidden" name="product[__IDX__][id]" value=""><div class="ly-field ly-field--grow"><label>Product</label><%- mSelect('product[__IDX__][product_ids][]', pc.products, []) %></div><div class="ly-field"><label>Cashback</label><div class="ly-money ly-money--suffix"><input type="number" name="product[__IDX__][cashback]" step="0.01" min="0" value=""><span class="ly-money__sym"><%= sym %></span></div></div><button type="button" class="ly-iconbtn ly-iconbtn--danger ly-erow__del" data-action="ly-row-del" aria-label="Remove">🗑</button></div></template>
            <% } %>
        </section>
        <% } %>

        <%# ── 5. Streak Bonus (multi-row, £) ── %>
        <% if (rs && SHOW.streak) { %>
        <section class="card ly-card">
            <div class="ly-card__head"><div class="ly-card__headtxt"><h3 class="card__title">5. Streak Bonus</h3><p class="ly-card__sub">Cashback users for consistent orders</p></div><div class="ly-card__headact"><%- tog('on_streak', rs.masterStreak) %><button type="button" class="ly-btn ly-btn--primary ly-btn--sm" data-action="ly-row-add" data-rows="streak">+ Add</button></div></div>
            <%# Legacy column order: Order Count | Duration | Cashback | Min Order
                Amount | Action. The "Kind" (type) select was ours — legacy has
                that <th> commented out and never posts the field. It stays as a
                hidden input at the row's current value because our api writes
                `type` on every save, so omitting it would flip Milestone rows
                back to Streak. %>
            <div class="ly-tbl ly-tbl--streak">
                <div class="ly-tbl__head" aria-hidden="true"><span>Order Count</span><span>Duration</span><span>Cashback</span><span>Min Order Amount</span><span>Action</span></div>
                <div class="ly-erows" data-rows-body="streak" data-next="<%= rs.streaks.length %>">
                    <% rs.streaks.forEach(function (s, i) { %>
                    <div class="ly-erow" data-erow>
                        <input type="hidden" name="streak[<%= i %>][id]" value="<%= s.id %>">
                        <input type="hidden" name="streak[<%= i %>][type]" value="<%= Number(s.type) === 2 ? 2 : 1 %>">
                        <div class="ly-field"><label>Order Count</label><input type="number" name="streak[<%= i %>][order_count]" min="1" step="1" value="<%= s.order_count %>"></div>
                        <div class="ly-field"><label>Duration</label><select name="streak[<%= i %>][duration_type]"><option value="1" <%= Number(s.duration_type) === 1 ? 'selected' : '' %>>Weekly</option><option value="2" <%= Number(s.duration_type) === 2 ? 'selected' : '' %>>Monthly</option></select></div>
                        <div class="ly-field"><label>Cashback</label><div class="ly-money ly-money--suffix"><input type="number" name="streak[<%= i %>][cashback]" step="0.01" min="0" value="<%= s.cashback %>"><span class="ly-money__sym"><%= sym %></span></div></div>
                        <div class="ly-field"><label>Min Order Amount</label><input type="number" name="streak[<%= i %>][min_order_amount]" step="0.01" min="0" value="<%= s.min_order_amount %>"></div>
                        <button type="button" class="ly-iconbtn ly-iconbtn--danger ly-erow__del" data-action="ly-row-del" aria-label="Remove">🗑</button>
                    </div>
                    <% }); %>
                </div>
            </div>
            <p class="ly-none" data-rows-empty <%= rs.streaks.length ? 'hidden' : '' %>>No streak milestones — click “+ Add”.</p>
            <template data-row-template="streak"><div class="ly-erow" data-erow><input type="hidden" name="streak[__IDX__][id]" value=""><input type="hidden" name="streak[__IDX__][type]" value="1"><div class="ly-field"><label>Order Count</label><input type="number" name="streak[__IDX__][order_count]" min="1" step="1" value=""></div><div class="ly-field"><label>Duration</label><select name="streak[__IDX__][duration_type]"><option value="1">Weekly</option><option value="2">Monthly</option></select></div><div class="ly-field"><label>Cashback</label><div class="ly-money ly-money--suffix"><input type="number" name="streak[__IDX__][cashback]" step="0.01" min="0" value=""><span class="ly-money__sym"><%= sym %></span></div></div><div class="ly-field"><label>Min Order Amount</label><input type="number" name="streak[__IDX__][min_order_amount]" step="0.01" min="0" value="0"></div><button type="button" class="ly-iconbtn ly-iconbtn--danger ly-erow__del" data-action="ly-row-del" aria-label="Remove">🗑</button></div></template>
        </section>
        <% } %>

        <%# ── 6. Community Rewards (8 fixed types, £) ── %>
        <% if (rr && SHOW.reviews) { %>
        <section class="card ly-card">
            <div class="ly-card__head"><div class="ly-card__headtxt"><h3 class="card__title">6. Community Rewards</h3><p class="ly-card__sub">Cashback users for giving reviews</p></div><%- tog('on_review', rr.masterOn) %></div>
            <p class="ly-hint">A <%= sym %> reward per type. Leave at 0 to switch that reward off.</p>
            <%# Legacy columns: Type | Cashback — the 8 fixed review/share types
                from params.php $reviewTypeList, in that order (the api's
                REVIEW_REWARD_TYPES is the same list). %>
            <table class="ly-ftbl">
                <thead><tr><th>Type</th><th>Cashback</th></tr></thead>
                <tbody>
                    <% rr.types.forEach(function (t) { %>
                    <tr>
                        <td><strong><%= t.name %></strong></td>
                        <td>
                            <div class="ly-money ly-money--suffix">
                                <input id="rv<%= t.id %>" type="number" name="review_<%= t.id %>_cashback" step="0.01" min="0" value="<%= Number(t.cashback).toFixed(2) %>" aria-label="<%= t.name %> cashback">
                                <span class="ly-money__sym"><%= sym %></span>
                            </div>
                        </td>
                    </tr>
                    <% }); %>
                </tbody>
            </table>
        </section>
        <% } %>

        <%# ── 7. Buy X Get Y (BOGO) (multi-row) ── %>
        <% if (bg && SHOW.bogof) { %>
        <section class="card ly-card">
            <div class="ly-card__head"><div class="ly-card__headtxt"><h3 class="card__title">7. Buy X Get Y (BOGO)</h3><p class="ly-card__sub">Create multiple buy get offers</p></div><div class="ly-card__headact"><%- tog('on_bogof', bg.masterOn) %><% if (bg.products.length || bg.categories.length) { %><button type="button" class="ly-btn ly-btn--primary ly-btn--sm" data-action="ly-row-add" data-rows="bogof">+ Add</button><% } %></div></div>
            <% if (!bg.products.length && !bg.categories.length) { %><p class="ly-none">No products or categories found yet.</p><% } else { %>
            <%# Legacy column order: Buy Qty | Get Qty | Apply On | Buy & Get
                Items | Action, with the "Apply On" labels "Product Wise" /
                "Category Wise". Legacy hides the non-matching list; we show both
                stacked in the one "Buy & Get Items" cell because the only
                hide/show hook available (loyalty.js syncApplyOn) resolves via
                closest('form') — with every section in ONE form it would toggle
                every row at once. The api reads whichever list matches apply_on
                and ignores the other, so both being filled is harmless. %>
            <p class="ly-hint">Pick “Apply On”, then fill the matching list (Ctrl/Cmd-click to multi-select).</p>
            <div class="ly-tbl ly-tbl--bogof">
                <div class="ly-tbl__head" aria-hidden="true"><span>Buy Qty</span><span>Get Qty</span><span>Apply On</span><span>Buy &amp; Get Items</span><span>Action</span></div>
                <div class="ly-erows" data-rows-body="bogof" data-next="<%= bg.rules.length %>">
                    <% bg.rules.forEach(function (r, i) { %>
                    <div class="ly-erow ly-erow--wide" data-erow>
                        <input type="hidden" name="bogof[<%= i %>][id]" value="<%= r.id %>">
                        <div class="ly-field"><label>Buy Qty</label><input type="number" name="bogof[<%= i %>][buy_quantity]" min="1" step="1" value="<%= r.buy_quantity %>"></div>
                        <div class="ly-field"><label>Get Qty</label><input type="number" name="bogof[<%= i %>][get_quantity]" min="1" step="1" value="<%= r.get_quantity %>"></div>
                        <div class="ly-field"><label>Apply On</label><select name="bogof[<%= i %>][apply_on]"><option value="1" <%= Number(r.apply_on) === 1 ? 'selected' : '' %>>Product Wise</option><option value="2" <%= Number(r.apply_on) === 2 ? 'selected' : '' %>>Category Wise</option></select></div>
                        <div class="ly-field ly-field--grow ly-bogo-items">
                            <label>Buy &amp; Get Items</label>
                            <div class="ly-bogo-items__pair">
                                <div class="ly-bogo-items__one"><span class="ly-bogo-items__cap">Products</span><%- mSelect('bogof[' + i + '][product_ids][]', bg.products, r.product_ids) %></div>
                                <div class="ly-bogo-items__one"><span class="ly-bogo-items__cap">Categories</span><%- mSelect('bogof[' + i + '][category_ids][]', bg.categories, r.category_ids) %></div>
                            </div>
                        </div>
                        <button type="button" class="ly-iconbtn ly-iconbtn--danger ly-erow__del" data-action="ly-row-del" aria-label="Remove">🗑</button>
                    </div>
                    <% }); %>
                </div>
            </div>
            <p class="ly-none" data-rows-empty <%= bg.rules.length ? 'hidden' : '' %>>No BOGO offers — click “+ Add”.</p>
            <template data-row-template="bogof"><div class="ly-erow ly-erow--wide" data-erow><input type="hidden" name="bogof[__IDX__][id]" value=""><div class="ly-field"><label>Buy Qty</label><input type="number" name="bogof[__IDX__][buy_quantity]" min="1" step="1" value="1"></div><div class="ly-field"><label>Get Qty</label><input type="number" name="bogof[__IDX__][get_quantity]" min="1" step="1" value="1"></div><div class="ly-field"><label>Apply On</label><select name="bogof[__IDX__][apply_on]"><option value="1">Product Wise</option><option value="2">Category Wise</option></select></div><div class="ly-field ly-field--grow ly-bogo-items"><label>Buy &amp; Get Items</label><div class="ly-bogo-items__pair"><div class="ly-bogo-items__one"><span class="ly-bogo-items__cap">Products</span><%- mSelect('bogof[__IDX__][product_ids][]', bg.products, []) %></div><div class="ly-bogo-items__one"><span class="ly-bogo-items__cap">Categories</span><%- mSelect('bogof[__IDX__][category_ids][]', bg.categories, []) %></div></div></div><button type="button" class="ly-iconbtn ly-iconbtn--danger ly-erow__del" data-action="ly-row-del" aria-label="Remove">🗑</button></div></template>
            <% } %>
        </section>
        <% } %>

        <%# ── 8. Celebration Reward (multi-row) ── %>
        <% if (so && SHOW.special) { %>
        <section class="card ly-card">
            <div class="ly-card__head"><div class="ly-card__headtxt"><h3 class="card__title">8. Celebration Reward</h3><p class="ly-card__sub">Create date-based cashback or discount offers for special events</p></div><div class="ly-card__headact"><%- tog('on_special', so.masterOn) %><button type="button" class="ly-btn ly-btn--primary ly-btn--sm" data-action="ly-row-add" data-rows="special">+ Add</button></div></div>
            <%# Legacy columns: Cashback (input + £/% select in ONE cell, legacy
                $loyalty_cash_type_both) | Offer Date | Action — it has no
                separate "Type" column. %>
            <div class="ly-tbl ly-tbl--special">
                <div class="ly-tbl__head" aria-hidden="true"><span>Cashback</span><span>Offer Date</span><span>Action</span></div>
                <div class="ly-erows" data-rows-body="special" data-next="<%= so.offers.length %>">
                    <% so.offers.forEach(function (o, i) { %>
                    <div class="ly-erow" data-erow>
                        <input type="hidden" name="special[<%= i %>][id]" value="<%= o.id %>">
                        <div class="ly-field"><label>Cashback</label>
                            <div class="ly-inputpair">
                                <input type="number" name="special[<%= i %>][cashback]" step="0.01" min="0" value="<%= o.cashback %>">
                                <select name="special[<%= i %>][value_type]" class="ly-unitsel" aria-label="Cashback type"><option value="£" <%= o.value_type === '£' ? 'selected' : '' %>><%= sym %></option><option value="%" <%= o.value_type === '%' ? 'selected' : '' %>>%</option></select>
                            </div>
                        </div>
                        <div class="ly-field"><label>Offer Date</label><input type="date" name="special[<%= i %>][offer_date]" value="<%= o.offer_date %>"></div>
                        <button type="button" class="ly-iconbtn ly-iconbtn--danger ly-erow__del" data-action="ly-row-del" aria-label="Remove">🗑</button>
                    </div>
                    <% }); %>
                </div>
            </div>
            <p class="ly-none" data-rows-empty <%= so.offers.length ? 'hidden' : '' %>>No special offers — click “+ Add”.</p>
            <template data-row-template="special"><div class="ly-erow" data-erow><input type="hidden" name="special[__IDX__][id]" value=""><div class="ly-field"><label>Cashback</label><div class="ly-inputpair"><input type="number" name="special[__IDX__][cashback]" step="0.01" min="0" value=""><select name="special[__IDX__][value_type]" class="ly-unitsel" aria-label="Cashback type"><option value="£"><%= sym %></option><option value="%">%</option></select></div></div><div class="ly-field"><label>Offer Date</label><input type="date" name="special[__IDX__][offer_date]" min="<%= soToday %>" value=""></div><button type="button" class="ly-iconbtn ly-iconbtn--danger ly-erow__del" data-action="ly-row-del" aria-label="Remove">🗑</button></div></template>
        </section>
        <% } %>

        <%# ── 9. Membership Tiers ── %>
        <% if (tc && SHOW.tiers) { %>
        <section class="card ly-card">
            <%# Legacy has NO on/off switch on this section (the block is
                commented out in index.php), so none is shown. The api's Save All
                still writes the membership-tier master flag from `on_tier`, so
                its current value rides along hidden — otherwise every save would
                switch tiers off. %>
            <div class="ly-card__head"><div class="ly-card__headtxt"><h3 class="card__title">9. Membership Tiers</h3><p class="ly-card__sub">Fixed Bronze / Silver / Gold tiers</p></div></div>
            <input type="hidden" name="on_tier" value="<%= tc.masterOn ? 1 : 0 %>">
            <%# Legacy columns: Tier | Min Amount | Max Amount | Free Delivery —
                one row per tier, gold's Max is the word "Above" (hidden 0). Ours
                rendered three separate cards instead. %>
            <table class="ly-ftbl">
                <thead><tr><th>Tier</th><th>Min Amount</th><th>Max Amount</th><th>Free Delivery</th></tr></thead>
                <tbody>
                    <% tierRows.forEach(function (def) { var key = def[0]; var t = tc.tiers[key] || { min_amount: 0, max_amount: 0, free_delivery_lifetime: false }; %>
                    <tr>
                        <td><strong><%= def[1] %></strong></td>
                        <td><input id="<%= key %>-min" type="number" name="<%= key %>_min_amount" step="0.01" min="0" placeholder="Min" value="<%= t.min_amount %>" aria-label="<%= def[1] %> min amount"></td>
                        <td>
                            <% if (key === 'gold') { %><input type="hidden" name="gold_max_amount" value="0"><strong class="ly-tier-above">Above</strong><% } else { %><input id="<%= key %>-max" type="number" name="<%= key %>_max_amount" step="0.01" min="0" placeholder="Max" value="<%= t.max_amount %>" aria-label="<%= def[1] %> max amount"><% } %>
                        </td>
                        <td class="ly-ftbl__mid"><input type="checkbox" class="ly-cbox" name="<%= key %>_free" value="1" <%= t.free_delivery_lifetime ? 'checked' : '' %> aria-label="<%= def[1] %> lifetime free delivery"></td>
                    </tr>
                    <% }); %>
                </tbody>
            </table>
        </section>
        <% } %>

        <%# ── 10. Performance Plus Reward (smart campaign) ── %>
        <% if (ch && SHOW.campaign) { %>
        <section class="card ly-card">
            <div class="ly-card__head"><div class="ly-card__headtxt"><h3 class="card__title">10. Performance Plus Reward</h3><p class="ly-card__sub">Cashback top users and re-engage inactive customers automatically</p></div><%- tog('on_campaign', ch.masterOn) %></div>
            <%# Legacy columns: Type | Count / Days | Cashback, and only the three
                types in params.php $loyalty_smart_campaign — Most Referrals,
                Top Spenders, Inactive. £ is fixed (read-only box) for the two
                count rows; only Inactive gets the £/% select. Our extra
                most_orders / most_reviews campaigns aren't on the legacy page,
                so they're carried hidden rather than zeroed on every save. %>
            <table class="ly-ftbl">
                <thead><tr><th>Type</th><th>Count / Days</th><th>Cashback</th></tr></thead>
                <tbody>
                    <% campRows.forEach(function (def) { var key = def[0]; var c = ch.campaigns[key] || { target_value: 0, value_type: (key === 'inactive' ? '%' : '£'), cashback: 0 }; %>
                    <tr>
                        <td><strong><%= def[1] %></strong></td>
                        <td><input id="<%= key %>-t" type="number" name="<%= key %>_target" min="0" step="1" value="<%= c.target_value %>" aria-label="<%= def[1] %> count or days"></td>
                        <td>
                            <% if (key === 'inactive') { %>
                            <div class="ly-inputpair">
                                <input id="<%= key %>-c" type="number" name="<%= key %>_cashback" step="0.01" min="0" value="<%= c.cashback %>" aria-label="Inactive cashback">
                                <select id="<%= key %>-vt" name="<%= key %>_vt" class="ly-unitsel" aria-label="Inactive cashback type"><option value="£" <%= c.value_type === '£' ? 'selected' : '' %>><%= sym %></option><option value="%" <%= c.value_type === '%' ? 'selected' : '' %>>%</option></select>
                            </div>
                            <% } else { %>
                            <div class="ly-money ly-money--suffix">
                                <input id="<%= key %>-c" type="number" name="<%= key %>_cashback" step="0.01" min="0" value="<%= c.cashback %>" aria-label="<%= def[1] %> cashback">
                                <span class="ly-money__sym"><%= sym %></span>
                            </div>
                            <% } %>
                        </td>
                    </tr>
                    <% }); %>
                </tbody>
            </table>
            <% ['most_orders', 'most_reviews'].forEach(function (key) { var c = ch.campaigns[key] || { target_value: 0, cashback: 0 }; %><input type="hidden" name="<%= key %>_target" value="<%= c.target_value %>"><input type="hidden" name="<%= key %>_cashback" value="<%= c.cashback %>"><% }); %>
        </section>
        <% } %>

        <div class="ly-saveall">
            <button type="submit" class="ly-btn ly-btn--primary ly-btn--lg">💾 Save All Settings</button>
        </div>

    </form>

    <% } %>
</div>
