<%#
  partials/sidebar.ejs — admin left navigation

  Dark navy rail. Mirrors the legacy POS "Settings" menu concept: a Settings
  group holds Loyalty Configuration + Review CMS Pages + Store Settings; Review
  Claims and Segments are their own items. Loyalty items show only when loyalty
  is available (super admin, or a company whose loyalty is switched ON).
  On mobile the rail slides in as an off-canvas drawer (topbar hamburger).
  active_nav (set per controller) highlights the current item.
-%>
<% var nav = active_nav || ''; %>
<% var scc = (typeof company_ctx !== 'undefined' && company_ctx) ? company_ctx : { isSuper: false, loyaltyEnabled: false }; %>
<% var loyaltyOn = scc.isSuper || scc.loyaltyEnabled; %>
<aside class="admin-sidebar" id="admin-sidebar">
    <div class="admin-sidebar__brand">
        <img class="admin-sidebar__logo" src="<%= brand.logoUrl %>?v=<%= ASSET_VERSION %>" alt="<%= brand.name %>">
        <span class="admin-sidebar__name"><%= brand.name %> <span>Admin</span></span>
    </div>

    <nav class="admin-nav" aria-label="Admin sections">
        <a class="admin-nav__item <%= nav === 'dashboard' ? 'is-active' : '' %>" href="/">
            <span class="admin-nav__ic" aria-hidden="true">📊</span><span>Dashboard</span>
        </a>
        <a class="admin-nav__item <%= nav === 'products' ? 'is-active' : '' %>" href="/products">
            <span class="admin-nav__ic" aria-hidden="true">🍽️</span><span>Products</span>
        </a>
        <% if (scc.isSuper) { %>
        <a class="admin-nav__item <%= nav === 'mp-categories' ? 'is-active' : '' %>" href="/marketplace-categories">
            <span class="admin-nav__ic" aria-hidden="true">🗂️</span><span>Marketplace Categories</span>
        </a>
        <%# Banners — both home-page banner screens in one menu. %>
        <details class="admin-nav__group" <%= ['welcome-banner', 'offer-banner'].includes(nav) ? 'open' : '' %>>
            <summary class="admin-nav__item admin-nav__sum">
                <span class="admin-nav__ic" aria-hidden="true">🖼️</span><span>Banners</span>
                <span class="admin-nav__chev" aria-hidden="true">▸</span>
            </summary>
            <div class="admin-nav__sub">
                <a class="admin-nav__item admin-nav__subitem <%= nav === 'welcome-banner' ? 'is-active' : '' %>" href="/welcome-banner">
                    <span class="admin-nav__ic" aria-hidden="true">🎉</span><span>Welcome Banner</span>
                </a>
                <a class="admin-nav__item admin-nav__subitem <%= nav === 'offer-banner' ? 'is-active' : '' %>" href="/offer-banner">
                    <span class="admin-nav__ic" aria-hidden="true">🎟️</span><span>Offer Banners</span>
                </a>
            </div>
        </details>
        <%# Home Feed group — all marketplace home-feed merchandising in ONE
            menu (collections, featured restaurants, featured products …).
            Open when any child is active. %>
        <details class="admin-nav__group" <%= ['collections', 'featured', 'featured-products', 'feed-order'].includes(nav) ? 'open' : '' %>>
            <summary class="admin-nav__item admin-nav__sum">
                <span class="admin-nav__ic" aria-hidden="true">🏬</span><span>Home Feed</span>
                <span class="admin-nav__chev" aria-hidden="true">▸</span>
            </summary>
            <div class="admin-nav__sub">
                <a class="admin-nav__item admin-nav__subitem <%= nav === 'feed-order' ? 'is-active' : '' %>" href="/feed-sections">
                    <span class="admin-nav__ic" aria-hidden="true">🔢</span><span>Feed Order</span>
                </a>
                <a class="admin-nav__item admin-nav__subitem <%= nav === 'collections' ? 'is-active' : '' %>" href="/collections">
                    <span class="admin-nav__ic" aria-hidden="true">⭐</span><span>Collections</span>
                </a>
                <a class="admin-nav__item admin-nav__subitem <%= nav === 'featured' ? 'is-active' : '' %>" href="/featured">
                    <span class="admin-nav__ic" aria-hidden="true">📌</span><span>Featured</span>
                </a>
                <a class="admin-nav__item admin-nav__subitem <%= nav === 'featured-products' ? 'is-active' : '' %>" href="/featured-products">
                    <span class="admin-nav__ic" aria-hidden="true">🍔</span><span>Featured Products</span>
                </a>
            </div>
        </details>
        <% } %>

        <%# Community group — Groups (manage + feeds) + the AI-moderation Review
            queue (super-admin) in ONE expandable menu. Open when a child is active. %>
        <details class="admin-nav__group" <%= ['community', 'community-review', 'community-blocked'].includes(nav) ? 'open' : '' %>>
            <summary class="admin-nav__item admin-nav__sum">
                <span class="admin-nav__ic" aria-hidden="true">👥</span><span>Community</span>
                <span class="admin-nav__chev" aria-hidden="true">▸</span>
            </summary>
            <div class="admin-nav__sub">
                <a class="admin-nav__item admin-nav__subitem <%= nav === 'community' ? 'is-active' : '' %>" href="/community">
                    <span class="admin-nav__ic" aria-hidden="true">👥</span><span>Groups</span>
                </a>
                <% if (scc.isSuper) { %>
                <a class="admin-nav__item admin-nav__subitem <%= nav === 'community-review' ? 'is-active' : '' %>" href="/community/review">
                    <span class="admin-nav__ic" aria-hidden="true">🛡️</span><span>Review queue</span>
                </a>
                <a class="admin-nav__item admin-nav__subitem <%= nav === 'community-blocked' ? 'is-active' : '' %>" href="/community/blocked">
                    <span class="admin-nav__ic" aria-hidden="true">🚫</span><span>Blocked users</span>
                </a>
                <% } %>
            </div>
        </details>

        <%# Loyalty group — SUPER ADMIN ONLY, and it configures the MARKETPLACE's
            own programme (company_id = 0) exclusively. A restaurant's loyalty is
            configured in the legacy POS, never here, so a company login must not
            see this at all: the gate is `isSuper`, NOT loyaltyOn (which is also
            true for any company whose loyalty is switched on).

            Hiding the menu isn't the permission — the routes are 404'd by
            requireSuperPage (admin/index.js) and the api re-checks with
            requireSuperAdmin. The controller pins every call to scope 0, so the
            company switcher above is ignored on these screens.

            Loyalty Configuration is ONE page: /loyalty/cashback-rules, /tiers,
            /events, /bogof … all redirect to /loyalty (`toConfig`), where each
            rule type is a section — so they'd all open the same screen and are
            deliberately not separate items. Cashback Review + Review CMS Pages
            are genuinely distinct pages, so they get their own rows. %>
        <%# ══ DISABLED 2026-07-17 (user request) ═══════════════════════════
            The whole Loyalty group — Loyalty Configuration, Reviews, Cashback
            Review, Review CMS Pages — is switched OFF for now.

            Turned off with `if (false)` rather than by wrapping it in an EJS
            comment: the block contains EJS output tags, and an EJS comment ends
            at the first closing tag inside it — which silently breaks the file.
            Same pattern the Notifications item uses in web's header.ejs.

            Hiding the menu is NOT the control: /loyalty* and /reviews* are 404'd
            by the gate in admin/index.js, so typing the URL gets you nothing.
            RESTORE: put `scc.isSuper` back below, and delete that gate.

            The customer-facing loyalty (web /wallet, /earn, rewards) is
            deliberately left running. %>
        <% if (false) { %>
        <details class="admin-nav__group" <%= ['loyalty', 'reviews', 'review-claims', 'cms'].includes(nav) ? 'open' : '' %>>
            <summary class="admin-nav__item admin-nav__sum">
                <span class="admin-nav__ic" aria-hidden="true">💷</span><span>Loyalty</span>
                <span class="admin-nav__chev" aria-hidden="true">▸</span>
            </summary>
            <div class="admin-nav__sub">
                <a class="admin-nav__item admin-nav__subitem <%= nav === 'loyalty' ? 'is-active' : '' %>" href="/loyalty">
                    <span class="admin-nav__ic" aria-hidden="true">⚙️</span><span>Loyalty Configuration</span>
                </a>
                <a class="admin-nav__item admin-nav__subitem <%= nav === 'reviews' ? 'is-active' : '' %>" href="/reviews">
                    <span class="admin-nav__ic" aria-hidden="true">⭐</span><span>Reviews</span>
                </a>
                <a class="admin-nav__item admin-nav__subitem <%= nav === 'review-claims' ? 'is-active' : '' %>" href="/loyalty/review-claims">
                    <span class="admin-nav__ic" aria-hidden="true">💬</span><span>Cashback Review</span>
                </a>
                <a class="admin-nav__item admin-nav__subitem <%= nav === 'cms' ? 'is-active' : '' %>" href="/loyalty/cms-pages">
                    <span class="admin-nav__ic" aria-hidden="true">📝</span><span>Review CMS Pages</span>
                </a>
            </div>
        </details>
        <% } %>
        <%# ══ end of the disabled Loyalty group ═════════════════════════ %>
    </nav>
    <%# Sign out lives in the topbar account menu — not duplicated here. %>
</aside>
