<%#
  views/partials/mobile-drawer.ejs

  What:  Slide-in drawer for mobile only. Opens from the right when the
         user taps the hamburger in the header. On mobile the site
         footer is hidden — ALL of its links + brand + social + legal
         live here instead, grouped into sections at the bottom of the
         drawer. This keeps the page itself short on small screens
         while still giving the user a single tap to reach Terms,
         Partner with us, Contact us, etc.

         Drawer order, top-to-bottom:
           • Head (brand mark + close)
           • Auth / account row
           • Primary nav (Home / Restaurants / Offers)
           • ── footer band ──
              · Company links
              · For-restaurants links
              · Help & legal links
              · Social icons row
              · Copyright + build version
           • Log out (only when signed in)
  Why:   Mobile header has room for the logo + location + hamburger
         only. Pushing the footer into the drawer matches the Zomato /
         Swiggy mobile pattern where users tap the menu for everything
         that isn't the main feed.
  Used:  Included from views/_layout.ejs. Toggled by /js/app.js via
         [data-action="toggle-mobile-menu"] (the hamburger) and
         dismissed by clicking the backdrop / close button / Esc.
-%>
<div
    id="mobile-drawer"
    class="mobile-drawer"
    role="dialog"
    aria-modal="true"
    aria-labelledby="mobile-drawer-title"
    aria-hidden="true"
    hidden
>
    <div class="mobile-drawer__backdrop" data-action="close-mobile-menu" aria-hidden="true"></div>

    <aside class="mobile-drawer__panel" role="document">

        <div class="mobile-drawer__head">
            <a class="mobile-drawer__brand" href="/">
                <img src="<%= brand.logoUrl %>?v=<%= ASSET_VERSION %>" alt="<%= brand.name %>" height="32">
            </a>
            <button
                type="button"
                class="mobile-drawer__close"
                data-action="close-mobile-menu"
                aria-label="Close menu"
            >
                <svg aria-hidden="true" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="18" y1="6"  x2="6"  y2="18"/>
                    <line x1="6"  y1="6"  x2="18" y2="18"/>
                </svg>
            </button>
        </div>

        <%# Auth row — visible when logged out, swaps to account row when logged in. %>
        <% if (user_session) { %>
            <a class="mobile-drawer__account" href="/account">
                <span class="mobile-drawer__avatar" aria-hidden="true">
                    <%= (user_session.firstname || '?').charAt(0).toUpperCase() %>
                </span>
                <span class="mobile-drawer__account-name">
                    <%= [user_session.firstname, user_session.lastname].filter(Boolean).join(' ') || 'My account' %>
                </span>
            </a>
        <% } else { %>
            <%# Single sign-in entry — the page handles both new + returning
                users via OTP, so we don't need a separate Sign-up button. -%>
            <div class="mobile-drawer__auth">
                <a href="/signin" class="btn btn--primary btn--block">Sign in</a>
            </div>
        <% } %>

        <%# Primary nav — the headline destinations. Restaurants + Offers
            mirror the bottom-nav on the home screen so users have two
            ways to reach the same page. %>
        <nav class="mobile-drawer__nav" aria-label="Primary navigation">
            <a href="/"            class="mobile-drawer__link">Home</a>
            <a href="/restaurants" class="mobile-drawer__link">Restaurants</a>
            <a href="/offers"      class="mobile-drawer__link">Offers</a>
        </nav>

        <%# ────────────────────────────────────────────────────────────
            Footer band — what used to live in views/partials/footer.ejs.
            The desktop footer is still rendered as normal; this band
            mirrors the same content for the mobile drawer so we never
            ship a page where Partner with us / Terms / etc. can only
            be reached via direct URL.
        ──────────────────────────────────────────────────────────── %>
        <div class="mobile-drawer__footer">

            <nav class="mobile-drawer__group" aria-label="Company">
                <h4 class="mobile-drawer__group-title">Company</h4>
                <a href="/about"   class="mobile-drawer__link mobile-drawer__link--sub">About</a>
                <a href="/careers" class="mobile-drawer__link mobile-drawer__link--sub">Careers</a>
                <a href="/blog"    class="mobile-drawer__link mobile-drawer__link--sub">Blog</a>
                <a href="/contact" class="mobile-drawer__link mobile-drawer__link--sub">Contact us</a>
            </nav>

            <nav class="mobile-drawer__group" aria-label="For restaurants">
                <h4 class="mobile-drawer__group-title">For restaurants</h4>
                <a href="/partner"  class="mobile-drawer__link mobile-drawer__link--sub">Partner with us</a>
                <a href="/ride"     class="mobile-drawer__link mobile-drawer__link--sub">Ride with us</a>
                <a href="/business" class="mobile-drawer__link mobile-drawer__link--sub">For business</a>
            </nav>

            <nav class="mobile-drawer__group" aria-label="Help and legal">
                <h4 class="mobile-drawer__group-title">Help &amp; legal</h4>
                <a href="/help" class="mobile-drawer__link mobile-drawer__link--sub">Help centre</a>
                <a href="<%= brand.termsUrl   || '/terms'   %>" class="mobile-drawer__link mobile-drawer__link--sub">Terms</a>
                <a href="<%= brand.privacyUrl || '/privacy' %>" class="mobile-drawer__link mobile-drawer__link--sub">Privacy</a>
                <% if (brand.supportEmail) { %>
                    <a href="mailto:<%= brand.supportEmail %>" class="mobile-drawer__link mobile-drawer__link--sub"><%= brand.supportEmail %></a>
                <% } %>
            </nav>

            <%# Social row — matches the icons in the desktop footer. %>
            <ul class="mobile-drawer__social" aria-label="Social media">
                <li>
                    <a href="#" aria-label="Facebook">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M22 12.06C22 6.5 17.52 2 12 2S2 6.5 2 12.06c0 5.02 3.66 9.19 8.44 9.94v-7.03H7.9v-2.91h2.54V9.85c0-2.5 1.49-3.89 3.77-3.89 1.09 0 2.24.2 2.24.2v2.46h-1.26c-1.24 0-1.63.77-1.63 1.56v1.88h2.78l-.44 2.91h-2.34V22c4.78-.75 8.44-4.92 8.44-9.94z"/></svg>
                    </a>
                </li>
                <li>
                    <a href="#" aria-label="Instagram">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor"/></svg>
                    </a>
                </li>
                <li>
                    <a href="#" aria-label="X">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2H21l-6.52 7.46L22 22h-6.828l-4.69-6.137L4.86 22H2.103l6.97-7.97L2 2h6.96l4.24 5.61L18.244 2zm-2.39 18h1.66L7.22 4H5.5l10.354 16z"/></svg>
                    </a>
                </li>
            </ul>

            <p class="mobile-drawer__copy">
                <%= brand.copyright %>
                <span class="mobile-drawer__build"> · v<%= ASSET_VERSION.slice(-6) %></span>
            </p>
        </div>

        <% if (user_session) { %>
            <form method="post" action="/logout" class="mobile-drawer__logout">
                <button type="submit" class="btn btn--ghost btn--block">Log out</button>
            </form>
        <% } %>

    </aside>
</div>
