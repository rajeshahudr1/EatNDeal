# ============================================================
# EatNDeal Admin — environment configuration
# Copy to .env and fill in values. NEVER commit .env.
# ============================================================

APP_ENV=development
PORT=4503
APP_URL=http://localhost:4503

# ── API endpoint (admin calls api/ for data + auth) ──
# This MUST point at a running EatNDeal API instance. The admin
# layer NEVER touches the database directly — every read/write
# goes through the api.
API_URL=http://localhost:4501

# ── Session ──────────────────────────────────────────
SESSION_NAME=eatndeal_admin
SESSION_SECRET=__change_me_to_a_long_random_string_minimum_32_chars__
# 1 day in milliseconds (admin sessions are short-lived on purpose)
SESSION_MAX_AGE=86400000

# ── Brand fallback ───────────────────────────────────
# If the api is down at boot, the layout uses these as a fallback.
# Otherwise the brand is fetched live from GET {API_URL}/api/v1/brand.
BRAND_NAME=EatNDeal
BRAND_TAGLINE=Admin Console
BRAND_COPYRIGHT=© EatNDeal. All rights reserved.

# ── Yii uploads passthrough (product / restaurant images) ────
# Same knobs as the web layer — leave PATH blank to skip the mount.
YII_UPLOADS_PATH=
YII_UPLOADS_URL=/yii-uploads
