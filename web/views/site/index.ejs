<%#
  views/site/index.ejs

  Landing page rebuilt to the EatNDeal mockup (top → bottom):
    Default home (no view mode):
      home-shell = filter sidebar (left)  +  content column (right):
        hero · cuisine rail · top restaurants · best offers ·
        popular cuisines · feature strip · app CTA
    View modes (?view= / ?restaurant=) keep a focused single-section
    layout with a back-to-home bar.

  Dynamic data: cuisines + featured restaurants come from the api
  (SiteController). Offers / popular-cuisine art / features / app CTA
  are static markup until their endpoints land — per the user's
  "implement what we have, static-HTML the rest" instruction.

  Controller passes extra_js: '/js/pages/home.js'.
-%>
<% var __viewMode = (typeof view_mode !== 'undefined' && view_mode) ? view_mode : ''; %>
<% var __order   = (typeof order_mode !== 'undefined' && order_mode) ? order_mode : 'delivery'; %>
<% var __pickup  = (__order === 'pickup' && !__viewMode); %>

<% if (__pickup) { %>
<%# ══════════════════════════════════════════════════════════════════
    PICKUP — split list + local stylized map
   ══════════════════════════════════════════════════════════════════ %>
<%- include('../partials/pickup') -%>

<% } else if (!__viewMode) { %>
<%# ══════════════════════════════════════════════════════════════════
    DEFAULT HOME — full mockup design
   ══════════════════════════════════════════════════════════════════ %>
<div class="home-shell">

    <%# Left filter sidebar (desktop ≥ 1024 px; mobile uses bottom-sheet) %>
    <%- include('../partials/filter-sidebar') -%>

    <div class="home-shell__content">

        <%# Compact "show filters" icon — only visible when the sidebar
            is collapsed (CSS gates it on .home-shell.is-filters-collapsed).
            Clicking it re-opens the sidebar. The HIDE control lives on
            the sidebar header itself (see filter-sidebar.ejs). %>
        <button type="button" class="filters-show" data-action="toggle-filters" aria-label="Show filters" title="Show filters">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"/></svg>
            <span>Filters</span>
        </button>

        <%# HERO removed per user — the home now opens straight at the
            categories. Location is set via the header chip. %>

        <%# ── CUISINE RAIL (slider only, with prev/next arrows) ──── %>
        <%# Heading text + "View all" intentionally omitted per the
            user — just the horizontal category slider. The arrows
            scroll the rail; /js/pages/home.js wires them and hides
            an arrow when there's nothing more to scroll that way. %>
        <% if (cuisines && cuisines.length > 0) { %>
        <section aria-label="Browse cuisines" class="rail-wrap" data-rail-wrap>
            <button type="button" class="rail-arrow rail-arrow--prev" data-rail-prev aria-label="Scroll left" hidden>
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>
            </button>
            <ul class="cuisine-rail" role="list" data-rail>
                <% cuisines.forEach(function (c) { %>
                    <li class="cuisine-rail__item" data-search-name="<%= c.searchName || (c.name||'').toLowerCase() %>">
                        <a class="cuisine-rail__link" href="/?cuisine=<%= encodeURIComponent(c.searchName || (c.name||'').toLowerCase()) %>" data-action="pick-cuisine">
                            <span class="cuisine-rail__disc">
                                <% if (c.icon) { %><img src="<%= c.icon %>" alt="" loading="lazy" data-img-fallback><% } else { %><%= c.initial || '🍽️' %><% } %>
                            </span>
                            <span class="cuisine-rail__name"><%= c.name %></span>
                        </a>
                    </li>
                <% }); %>
            </ul>
            <button type="button" class="rail-arrow rail-arrow--next" data-rail-next aria-label="Scroll right" hidden>
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
            </button>
        </section>
        <% } %>

        <%# ── TOP RESTAURANTS ──────────────────────────────────── %>
        <%# data-home-feed: the ONLY region swapped on an in-place
            cuisine filter. The cuisine rail + filter sidebar above stay
            physically in the DOM (no flicker, no scroll reset); only
            this restaurant list reloads. Always rendered (even when
            empty) so the partial-swap target is always present. %>
        <div data-home-feed>
        <% if (typeof cuisine_no_match !== 'undefined' && cuisine_no_match && selected_cuisine) { %>
            <p class="feed-note">No restaurants serving “<%= selected_cuisine.charAt(0).toUpperCase() + selected_cuisine.slice(1) %>” near you yet — here’s what else is available.</p>
        <% } %>
        <% if (featured && featured.length > 0) { %>
        <section aria-labelledby="resto-rail-title">
            <div class="hv2-head">
                <h2 id="resto-rail-title" class="hv2-head__title"><%= (typeof cuisine_no_match !== 'undefined' && cuisine_no_match) ? 'More restaurants near you' : 'Top restaurants near you' %></h2>
                <a href="/?view=restaurants" class="hv2-head__link" data-action="view-all">View all</a>
            </div>
            <ul class="resto-rail" role="list" data-load-target>
                <% featured.forEach(function (r) { %>
                    <li data-search-id="<%= r.id %>">
                        <a class="resto-card<%= r.isOpen ? '' : ' is-closed' %>" href="/?restaurant=<%= encodeURIComponent(r.slug || r.id) %>" data-action="pick-restaurant">
                            <div class="resto-card__media" data-tint="<%= r.tint %>">
                                <% if (r.image) { %><img src="<%= r.image %>" alt="" loading="lazy" data-img-fallback><% } else { %><%= r.initial %><% } %>
                                <%# Real offer badge — representative offer + a count chip
                                    when the restaurant has more than one offer. %>
                                <% if (r.offer) { %><span class="resto-card__badge resto-card__badge--offer"><%= r.offer %><% if (r.offerCount && r.offerCount > 1) { %><span class="resto-card__badge-count"><%= r.offerCount %></span><% } %></span><% } %>
                            </div>
                            <div class="resto-card__body">
                                <span class="resto-card__name">
                                    <%= r.name %>
                                    <svg class="resto-card__verified" width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="m9 12 2 2 4-4"/><path d="M12 2 4 5v6c0 5 8 11 8 11s8-6 8-11V5l-8-3z" fill="none" stroke="currentColor" stroke-width="2"/></svg>
                                </span>
                                <% if ((r.cuisines || []).length) { %><p class="resto-card__cuisines"><%= (r.cuisines || []).slice(0,3).join(' · ') %></p><% } %>
                                <div class="resto-card__meta">
                                    <span class="resto-card__rating">
                                        <svg width="11" height="11" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                                        <%= r.rating %>
                                    </span>
                                    <% if (r.deliveryMinutes) { %><span class="resto-card__time"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><polyline points="12 7 12 12 15 14"/></svg> <%= r.deliveryMinutes %></span><% } %>
                                    <% if (typeof r.distanceKm === 'number' && r.distanceKm >= 0) { %><span class="resto-card__dist"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s7-7.5 7-13a7 7 0 0 0-14 0c0 5.5 7 13 7 13z"/><circle cx="12" cy="9" r="2.5"/></svg> <%= r.distanceKm.toFixed(1) %> km</span><% } %>
                                </div>
                                <%# Real delivery line: closed wins, then postcode-zone deliverability, then fee / min-order. %>
                                <% if (!r.isOpen) { %>
                                    <span class="resto-card__delivery resto-card__delivery--muted">Currently closed</span>
                                <% } else if (r.deliverable === false) { %>
                                    <span class="resto-card__delivery resto-card__delivery--muted">Doesn't deliver to your area</span>
                                <% } else if (typeof r.deliveryFee === 'number') { %>
                                    <span class="resto-card__delivery"><% if (r.deliveryFee === 0) { %>Free delivery<% } else { %><%= brand.currencySymbol %><%= r.deliveryFee.toFixed(2) %> delivery<% } %><% if (typeof r.minOrder === 'number' && r.minOrder > 0) { %> · min <%= brand.currencySymbol %><%= r.minOrder.toFixed(0) %><% } %></span>
                                <% } %>
                            </div>
                        </a>
                    </li>
                <% }); %>
            </ul>
            <% if (typeof featured_more !== 'undefined' && featured_more) { %>
                <div class="section__loadmore" data-load-more="featured" data-offset="<%= featured.length %>">
                    <button type="button" class="btn btn--ghost btn--lg section__loadmore-btn">See more</button>
                </div>
            <% } %>
        </section>
        <% } %>
        </div><%# /[data-home-feed] %>

        <%# ── BEST OFFERS — real store-offer banners (fallback: static) ─ %>
        <% var __offers = (typeof home_offers !== 'undefined' && home_offers) ? home_offers : []; %>
        <% if (__offers.length) { %>
        <section aria-labelledby="offers-title">
            <div class="hv2-head">
                <h2 id="offers-title" class="hv2-head__title">Best offers for you</h2>
            </div>
            <div class="offers-rail">
                <% var __ov = ['offer-banner--red','offer-banner--orange','offer-banner--purple']; %>
                <% __offers.forEach(function (o, i) { %>
                    <a class="offer-banner offer-banner--real <%= __ov[i % __ov.length] %>" href="/?restaurant=<%= encodeURIComponent(o.restaurant.slug) %>" data-action="pick-restaurant">
                        <span class="offer-banner__title"><%= o.title %></span>
                        <% if (o.details) { %><span class="offer-banner__sub"><%= o.details %></span><% } %>
                        <span class="offer-banner__from"><%= o.restaurant.name %></span>
                        <span class="offer-banner__cta">Order Now →</span>
                    </a>
                <% }); %>
            </div>
        </section>
        <% } else { %>
        <section aria-labelledby="offers-title">
            <div class="hv2-head">
                <h2 id="offers-title" class="hv2-head__title">Best offers for you</h2>
                <a href="/?view=restaurants&offer=1" class="hv2-head__link" data-action="view-all">View all offers</a>
            </div>
            <div class="offers-rail">
                <div class="offer-banner offer-banner--red">
                    <span class="offer-banner__title">50% OFF</span>
                    <span class="offer-banner__sub">On your first order</span>
                    <span class="offer-banner__code">Use code: WELCOME50</span>
                </div>
                <div class="offer-banner offer-banner--orange">
                    <span class="offer-banner__title">BUY 1 GET 1</span>
                    <span class="offer-banner__sub">On selected items</span>
                    <a href="/?view=restaurants" class="offer-banner__cta" data-action="view-all">Order Now →</a>
                </div>
                <div class="offer-banner offer-banner--purple">
                    <span class="offer-banner__title">Weekend Special</span>
                    <span class="offer-banner__sub">Up to 40% OFF on family combos</span>
                    <a href="/?view=restaurants" class="offer-banner__cta" data-action="view-all">Order Now →</a>
                </div>
            </div>
        </section>
        <% } %>

        <%# ── POPULAR CUISINES (dark cards) ────────────────────── %>
        <% if (cuisines && cuisines.length > 0) { %>
        <section aria-labelledby="popcuisine-title">
            <div class="hv2-head">
                <h2 id="popcuisine-title" class="hv2-head__title">Popular cuisines</h2>
            </div>
            <div class="popcuisine-grid">
                <% cuisines.slice(0, 4).forEach(function (c) { %>
                    <a class="popcuisine-card" href="/?cuisine=<%= encodeURIComponent(c.searchName || (c.name||'').toLowerCase()) %>" data-action="pick-cuisine">
                        <span class="popcuisine-card__copy">
                            <span class="popcuisine-card__name"><%= c.name %></span><br>
                            <span class="popcuisine-card__explore">Explore →</span>
                        </span>
                        <span class="popcuisine-card__art">
                            <% if (c.icon) { %><img src="<%= c.icon %>" alt="" loading="lazy" data-img-fallback><% } else { %><%= c.initial || '🍽️' %><% } %>
                        </span>
                    </a>
                <% }); %>
            </div>
        </section>
        <% } %>

        <%# ── FEATURE STRIP (static) ───────────────────────────── %>
        <section aria-label="Why EatNDeal">
            <div class="feature-strip">
                <div class="feature-item feature-item--a"><span class="feature-item__icon">🛵</span><span><span class="feature-item__title">Fast Delivery</span><br><span class="feature-item__sub">Get your food in 20-30 minutes</span></span></div>
                <div class="feature-item feature-item--b"><span class="feature-item__icon">📍</span><span><span class="feature-item__title">Live Tracking</span><br><span class="feature-item__sub">Track your order in real-time</span></span></div>
                <div class="feature-item feature-item--c"><span class="feature-item__icon">🛡️</span><span><span class="feature-item__title">Safe Payments</span><br><span class="feature-item__sub">100% secure payment options</span></span></div>
                <div class="feature-item feature-item--d"><span class="feature-item__icon">🏷️</span><span><span class="feature-item__title">Best Offers</span><br><span class="feature-item__sub">Exclusive deals &amp; discounts</span></span></div>
            </div>
        </section>

        <%# ── APP CTA (static) ─────────────────────────────────── %>
        <section class="appcta" aria-labelledby="appcta-title">
            <div>
                <h2 id="appcta-title" class="appcta__title">It's all at<br>your fingertips</h2>
                <p class="appcta__sub">Download the <%= brand.name %> app and get exclusive offers</p>
                <div class="appcta__badges">
                    <span class="appcta__badge"> App Store</span>
                    <span class="appcta__badge">▶ Google Play</span>
                    <span class="appcta__qr">QR</span>
                </div>
            </div>
            <div class="appcta__phone" aria-hidden="true">📱</div>
            <ul class="appcta__checks">
                <li class="appcta__check"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>Exclusive app offers</li>
                <li class="appcta__check"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>Faster order placement</li>
                <li class="appcta__check"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>Real-time order tracking</li>
                <li class="appcta__check"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>Save your favorite places</li>
            </ul>
        </section>

    </div><%# /.home-shell__content %>
</div><%# /.home-shell %>

<% } else if (__viewMode === 'restaurant') { %>
<%# ══════════════════════════════════════════════════════════════════
    RESTAURANT — full detail page (left menu · center · right info)
   ══════════════════════════════════════════════════════════════════ %>
<%- include('../partials/restaurant-detail') -%>

<% } else if (__viewMode === 'product') { %>
<%# ══════════════════════════════════════════════════════════════════
    PRODUCT — detail page with selectable options (size / toppings / qty)
   ══════════════════════════════════════════════════════════════════ %>
<%- include('../partials/product-detail') -%>

<% } else { %>
<%# ══════════════════════════════════════════════════════════════════
    VIEW MODES — focused single-section layouts (cuisines / restaurants)
   ══════════════════════════════════════════════════════════════════ %>
<nav class="view-mode-bar" aria-label="Back to home">
    <a class="view-mode-bar__back" href="/" data-action="view-home">
        <svg aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
        <span>Back to home</span>
    </a>
    <h1 class="view-mode-bar__title">
        <% if (__viewMode === 'cuisines') { %>All cuisines<% } %>
        <% if (__viewMode === 'restaurants') { %>All restaurants<% } %>
        <% if (__viewMode === 'restaurant') { %><%= selected_restaurant ? selected_restaurant.name : 'Restaurant' %><% } %>
    </h1>
</nav>

<%# View=cuisines → full cuisine grid %>
<% if (__viewMode === 'cuisines' && cuisines && cuisines.length > 0) { %>
<section class="section">
    <ul class="cuisine-grid" role="list">
        <% cuisines.forEach(function (c) { %>
            <li class="cuisine-grid__item" data-search-name="<%= c.searchName || (c.name||'').toLowerCase() %>">
                <a class="cuisine-pill" href="/?cuisine=<%= encodeURIComponent(c.searchName || (c.name||'').toLowerCase()) %>" data-action="pick-cuisine">
                    <span class="cuisine-pill__icon cuisine-pill__icon--placeholder" data-tint="<%= c.tint %>" aria-hidden="true">
                        <span class="cuisine-pill__initial"><%= c.initial || '' %></span>
                        <% if (c.icon) { %><img class="cuisine-pill__photo" src="<%= c.icon %>" alt="" width="48" height="48" loading="lazy" data-img-fallback><% } %>
                    </span>
                    <span class="cuisine-pill__name"><%= c.name %></span>
                </a>
            </li>
        <% }); %>
    </ul>
</section>
<% } %>

<%# View=restaurants → full restaurant grid (paginated) %>
<% if (__viewMode === 'restaurants' && featured && featured.length > 0) { %>
<section class="section" data-paginate-section="featured">
    <ul class="resto-rail" role="list" data-load-target style="display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr))">
        <% featured.forEach(function (r) { %>
            <li data-search-id="<%= r.id %>">
                <a class="resto-card<%= r.isOpen ? '' : ' is-closed' %>" href="/?restaurant=<%= encodeURIComponent(r.slug || r.id) %>" data-action="pick-restaurant">
                    <div class="resto-card__media" data-tint="<%= r.tint %>">
                        <% if (r.image) { %><img src="<%= r.image %>" alt="" loading="lazy" data-img-fallback><% } else { %><%= r.initial %><% } %>
                        <% if (r.offer) { %><span class="resto-card__badge resto-card__badge--offer"><%= r.offer %><% if (r.offerCount && r.offerCount > 1) { %><span class="resto-card__badge-count"><%= r.offerCount %></span><% } %></span><% } %>
                    </div>
                    <div class="resto-card__body">
                        <span class="resto-card__name"><%= r.name %></span>
                        <% if ((r.cuisines || []).length) { %><p class="resto-card__cuisines"><%= (r.cuisines || []).slice(0,3).join(' · ') %></p><% } %>
                        <div class="resto-card__meta">
                            <span class="resto-card__rating"><svg width="11" height="11" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg><%= r.rating %></span>
                            <% if (r.deliveryMinutes) { %><span class="resto-card__time"><%= r.deliveryMinutes %></span><% } %>
                            <% if (typeof r.distanceKm === 'number' && r.distanceKm >= 0) { %><span class="resto-card__dist"><%= r.distanceKm.toFixed(1) %> km</span><% } %>
                        </div>
                    </div>
                </a>
            </li>
        <% }); %>
    </ul>
    <% if (typeof featured_more !== 'undefined' && featured_more) { %>
        <div class="section__loadmore" data-load-more="featured" data-offset="<%= featured.length %>">
            <button type="button" class="btn btn--ghost btn--lg section__loadmore-btn">See more</button>
        </div>
    <% } %>
</section>
<% } %>

<% } %>
