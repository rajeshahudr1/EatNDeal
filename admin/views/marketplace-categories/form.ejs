<%#
  views/marketplace-categories/form.ejs

  Add / edit a global marketplace category: name, slug (auto from name), an
  emoji icon (picker grid), an optional image (Yii uploads), status and sort
  order. `category` = the row to edit (or null to add).

  Used: Controllers/MarketplaceCategoriesController.form.
-%>
<%
    var p = category || {};
    var isEdit = !!(category && category.id);
    function isImg(s) { return !!s && (String(s).indexOf('/') !== -1 || /\.[a-z0-9]{2,5}$/i.test(String(s))); }
    var iconIsEmoji = p.icon && !isImg(p.icon);
    var EMOJIS = ['ЁЯНФ','ЁЯНЯ','ЁЯНХ','ЁЯМн','ЁЯек','ЁЯМо','ЁЯМп','ЁЯеЩ','ЁЯзЖ','ЁЯН│','ЁЯеШ','ЁЯН▓','ЁЯлХ','ЁЯег','ЁЯеЧ','ЁЯН┐','ЁЯел','ЁЯН▒','ЁЯНШ','ЁЯНЩ','ЁЯНЪ','ЁЯНЫ','ЁЯНЬ','ЁЯНЭ','ЁЯНа','ЁЯНв','ЁЯНг','ЁЯНд','ЁЯНе','ЁЯео','ЁЯНб','ЁЯеЯ','ЁЯеа','ЁЯеб','ЁЯжк','ЁЯНж','ЁЯНз','ЁЯНи','ЁЯНй','ЁЯНк','ЁЯОВ','ЁЯН░','ЁЯзБ','ЁЯез','ЁЯНл','ЁЯНм','ЁЯНн','ЁЯНо','ЁЯНп','ЁЯеЫ','тШХ','ЁЯлЦ','ЁЯН╡','ЁЯН╢','ЁЯН╛','ЁЯН╖','ЁЯН╕','ЁЯН╣','ЁЯН║','ЁЯН╗','ЁЯеВ','ЁЯеГ','ЁЯед','ЁЯзЛ','ЁЯзГ','ЁЯзЙ','ЁЯзК','ЁЯН╜я╕П','ЁЯН┤','ЁЯев','ЁЯем','ЁЯеж','ЁЯзД','ЁЯзЕ','ЁЯНД','ЁЯеЬ','ЁЯМ░','ЁЯНЗ','ЁЯНИ','ЁЯНЙ','ЁЯНК','ЁЯНЛ','ЁЯНМ','ЁЯНН','ЁЯен','ЁЯНО','ЁЯНП','ЁЯНР','ЁЯНС','ЁЯНТ','ЁЯНУ','ЁЯлР','ЁЯеЭ','ЁЯНЕ','ЁЯлТ','ЁЯее','ЁЯеС','ЁЯНЖ','ЁЯеФ','ЁЯеХ','ЁЯМ╜','ЁЯМ╢я╕П','ЁЯлС','ЁЯеТ','ЁЯНЮ','ЁЯеР','ЁЯеЦ','ЁЯлУ','ЁЯеи','ЁЯеп','ЁЯеЮ','ЁЯзЗ','ЁЯзА','ЁЯНЦ','ЁЯНЧ','ЁЯей','ЁЯеУ','ЁЯРЯ','ЁЯжР','ЁЯжА','ЁЯжЮ','ЁЯНЧ','ЁЯМ▒','ЁЯМ┐','ЁЯЫТ','ЁЯЫНя╕П','ЁЯПк','ЁЯОБ'];
%>
<div class="ly">

    <div class="ly__head">
        <div>
            <h2 class="ly__title"><%= isEdit ? 'тЬО Edit Category' : 'тЮХ Add Category' %></h2>
            <p class="ly__sub"><%= isEdit ? (p.name || 'Category') : 'A global marketplace category' %></p>
        </div>
        <a href="/marketplace-categories" class="ly-btn ly-btn--ghost ly-btn--sm">тЖР Back to list</a>
    </div>

    <% if (load_error) { %>
        <div class="ly-empty"><span class="ly-empty__ic" aria-hidden="true">ЁЯПв</span><p class="ly-empty__msg"><%= load_error %></p></div>
    <% } else { %>

    <form method="post" action="/marketplace-categories/save" enctype="multipart/form-data" class="pr-form mpc-form">
        <% if (isEdit) { %><input type="hidden" name="id" value="<%= p.id %>"><% } %>

        <section class="card ly-card">
            <h3 class="card__title">Details</h3>
            <div class="ly-grid">
                <div class="ly-field">
                    <label for="mc-name">Name <span class="pr-req">*</span></label>
                    <input id="mc-name" type="text" name="name" maxlength="120" value="<%= p.name || '' %>" required data-mc-name>
                </div>
                <div class="ly-field">
                    <label for="mc-slug">Slug <span class="ly-field__hint">(auto from name)</span></label>
                    <input id="mc-slug" type="text" name="slug" maxlength="140" value="<%= p.slug || '' %>" placeholder="e.g. fast-food" data-mc-slug>
                </div>
                <div class="ly-field">
                    <label for="mc-status">Status</label>
                    <select id="mc-status" name="status">
                        <option value="1" <%= (!isEdit || Number(p.status) === 1) ? 'selected' : '' %>>Active</option>
                        <option value="0" <%= (isEdit && Number(p.status) !== 1) ? 'selected' : '' %>>Inactive</option>
                    </select>
                </div>
                <div class="ly-field">
                    <label for="mc-sort">Sort order <span class="ly-field__hint">(auto тАФ last + 1, editable)</span></label>
                    <input id="mc-sort" type="number" name="sort_order" min="0" step="1" value="<%= isEdit ? (p.sort_order || 0) : (typeof next_sort !== 'undefined' ? next_sort : 1) %>" data-mc-sort>
                </div>
            </div>
        </section>

        <section class="card ly-card">
            <h3 class="card__title">Icon</h3>
            <input type="hidden" name="icon" value="<%= iconIsEmoji ? p.icon : '' %>" data-icon-input>
            <div class="mpc-iconhead">
                <span class="mpc-iconhead__lbl">Selected:</span>
                <span class="mpc-iconhead__cur" data-icon-current><%= iconIsEmoji ? p.icon : 'тАФ' %></span>
                <button type="button" class="ly-btn ly-btn--ghost ly-btn--sm" data-action="icon-clear">Clear</button>
            </div>
            <div class="mpc-iconpick">
                <% EMOJIS.forEach(function (e) { %>
                <button type="button" class="mpc-iconbtn<%= (iconIsEmoji && p.icon === e) ? ' is-on' : '' %>" data-icon="<%= e %>" aria-label="icon"><%= e %></button>
                <% }); %>
            </div>
        </section>

        <section class="card ly-card">
            <h3 class="card__title">Image <span class="ly-field__hint">(optional тАФ overrides the emoji)</span></h3>
            <div class="pr-imgrow">
                <div class="pr-imgprev" data-img-prev>
                    <% if (isEdit && p.image_url) { %><img src="<%= p.image_url %>" alt="" data-img-thumb><% } else { %><span class="pr-imgprev__ph" data-img-ph>No image</span><% } %>
                </div>
                <div class="pr-imgupload">
                    <input type="file" name="image" accept="image/png,image/jpeg,image/webp,image/gif,image/svg+xml" data-img-input>
                    <p class="ly-hint">PNG / JPG / WEBP / GIF / SVG, up to 3 MB. <%= isEdit ? 'Leave empty to keep the current image.' : '' %></p>
                    <%# Remove image тАФ an empty file input means "keep what's
                        there", so without this tick an uploaded image could
                        never be taken back off and the emoji icon could never
                        show again. Only offered when there IS one to remove. %>
                    <% if (isEdit && p.image_url) { %>
                    <label class="ly-check">
                        <input type="checkbox" name="remove_image" value="1">
                        <span>Remove image (show the emoji icon instead)</span>
                    </label>
                    <% } %>
                </div>
            </div>
        </section>

        <div class="ly-saveall">
            <a href="/marketplace-categories" class="ly-btn ly-btn--ghost">Cancel</a>
            <button type="submit" class="ly-btn ly-btn--primary ly-btn--lg"><%= isEdit ? 'Save changes' : 'Create category' %></button>
        </div>
    </form>

    <% } %>
</div>
