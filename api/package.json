{
  "name": "eatndeal-api",
  "version": "0.1.0",
  "private": true,
  "description": "EatNDeal Marketplace API — Node + Express + PostgreSQL. Connects to the existing wtw_eatndeal database; ports business logic from the Yii2 eatndealclean codebase.",
  "main": "index.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node --no-deprecation index.js",
    "dev": "nodemon --exec \"node --no-deprecation\" index.js"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "chalk": "^4.1.2",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.1",
    "google-auth-library": "^10.6.2",
    "helmet": "^7.1.0",
    "joi": "^18.2.1",
    "jsonwebtoken": "^9.0.3",
    "knex": "^3.2.10",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.11",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  }
}
