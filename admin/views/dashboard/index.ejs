<%#
  views/dashboard/index.ejs

  Post-login landing — the Loyalty Dashboard from the mockup: key metric
  cards, tier distribution, active features and quick-action tiles. The
  numbers are placeholders for now; a later phase wires them to the api.

  Used: Controllers/DashboardController.index (shell layout).
-%>
<div class="dash">

    <div class="dash__head">
        <div>
            <h2 class="dash__title">Loyalty Dashboard</h2>
            <p class="dash__sub">Program overview &amp; quick actions</p>
        </div>
        <span class="dash__period">This Month</span>
    </div>

    <%# Placeholder-data notice so nobody mistakes these for live figures. %>
    <p class="dash__note">ℹ️ Sample figures — live data is wired up in the next phase.</p>

    <%# Key metrics %>
    <div class="dash__metrics">
        <div class="metric metric--green"><span class="metric__val">£4,250</span><span class="metric__lbl">Cashback Given</span></div>
        <div class="metric metric--blue"><span class="metric__val">1,842</span><span class="metric__lbl">Active Wallets</span></div>
        <div class="metric metric--amber"><span class="metric__val">£1,120</span><span class="metric__lbl">Wallet Redeemed</span></div>
        <div class="metric metric--purple"><span class="metric__val">324</span><span class="metric__lbl">Total Referrals</span></div>
    </div>

    <div class="dash__grid">
        <%# Tier distribution %>
        <section class="card">
            <h3 class="card__title">🏅 Tier Distribution</h3>
            <div class="tierbar"><span class="tierbar__lbl">🥉 Bronze</span><span class="tierbar__track"><span class="tierbar__fill" style="width:65%;background:#cd7f32"></span></span><span class="tierbar__n">1,198</span></div>
            <div class="tierbar"><span class="tierbar__lbl">🥈 Silver</span><span class="tierbar__track"><span class="tierbar__fill" style="width:25%;background:#b9b9b9"></span></span><span class="tierbar__n">460</span></div>
            <div class="tierbar"><span class="tierbar__lbl">🏅 Gold</span><span class="tierbar__track"><span class="tierbar__fill" style="width:10%;background:#e7b400"></span></span><span class="tierbar__n">184</span></div>
        </section>

        <%# Active features %>
        <section class="card">
            <h3 class="card__title">⚡ Active Features</h3>
            <div class="feat-chips">
                <span class="chip chip--on">✓ Cashback</span>
                <span class="chip chip--on">✓ Tiers</span>
                <span class="chip chip--on">✓ Referrals</span>
                <span class="chip chip--on">✓ Streaks</span>
                <span class="chip chip--on">✓ BOGOF</span>
                <span class="chip chip--pause">⏸ Challenges</span>
                <span class="chip chip--off">✗ Segments</span>
            </div>
        </section>
    </div>

    <%# Quick actions %>
    <section class="card">
        <h3 class="card__title">🔧 Quick Actions</h3>
        <div class="quick">
            <a class="quick__tile" href="/loyalty/cashback-rules"><span class="quick__ic">💷</span><span>Cashback Rules</span></a>
            <a class="quick__tile" href="/loyalty/tiers"><span class="quick__ic">🏅</span><span>Tier Config</span></a>
            <a class="quick__tile" href="/loyalty/challenges"><span class="quick__ic">🏆</span><span>Challenges</span></a>
            <a class="quick__tile" href="/loyalty/review-claims"><span class="quick__ic">⭐</span><span>Review Claims</span></a>
            <a class="quick__tile" href="/loyalty/events"><span class="quick__ic">🎉</span><span>Event Rewards</span></a>
            <a class="quick__tile" href="/loyalty/segments"><span class="quick__ic">👥</span><span>Segments</span></a>
        </div>
    </section>

</div>
