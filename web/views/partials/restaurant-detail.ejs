<%#
  views/partials/restaurant-detail.ejs

  What:  Full single-restaurant page, built to the supplied mockup.
         Direct children of .rd (hero, info-bar, left menu, main, right
         rail) are placed by CSS grid-areas on desktop and re-ordered by
         flex `order` on mobile, so the reading order is always:
           hero → order info → category menu → dishes → side info.
  Why:   The user supplied this layout and asked for it on every
         restaurant open, fully responsive (proper mobile PWA), with the
         data driven from what we actually have.
  Data:  SiteController passes selected_restaurant + menu_categories +
         menu_sections (from GET /api/v1/marketplace/restaurant). Panels
         we have no data for (tiered offers, popular times, a real cart)
         are omitted rather than faked.
  JS:    /js/pages/restaurant.js (jump-links, scroll-spy, +Add, tabs).
-%>
<% if (!selected_restaurant) { %>
<section class="section"><p class="section__empty">We couldn't find that restaurant. <a href="/" data-action="view-home">Back to home</a>.</p></section>
<% } else { %>
<% var r = selected_restaurant; %>
<% var cats = (typeof menu_categories !== 'undefined' && menu_categories) ? menu_categories : []; %>
<% var secs = (typeof menu_sections   !== 'undefined' && menu_sections)   ? menu_sections   : []; %>
<% var sym  = fmt.currencySymbol(brand); %>
<% var __rv = (typeof restaurant_reviews !== 'undefined' && restaurant_reviews) ? restaurant_reviews : null; %>
<div class="rd" data-restaurant data-rslug="<%= r.slug %>" data-rd-open="<%= r.isOpen ? '1' : '0' %>" data-rd-preorder="<%= r.preOrder ? '1' : '0' %>">

    <%# Mobile-only rating bar — sits right under the search box (top of the
        restaurant content) and opens the reviews modal. Desktop uses the
        rail card + hero rating instead. Dynamic: only when reviews exist. %>
    <% if (__rv && __rv.count) { %>
    <button type="button" class="rd-ratingbar" data-action="open-reviews" aria-label="See ratings and reviews">
        <span class="rd-ratingbar__star">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            <strong><%= __rv.average %></strong>
        </span>
        <span class="rd-ratingbar__count"><%= __rv.count %> ratings &amp; reviews</span>
        <svg class="rd-ratingbar__chev" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
    </button>
    <% } %>

    <%# Reward-card balance — the signed-in customer's usable reward at THIS
        restaurant (loyalty, per company_id). Tap → Rewards wallet. Only > 0. %>
    <% var __rb = (typeof restaurant_reward_balance !== 'undefined' && restaurant_reward_balance) ? Number(restaurant_reward_balance) : 0; %>
    <% if (__rb > 0) { %>
    <a class="rd-rewardbar" href="/account?tab=rewards">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="5" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/></svg>
        <span>You have <strong><%= sym %><%= __rb.toFixed(2) %></strong> reward to use here</span>
        <svg class="rd-rewardbar__chev" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
    </a>
    <% } %>

    <%# Order-streak progress — nudge toward the next reward (loyalty
        product_streak). Stamp-card dots: <target> dots, first <current>
        filled. "ready" = the next order earns the reward. Only when a rule
        exists for this restaurant. %>
    <% var __rs = (typeof restaurant_reward_streak !== 'undefined' && restaurant_reward_streak) ? restaurant_reward_streak : null; %>
    <% if (__rs && __rs.target > 0) { %>
    <div class="rd-streakbar<%= __rs.ready ? ' rd-streakbar--ready' : '' %>">
        <span class="rd-streakbar__icon" aria-hidden="true">🎁</span>
        <div class="rd-streakbar__body">
            <% if (__rs.ready) { %>
                <p class="rd-streakbar__title">Reward ready — your next order earns <%= __rs.rewardLabel %>!</p>
            <% } else { %>
                <p class="rd-streakbar__title"><%= __rs.remaining %> more order<%= __rs.remaining === 1 ? '' : 's' %> → <%= __rs.rewardLabel %> reward</p>
            <% } %>
            <span class="rd-streakbar__dots" aria-hidden="true">
                <% for (var __i = 0; __i < __rs.target; __i++) { %><span class="rd-streakbar__dot<%= (__rs.ready || __i < __rs.current) ? ' is-on' : '' %>"></span><% } %>
            </span>
        </div>
    </div>
    <% } %>

    <%# ── Hero ───────────────────────────────────────────────────── %>
    <section class="rd-hero">
        <div class="rd-hero__media" data-tint="<%= r.tint %>">
            <% if (r.image) { %><img class="rd-hero__bg" src="<%= r.image %>" alt="" loading="lazy" data-img-fallback><% } %>
            <span class="rd-hero__logo" data-tint="<%= r.tint %>">
                <% if (r.logo) { %><img src="<%= r.logo %>" alt="<%= r.name %>" loading="lazy" data-img-fallback><% } else { %><span class="rd-hero__logo-initial"><%= r.initial %></span><% } %>
            </span>
            <%# Heart icon — login-only. Top-right of the hero. %>
            <% if (user_session) { %>
            <button type="button" class="rd-hero__fav<%= r.isFavourite ? ' is-active' : '' %>" data-fav-toggle="<%= r.id %>" data-fav-branch="<%= r.branchId || '' %>" data-fav-name="<%= r.name %>" aria-label="<%= r.isFavourite ? 'Remove from favourites' : 'Add to favourites' %>" aria-pressed="<%= r.isFavourite ? 'true' : 'false' %>">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
            </button>
            <% } %>
            <div class="rd-hero__overlay">
                <h1 class="rd-hero__name">
                    <%= r.name %>
                    <svg class="rd-hero__verified" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2 4 5v6c0 5 8 11 8 11s8-6 8-11V5l-8-3z" fill="none" stroke="currentColor" stroke-width="2"/><path d="m9 12 2 2 4-4" fill="none" stroke="currentColor" stroke-width="2"/></svg>
                </h1>
                <p class="rd-hero__meta">
                    <% if (r.rating) { %><span class="rd-hero__rating rd-hero__rating--btn" data-action="open-reviews" role="button" tabindex="0" aria-label="See ratings and reviews"><svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg> <%= r.rating %><% if (r.ratingCount) { %> <span class="rd-hero__rating-count">(<%= r.ratingCount %>+)</span><% } %></span><% } %>
                    <% if ((r.cuisines || []).length) { %><span class="rd-hero__dot">·</span><span><%= (r.cuisines || []).slice(0, 3).join(', ') %></span><% } %>
                </p>
                <% if (r.address) { %><p class="rd-hero__address"><%= r.address %></p><% } %>
            </div>
        </div>
    </section>

    <%# ── Info bar — fulfilment tabs + details + mini map ───────────── %>
    <section class="rd-info-bar">
        <%# Fulfilment tabs — only the modes this restaurant OFFERS (config-level,
            from r.offersDelivery / r.offersPickup). A single-mode restaurant shows
            just its one tab. The DEFAULT active tab follows the header mode
            (order_mode) but is constrained to an offered mode — so a pickup-only
            restaurant opened from a delivery link still starts on Pickup, and
            add-to-cart goes out as pickup (not delivery → no "doesn't deliver"). %>
        <% var __offDel  = (typeof r.offersDelivery === 'undefined') ? true : (r.offersDelivery !== false);
           var __offPick = (typeof r.offersPickup   === 'undefined') ? true : (r.offersPickup   !== false);
           var __mode = (typeof order_mode !== 'undefined' && order_mode === 'pickup') ? 'pickup' : 'delivery';
           if (__mode === 'delivery' && !__offDel)  { __mode = 'pickup';   }
           if (__mode === 'pickup'   && !__offPick) { __mode = 'delivery'; }
        %>
        <div class="rd-tabs<%= (__offDel && __offPick) ? '' : ' rd-tabs--single' %>" role="tablist" aria-label="Order type">
            <% if (__offDel) { %>
            <button type="button" class="rd-tab<%= __mode === 'delivery' ? ' is-active' : '' %>" data-rd-tab="delivery" role="tab" aria-selected="<%= __mode === 'delivery' ? 'true' : 'false' %>">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="9" cy="19" r="2"/><circle cx="18" cy="19" r="2"/><path d="M3 5h2l2 10h10l2-7H7"/></svg>
                Delivery
            </button>
            <% } %>
            <% if (__offPick) { %>
            <button type="button" class="rd-tab<%= __mode === 'pickup' ? ' is-active' : '' %>" data-rd-tab="pickup" role="tab" aria-selected="<%= __mode === 'pickup' ? 'true' : 'false' %>">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
                Pickup
            </button>
            <% } %>
        </div>

        <%# Delivery panel — time comes from the merchant/postcode. Starts
            hidden unless the effective mode is delivery. %>
        <div class="rd-info" data-rd-panel="delivery"<%= __mode === 'delivery' ? '' : ' hidden' %>>
            <div class="rd-info__cell">
                <span class="rd-info__label">Deliver to</span>
                <span class="rd-info__value"><%= (user_location && user_location.label) ? user_location.label : 'Set your location' %></span>
                <button type="button" class="rd-info__change" data-action="open-location-modal">Change</button>
            </div>
            <% if (r.deliveryMinutes) { %>
            <div class="rd-info__cell">
                <span class="rd-info__label">Delivery time</span>
                <span class="rd-info__value rd-info__value--strong"><%= r.deliveryMinutes %></span>
            </div>
            <% } %>
            <% if (typeof r.distanceKm === 'number' && r.distanceKm >= 0) { %>
            <div class="rd-info__cell">
                <span class="rd-info__label">Distance</span>
                <span class="rd-info__value rd-info__value--strong"><%= r.distanceKm.toFixed(1) %> km</span>
            </div>
            <% } %>
            <% if (typeof r.minOrder === 'number' && r.minOrder > 0) { %>
            <div class="rd-info__cell">
                <span class="rd-info__label">Min order</span>
                <span class="rd-info__value rd-info__value--strong"><%= brand.currencySymbol %><%= r.minOrder.toFixed(2) %></span>
            </div>
            <% } %>
            <% if (typeof r.deliveryFee === 'number') { %>
            <div class="rd-info__cell">
                <span class="rd-info__label">Delivery fee</span>
                <span class="rd-info__value rd-info__value--strong"><% if (r.deliveryFee === 0) { %>Free<% } else { %><%= brand.currencySymbol %><%= r.deliveryFee.toFixed(2) %><% } %></span>
            </div>
            <% } %>
            <% if (r.deliverable === false) { %>
            <div class="rd-info__cell rd-info__warn">Doesn't deliver to your area</div>
            <% } %>
            <div class="rd-map" aria-hidden="true">
                <span class="rd-map__home"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12 12 3l9 9"/><path d="M5 10v10h14V10"/></svg></span>
                <span class="rd-map__pin"><svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C7.6 2 4 5.6 4 10c0 5.5 8 12 8 12s8-6.5 8-12c0-4.4-3.6-8-8-8z"/></svg></span>
                <% if (typeof r.distanceKm === 'number' && r.distanceKm >= 0) { %>
                <span class="rd-map__pill"><%= r.distanceKm.toFixed(1) %> km<% if (r.deliveryMinutes) { %> · <%= r.deliveryMinutes %><% } %></span>
                <% } %>
            </div>
        </div>

        <%# Pickup panel — collect from the shop; time is a location/
            distance estimate (how long to reach the shop). Shown when the
            effective mode is pickup. %>
        <div class="rd-info" data-rd-panel="pickup"<%= __mode === 'pickup' ? '' : ' hidden' %>>
            <div class="rd-info__cell">
                <span class="rd-info__label">Collect from</span>
                <span class="rd-info__value"><%= r.address || r.name %></span>
            </div>
            <% if (r.pickupMinutes) { %>
            <div class="rd-info__cell">
                <span class="rd-info__label">Pickup time</span>
                <span class="rd-info__value rd-info__value--strong"><%= r.pickupMinutes %></span>
            </div>
            <% } %>
            <% if (typeof r.distanceKm === 'number' && r.distanceKm >= 0) { %>
            <div class="rd-info__cell">
                <span class="rd-info__label">Distance</span>
                <span class="rd-info__value rd-info__value--strong"><%= r.distanceKm.toFixed(1) %> km</span>
            </div>
            <% } %>
            <% if (r.phone) { %>
            <div class="rd-info__cell">
                <span class="rd-info__label">Call the shop</span>
                <a class="rd-info__value rd-info__value--strong rd-info__call" href="tel:<%= r.phone %>"><%= r.phone %></a>
            </div>
            <% } %>
            <div class="rd-map" aria-hidden="true">
                <span class="rd-map__home"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12 12 3l9 9"/><path d="M5 10v10h14V10"/></svg></span>
                <span class="rd-map__pin"><svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C7.6 2 4 5.6 4 10c0 5.5 8 12 8 12s8-6.5 8-12c0-4.4-3.6-8-8-8z"/></svg></span>
                <% if (typeof r.distanceKm === 'number' && r.distanceKm >= 0) { %>
                <span class="rd-map__pill"><%= r.distanceKm.toFixed(1) %> km<% if (r.pickupMinutes) { %> · <%= r.pickupMinutes %><% } %></span>
                <% } %>
            </div>
        </div>
    </section>

    <%# ── Left rail: back + category menu ────────────────────────── %>
    <aside class="rd__left">
        <a class="rd__back" href="/" data-action="view-home">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>
            <span>Back to all restaurants</span>
        </a>
        <% if (cats.length) { %>
        <nav class="rd-menu" aria-label="Menu categories" data-rd-menu>
            <% cats.forEach(function (c, i) { %>
                <a class="rd-menu__item<%= i === 0 ? ' is-active' : '' %>" href="#sec-<%= c.id %>" data-rd-jump="<%= c.id %>">
                    <% if (c.featured) { %><svg class="rd-menu__icon" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2c.4 3.2 2.8 4.6 2.8 7.2A2.8 2.8 0 0 1 12 12a2.8 2.8 0 0 1-2.8-2.8C9.2 6.6 11.6 5.2 12 2zM7 13c-2 1.5-3 3.3-3 5.2A5 5 0 0 0 12 22a5 5 0 0 0 5-3.8c0-1.9-1-3.7-3-5.2.3 1.6-.7 2.8-2 2.8-1.6 0-2-1.6-1-3-1.3.4-2.4 1.4-4 .4z"/></svg><% } %>
                    <span class="rd-menu__name"><%= c.name %></span>
                    <% if (typeof c.count === 'number') { %><span class="rd-menu__count"><%= c.count %></span><% } %>
                </a>
            <% }); %>
        </nav>
        <% } %>
    </aside>

    <%# ── Main: product sections ─────────────────────────────────── %>
    <div class="rd__main">
        <%# Surprise box ("Too Good To Go") — a discounted mystery box this
            restaurant offers. Shown at the top when the branch has one
            enabled (legacy is_toogoodtogo_product logic). %>
        <% if (r.surpriseBox) { var sb = r.surpriseBox; %>
        <section class="rd-surprise<%= sb.qty > 0 ? '' : ' is-out' %>" aria-label="Surprise box">
            <span class="rd-surprise__icon" aria-hidden="true">🎁</span>
            <div class="rd-surprise__body">
                <div class="rd-surprise__top">
                    <h2 class="rd-surprise__title">Surprise Box</h2>
                    <span class="rd-surprise__tag">Too Good To Go</span>
                </div>
                <% if (sb.description) { %><p class="rd-surprise__desc"><%= sb.description %></p><% } %>
                <p class="rd-surprise__meta">
                    <% if (sb.pickupFrom && sb.pickupTo) { %><span>⏰ Collect <%= sb.pickupFrom %> – <%= sb.pickupTo %></span><% } %>
                    <% if (sb.qty > 0) { %><span class="rd-surprise__left"><%= sb.qty %> left</span><% } else { %><span class="rd-surprise__left rd-surprise__left--out">Sold out today</span><% } %>
                </p>
                <%# PICKUP ONLY. The api refuses to add a box to a delivery cart
                    (CartController.addSurpriseBox, legacy's rule), so on the
                    delivery tab the CTA is swapped for this line — the button
                    was being offered and the customer only found out after
                    tapping it. It SAYS what to do rather than just vanishing,
                    so the box stays discoverable.
                    Rendered always and toggled by /js/pages/restaurant.js,
                    because the fulfilment tabs switch client-side (no reload) —
                    a server-only check would go stale the moment the customer
                    changed tab. %>
                <p class="rd-surprise__pickuponly" data-sb-pickuponly<%= __mode === 'delivery' ? '' : ' hidden' %>>Pickup only — switch to Pickup to add this box.</p>
            </div>
            <div class="rd-surprise__price">
                <% if (sb.price && sb.price > sb.discountPrice) { %><span class="rd-surprise__was"><%= sym %><%= sb.price.toFixed(2) %></span><% } %>
                <span class="rd-surprise__now"><%= sym %><%= (sb.discountPrice || 0).toFixed(2) %></span>
                <%# Hidden when today's slots are gone, and on the DELIVERY tab —
                    a surprise box is collected at the counter, never delivered
                    (see the pickup-only note above). The delivery case is a
                    `hidden` attribute rather than a skipped render so the tab
                    script can bring it back without a page load. %>
                <% if (sb.qty > 0) { %>
                <button type="button" class="rd-surprise__cta" data-sb-open<%= __mode === 'delivery' ? ' hidden' : '' %>>
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                    View &amp; Add to Cart
                </button>
                <% } %>
            </div>
        </section>

        <%# Surprise Box detail popup — opened by the CTA above. Server-rendered
            (no fetch): every field is already on the page. %>
        <div class="sb-modal" id="sb-modal" hidden>
            <div class="sb-modal__box" role="dialog" aria-modal="true" aria-labelledby="sb-modal-title">
                <button type="button" class="sb-modal__x" data-sb-close aria-label="Close">×</button>

                <div class="sb-modal__media">
                    <% if (sb.image) { %><img src="<%= sb.image %>" alt="Surprise Box" loading="lazy"><% } else { %><span class="sb-modal__ph" aria-hidden="true">🎁</span><% } %>
                    <span class="sb-modal__slots"><%= sb.qty %> slot<%= sb.qty === 1 ? '' : 's' %> left</span>
                </div>

                <div class="sb-modal__body">
                    <h3 class="sb-modal__title" id="sb-modal-title">Surprise Box</h3>
                    <p class="sb-modal__brand"><%= r.name %></p>

                    <p class="sb-modal__price">
                        <span class="sb-modal__now"><%= sym %><%= (sb.discountPrice || 0).toFixed(2) %></span>
                        <% if (sb.price && sb.price > sb.discountPrice) { %>
                        <span class="sb-modal__was"><%= sym %><%= sb.price.toFixed(2) %></span>
                        <% if (sb.savePct > 0) { %><span class="sb-modal__save">Save <%= sb.savePct %>%</span><% } %>
                        <% } %>
                    </p>

                    <% if (sb.pickupFrom && sb.pickupTo) { %>
                    <div class="sb-modal__collect">
                        <p class="sb-modal__collect-t">⏰ Collect Today: <%= sb.pickupFrom %> – <%= sb.pickupTo %></p>
                        <p class="sb-modal__collect-s">Show your order to staff at the counter</p>
                    </div>
                    <% } %>

                    <%# PICKUP ONLY — said up front, because the customer would
                        otherwise only discover it when Add fails. %>
                    <p class="sb-modal__note">🛍️ Collection only — this box can’t be delivered.</p>

                    <% if (r.address) { %>
                    <section class="sb-modal__sec">
                        <h4 class="sb-modal__h">Branch Address</h4>
                        <p class="sb-modal__addr">📍 <strong><%= r.name %></strong><br><%= r.address %></p>
                    </section>
                    <% } %>

                    <% if (sb.about) { %>
                    <section class="sb-modal__sec">
                        <h4 class="sb-modal__h">About this box</h4>
                        <p><%= sb.about %></p>
                    </section>
                    <% } %>

                    <section class="sb-modal__sec">
                        <h4 class="sb-modal__h">Ingredients &amp; allergens</h4>
                        <p>We wish we could tell you what exactly will be in your Surprise Bag — but it’s always a surprise! The store will fill it with a selection of their unsold items. If you have questions about allergens or specific ingredients, please ask the store.</p>
                    </section>

                    <% if (sb.collection) { %>
                    <section class="sb-modal__sec">
                        <h4 class="sb-modal__h">Collection instructions</h4>
                        <p><%= sb.collection %></p>
                    </section>
                    <% } %>
                </div>

                <form class="sb-modal__foot" data-sb-form
                      data-company="<%= r.id %>" data-max="<%= sb.qty %>" data-unit="<%= (sb.discountPrice || 0).toFixed(2) %>">
                    <div class="sb-qty">
                        <button type="button" class="sb-qty__b" data-sb-dec aria-label="Decrease quantity">−</button>
                        <span class="sb-qty__n" data-sb-qty>1</span>
                        <button type="button" class="sb-qty__b" data-sb-inc aria-label="Increase quantity">+</button>
                    </div>
                    <button type="submit" class="sb-modal__add" data-sb-add>
                        🛍️ Add to Cart — <span data-sb-total><%= sym %><%= (sb.discountPrice || 0).toFixed(2) %></span>
                    </button>
                </form>
            </div>
        </div>
        <% } %>

        <%# Active offers (banners + promo codes + auto-discounts) — real
            data from store_offer_banner_table / coupons / discounts. %>
        <% var offers = (typeof restaurant_offers !== 'undefined' && restaurant_offers) ? restaurant_offers : null; %>
        <% if (offers && offers.hasAny) { %>
        <section class="rd-offers" data-rail-wrap aria-label="Offers and deals">
            <div class="rd-offers__head">
                <h2 class="rd-offers__title">Offers &amp; deals</h2>
                <div class="hv2-head__nav rd-offers__nav">
                    <button type="button" class="rail-arrow rail-arrow--prev" data-rail-prev aria-label="Scroll left" disabled>
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>
                    </button>
                    <button type="button" class="rail-arrow rail-arrow--next" data-rail-next aria-label="Scroll right" disabled>
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
                    </button>
                </div>
            </div>
            <div class="rail-wrap">
                <div class="rd-offers__list" data-rail>
                <% offers.banners.forEach(function (b) { %>
                    <div class="rd-offer rd-offer--banner">
                        <span class="rd-offer__icon" aria-hidden="true"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.6 13.4 12 22l-9-9V3h10l7.6 7.6a2 2 0 0 1 0 2.8z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg></span>
                        <div class="rd-offer__body">
                            <p class="rd-offer__title"><%= b.title %></p>
                            <% if (b.details) { %><p class="rd-offer__sub"><%= b.details %></p><% } %>
                            <% if (b.terms) { %><p class="rd-offer__terms"><%= b.terms %></p><% } %>
                        </div>
                    </div>
                <% }); %>
                <% offers.coupons.forEach(function (c) { %>
                    <div class="rd-offer rd-offer--code">
                        <span class="rd-offer__icon" aria-hidden="true"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.59 13.41 11 3.83V3H3v8h.83l9.58 9.59a2 2 0 0 0 2.83 0l4.35-4.35a2 2 0 0 0 0-2.83z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg></span>
                        <div class="rd-offer__body">
                            <p class="rd-offer__title"><% if (c.type === 1) { %><%= c.value %>% OFF<% } else { %><%= sym %><%= c.value.toFixed(2) %> OFF<% } %><% if (c.freeDelivery) { %> · Free delivery<% } %></p>
                            <p class="rd-offer__sub">Use code <strong class="rd-offer__code"><%= c.code %></strong><% if (c.minOrder > 0) { %> · min <%= sym %><%= c.minOrder.toFixed(2) %><% } %></p>
                        </div>
                    </div>
                <% }); %>
                <% offers.discounts.forEach(function (d) { %>
                    <div class="rd-offer rd-offer--auto">
                        <span class="rd-offer__icon" aria-hidden="true"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="5" x2="5" y2="19"/><circle cx="6.5" cy="6.5" r="2.5"/><circle cx="17.5" cy="17.5" r="2.5"/></svg></span>
                        <div class="rd-offer__body">
                            <p class="rd-offer__title"><% if (d.type === 1) { %><%= d.value %>% off<% } else if (d.type === 2) { %><%= sym %><%= (d.value || 0).toFixed(2) %> off<% } else { %>Special deal<% } %><% if (d.product) { %> on <%= d.product %><% } %></p>
                            <p class="rd-offer__sub">Auto-applied at checkout<% if (d.minOrder > 0) { %> · orders over <%= sym %><%= d.minOrder.toFixed(0) %><% } %></p>
                        </div>
                    </div>
                <% }); %>
                </div><%# /.rd-offers__list %>
            </div><%# /.rail-wrap %>
        </section>
        <% } %>

        <% if (secs.length) { %>
            <% secs.forEach(function (s) { %>
            <section class="rd-section" id="sec-<%= s.id %>" data-rd-section="<%= s.id %>" data-section-slug="<%= s.slug || '' %>">
                <div class="rd-section__head">
                    <h2 class="rd-section__title"><%= s.name %> <span class="rd-section__count"><%= s.products.length %></span></h2>
                </div>
                <ul class="rd-products" role="list">
                    <% s.products.forEach(function (p) { %>
                        <%# Availability — status-driven (no stock). Unavailable
                            items (sold out / unavailable today / until) stay in
                            the menu but greyed with a badge + Add disabled. %>
                        <% var av = p.availability || { available: (p.available !== false), soldOut: false, label: 'Available' }; %>
                        <% var unavail = (av.available === false); %>
                        <li class="rd-product<%= unavail ? ' is-soldout' : '' %>" data-slug="<%= p.slug %>">
                            <div class="rd-product__media" data-tint="<%= p.tint %>">
                                <% if (unavail) { %><span class="rd-product__soldout"><%= av.soldOut ? 'Sold out' : 'Unavailable' %></span><% } %>
                                <% if (p.image) { %><img src="<%= p.image %>" alt="" loading="lazy" data-img-fallback><% } else { %><span class="rd-product__initial" aria-hidden="true"><%= p.initial %></span><% } %>
                                <% if (p.veg) { %><span class="veg-marker veg-marker--veg" aria-label="Vegetarian"></span><% } else { %><span class="veg-marker veg-marker--non-veg" aria-label="Non-vegetarian"></span><% } %>
                                <% if (p.isFeatured) { %><span class="rd-product__badge">Bestseller</span><% } %>
                            </div>
                            <div class="rd-product__body">
                                <h3 class="rd-product__name"><%= p.name %></h3>
                                <p class="rd-product__meta">
                                    <% if (p.rating) { %><span class="rd-product__rating"><svg width="11" height="11" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg> <%= p.rating %></span><% } %>
                                </p>
                                <%# Availability badge — ONLY when there's something to
                                    flag (Sold out / the precise reason e.g. "Available
                                    from 5 Jun"). An available item shows nothing — no
                                    redundant "Available" line. %>
                                <% if (av.soldOut) { %>
                                    <span class="rd-product__stockline rd-product__stockline--out">
                                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
                                        Sold out
                                    </span>
                                <% } else if (unavail) { %>
                                    <span class="rd-product__stockline rd-product__stockline--out">
                                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
                                        <%= av.label %>
                                    </span>
                                <% } %>
                                <% if (p.bogo && p.bogo.buyQty > 0 && p.bogo.getQty > 0) { %>
                                    <span class="rd-product__bogo">🎁 Buy <%= p.bogo.buyQty %> Get <%= p.bogo.getQty %> Free</span>
                                <% } %>
                                <div class="rd-product__foot">
                                    <% if (typeof p.originalPrice === 'number' && p.originalPrice > 0) { %>
                                        <span class="rd-product__price-was"><%= sym %><%= p.originalPrice.toFixed(2) %></span>
                                    <% } %>
                                    <span class="rd-product__price<%= (typeof p.originalPrice === 'number' && p.originalPrice > 0) ? ' rd-product__price--off' : '' %>"><%= sym %><%= (typeof p.price === 'number' ? p.price : 0).toFixed(2) %></span>
                                    <% if (unavail) { %>
                                        <span class="rd-product__oos"><%= av.soldOut ? 'Sold out' : 'Unavailable' %></span>
                                    <% } else { %>
                                        <button type="button" class="rd-product__add" data-action="rd-add" data-id="<%= p.id %>" data-name="<%= p.name %>">
                                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                                            Add
                                        </button>
                                    <% } %>
                                </div>
                            </div>
                        </li>
                    <% }); %>
                </ul>
            </section>
            <% }); %>
        <% } else { %>
            <section class="rd-section"><p class="section__empty">This restaurant hasn't published a marketplace menu yet.</p></section>
        <% } %>
    </div>

    <%# ── Right rail: cart · delivery to · restaurant info ───────── %>
    <aside class="rd__right" id="rd-info">
        <div class="rd-card rd-deliver">
            <h3 class="rd-card__subtitle"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s7-7.5 7-13a7 7 0 0 0-14 0c0 5.5 7 13 7 13z"/><circle cx="12" cy="9" r="2.5"/></svg> <%= (order_mode === 'pickup') ? 'Pickup from' : 'Delivery to' %></h3>
            <p class="rd-deliver__addr"><%= (user_location && user_location.label) ? user_location.label : 'Set your location' %></p>
            <button type="button" class="rd-deliver__change" data-action="open-location-modal">Change</button>
        </div>

        <div class="rd-card rd-rinfo">
            <h3 class="rd-card__subtitle">Restaurant info
                <button type="button" class="rd-rinfo__more" data-action="rd-open-info" aria-label="Restaurant details and opening hours" title="Details &amp; opening hours">
                    <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
                </button>
            </h3>
            <ul class="rd-rinfo__list">
                <li class="rd-rinfo__row">
                    <span class="rd-rinfo__dot <%= r.isOpen ? 'is-open' : 'is-closed' %>"></span>
                    <span class="rd-rinfo__text">
                        <span class="rd-rinfo__label"><%= r.isOpen ? 'Open now' : (r.openStatus === 'preorder' ? 'Closed — pre-order' : 'Closed') %></span>
                        <% if (!r.isOpen && r.closedMessage) { %>
                            <span class="rd-rinfo__sub"><%= r.closedMessage %></span>
                        <% } else if (!r.isOpen && r.opensAt) { %>
                            <span class="rd-rinfo__sub">Opens at <%= r.opensAt %><% if (r.hours) { %> · <%= r.hours %><% } %></span>
                        <% } else if (r.hours) { %>
                            <span class="rd-rinfo__sub"><%= r.hours %></span>
                        <% } %>
                    </span>
                </li>

                <%# Per-service availability — Delivery / Pickup / Pre-order
                    (real open/closed from store_business_hours + ETA). %>
                <li class="rd-rinfo__row">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
                    <span class="rd-rinfo__text">
                        <span class="rd-rinfo__label">Delivery
                            <span class="rd-rinfo__badge <%= r.deliveryOpen ? 'is-open' : 'is-closed' %>"><%= r.deliveryOpen ? 'Open' : 'Closed' %></span>
                        </span>
                        <% if (r.deliveryOpen && r.deliveryMinutes) { %><span class="rd-rinfo__sub"><%= r.deliveryMinutes %></span><% } %>
                    </span>
                </li>
                <li class="rd-rinfo__row">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
                    <span class="rd-rinfo__text">
                        <span class="rd-rinfo__label">Pickup
                            <span class="rd-rinfo__badge <%= r.pickupOpen ? 'is-open' : 'is-closed' %>"><%= r.pickupOpen ? 'Open' : 'Closed' %></span>
                        </span>
                        <% if (r.pickupOpen && r.pickupMinutes) { %><span class="rd-rinfo__sub"><%= r.pickupMinutes %></span><% } %>
                    </span>
                </li>
                <% if (r.preOrder) { %>
                <li class="rd-rinfo__row">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                    <span class="rd-rinfo__text">
                        <span class="rd-rinfo__label">Pre-order
                            <span class="rd-rinfo__badge is-open">Available</span>
                        </span>
                        <span class="rd-rinfo__sub">Schedule for a later time</span>
                    </span>
                </li>
                <% } %>

                <% if (r.phone) { %>
                <li class="rd-rinfo__row">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                    <a class="rd-rinfo__text rd-rinfo__link" href="tel:<%= r.phone %>"><%= r.phone %></a>
                </li>
                <% } %>
                <% if (r.website) { %>
                <li class="rd-rinfo__row">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
                    <a class="rd-rinfo__text rd-rinfo__link" href="<%= /^https?:/i.test(r.website) ? r.website : 'http://' + r.website %>" target="_blank" rel="noopener noreferrer"><%= r.website %></a>
                </li>
                <% } %>
                <li class="rd-rinfo__row">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                    <button type="button" class="rd-rinfo__text rd-rinfo__link" data-action="rd-report">Report a problem</button>
                </li>
            </ul>
        </div>

        <%# The "Review us & earn cashback" screenshot-upload widget was removed
            from here on request — earning cashback for a Google/Facebook review
            happens on the dedicated /earn page, not scattered on the restaurant
            page. Only the reviews LIST stays below. %>

        <%# Customer reviews — published post-order ratings (stars + text +
            optional food photo), from /api/v1/marketplace/reviews. %>
        <% if (__rv && __rv.count) { %>
        <%# Compact rail card — top reviews preview + "View all" opens the modal. %>
        <div class="rd-card rd-reviews">
            <h3 class="rd-card__subtitle">
                Ratings &amp; reviews
                <% if (__rv.average) { %><span class="rd-reviews__avg">&#9733; <%= __rv.average %></span> <span class="rd-reviews__count">(<%= __rv.count %>)</span><% } %>
            </h3>
            <ul class="rd-reviews__list rd-reviews__list--preview">
                <% (__rv.reviews || []).slice(0, 5).forEach(function (rev) { %>
                <li class="rd-review">
                    <div class="rd-review__head">
                        <span class="rd-review__name"><%= rev.customerName %></span>
                        <span class="rd-review__stars" aria-label="<%= rev.rating %> out of 5">
                            <% for (var k = 1; k <= 5; k++) { %><span class="<%= rev.rating >= k ? 'is-on' : '' %>">&#9733;</span><% } %>
                        </span>
                    </div>
                    <% if (rev.review) { %><p class="rd-review__text"><%= rev.review %></p><% } %>
                    <% if (rev.photo) { %><img class="rd-review__photo" src="<%= rev.photo %>" alt="Review photo" loading="lazy"><% } %>
                </li>
                <% }); %>
            </ul>
            <button type="button" class="rd-reviews__viewall" data-action="open-reviews">View all <%= __rv.count %> reviews</button>
        </div>
        <% } %>
    </aside>

    <%# ── Ratings & reviews modal — full sort / star-filter / load-more
        experience. Opened by the rail's "View all" OR the hero rating (the
        primary entry on phones, near the top). Lives OUTSIDE the rail so
        hiding the rail card on phones doesn't hide it. JS: reviews-list.js. -%>
    <% if (__rv && __rv.count) { %>
    <div class="reviews-modal" data-reviews-modal data-company-id="<%= r.id %>" hidden aria-hidden="true">
        <div class="reviews-modal__backdrop" data-action="close-reviews"></div>
        <div class="reviews-modal__panel" role="dialog" aria-modal="true" aria-labelledby="reviews-modal-title">
            <header class="reviews-modal__head">
                <h2 class="reviews-modal__title" id="reviews-modal-title">Ratings &amp; reviews
                    <% if (__rv.average) { %><span class="rd-reviews__avg">&#9733; <%= __rv.average %></span> <span class="rd-reviews__count">(<%= __rv.count %>)</span><% } %>
                </h2>
                <button type="button" class="reviews-modal__close" data-action="close-reviews" aria-label="Close">&times;</button>
            </header>
            <div class="reviews-modal__controls">
                <div class="rd-reviews__sort" role="tablist" aria-label="Sort reviews" data-rv-sort>
                    <button type="button" class="rd-reviews__sort-btn is-active" data-sort="recent">All</button>
                    <button type="button" class="rd-reviews__sort-btn" data-sort="best">Best first</button>
                    <button type="button" class="rd-reviews__sort-btn" data-sort="worst">Critical</button>
                </div>
                <div class="rd-reviews__filter" aria-label="Filter by stars" data-rv-stars>
                    <button type="button" class="rd-reviews__chip is-active" data-star="">All</button>
                    <% [5, 4, 3, 2, 1].forEach(function (s) { %>
                    <button type="button" class="rd-reviews__chip" data-star="<%= s %>"><%= s %>&#9733; <span class="rd-reviews__chip-n">(<%= (__rv.breakdown && __rv.breakdown[s]) || 0 %>)</span></button>
                    <% }); %>
                </div>
            </div>
            <div class="reviews-modal__body">
                <div class="rd-reviews__loader" data-rv-loader hidden><span class="rv-spinner" aria-hidden="true"></span> Loading reviews…</div>
                <ul class="rd-reviews__list" data-rv-list></ul>
                <p class="rd-reviews__empty" data-rv-empty hidden>No reviews with this rating yet.</p>
                <button type="button" class="rd-reviews__more" data-rv-more hidden>Load more reviews</button>
            </div>
        </div>
    </div>
    <% } %>

    <%# ── Restaurant info + opening-hours popup (info icon in the card) ──
        Mobile: bottom sheet · desktop: centred card. JS: pages/restaurant.js. -%>
    <div class="rd-infomodal" data-rd-infomodal hidden aria-hidden="true">
        <div class="rd-infomodal__backdrop" data-action="rd-close-info"></div>
        <div class="rd-infomodal__sheet" role="dialog" aria-modal="true" aria-labelledby="rd-infomodal-title">
            <header class="rd-infomodal__head">
                <h2 class="rd-infomodal__title" id="rd-infomodal-title">Restaurant info</h2>
                <button type="button" class="rd-infomodal__close" data-action="rd-close-info" aria-label="Close">&times;</button>
            </header>
            <div class="rd-infomodal__body">
                <section class="rd-infomodal__sec">
                    <h3 class="rd-infomodal__h">Info</h3>
                    <p class="rd-infomodal__name"><%= r.name %></p>
                    <% if (r.phone) { %><a class="rd-infomodal__line rd-infomodal__link" href="tel:<%= r.phone %>"><%= r.phone %></a><% } %>
                    <% if (r.address) { %><p class="rd-infomodal__line"><%= r.address %></p><% } %>
                </section>

                <% if (r.address || (r.lat != null && r.lng != null)) { %>
                <% var __maps = (r.lat != null && r.lng != null) ? ('https://www.google.com/maps/search/?api=1&query=' + r.lat + ',' + r.lng) : ('https://www.google.com/maps/search/?api=1&query=' + encodeURIComponent(r.address || r.name)); %>
                <section class="rd-infomodal__sec">
                    <h3 class="rd-infomodal__h">Location</h3>
                    <% if (r.address) { %><p class="rd-infomodal__line"><%= r.address %></p><% } %>
                    <a class="rd-infomodal__maps" href="<%= __maps %>" target="_blank" rel="noopener noreferrer">Open in Maps
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                    </a>
                </section>
                <% } %>

                <% if (r.weekHours && r.weekHours.length) { %>
                <section class="rd-infomodal__sec">
                    <h3 class="rd-infomodal__h">Opening hours</h3>
                    <table class="rd-hours">
                        <thead><tr><th scope="col">Day</th><th scope="col">Pickup</th><th scope="col">Delivery</th></tr></thead>
                        <tbody>
                            <% r.weekHours.forEach(function (d) { %>
                            <tr class="rd-hours__row<%= d.isToday ? ' is-today' : '' %>">
                                <th scope="row" class="rd-hours__day"><%= d.short %><% if (d.isToday) { %> <span class="rd-hours__badge">Today</span><% } %></th>
                                <td><%= d.pickup || 'Closed' %></td>
                                <td><%= d.delivery || 'Closed' %></td>
                            </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </section>
                <% } %>
            </div>
        </div>
    </div>
</div>
<% } %>
