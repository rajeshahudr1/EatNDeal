<%#
  views/partials/mobile-drawer.ejs

  What:  Mobile slide-in drawer (from the right) — the phone equivalent of
         the desktop account page. It now mirrors the REAL account features
         (My Profile, Addresses, Payment Methods, My Orders, Favourites,
         Rewards) so every row opens a working, responsive page. Dead /
         placeholder rows (Appearance, personalised-ratings toggle,
         Notifications, Settings — none of which have a real screen) were
         removed per the "remove what doesn't work" cleanup.
  Links: every account row → /account?tab=… (the same destinations the
         desktop sidebar uses). Account rows + rewards show only when the
         customer is signed in; guests get a sign-in prompt instead.
  Used:  Included from views/_layout.ejs. Toggled by /js/app.js.
-%>
<div
    id="mobile-drawer"
    class="mobile-drawer"
    role="dialog"
    aria-modal="true"
    aria-labelledby="mobile-drawer-title"
    aria-hidden="true"
    hidden
>
    <div class="mobile-drawer__backdrop" data-action="close-mobile-menu" aria-hidden="true"></div>

    <aside class="mobile-drawer__panel" role="document">

        <div class="md-head">
            <button type="button" class="md-back" data-action="close-mobile-menu" aria-label="Close menu">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
            </button>
        </div>

        <%# Profile card / sign-in %>
        <% if (user_session) { %>
            <div class="md-profile">
                <span class="md-profile__avatar" aria-hidden="true"><%= (user_session.firstname || '?').charAt(0).toUpperCase() %></span>
                <div class="md-profile__body">
                    <p class="md-profile__name"><%= (user_session.firstname || 'My account').toUpperCase() %></p>
                    <a class="md-profile__edit" href="/account">Edit profile <span aria-hidden="true">›</span></a>
                </div>
            </div>
        <% } else { %>
            <div class="md-profile md-profile--guest">
                <span class="md-profile__avatar" aria-hidden="true">👋</span>
                <div class="md-profile__body">
                    <p class="md-profile__name">Welcome</p>
                    <a class="md-profile__edit" href="/signin">Sign in or create account <span aria-hidden="true">›</span></a>
                </div>
            </div>
        <% } %>

        <%# Rewards banner — signed-in opens the Rewards tab; guests are sent
            to sign-in (rewards need an account). %>
        <a class="md-rewards" href="<%= user_session ? '/account?tab=rewards' : '/signin' %>">
            <span class="md-rewards__crown" aria-hidden="true">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M5 16 3 6l5.5 4L12 4l3.5 6L21 6l-2 10H5zm0 2h14v2H5v-2z"/></svg>
            </span>
            <span class="md-rewards__text"><%= user_session ? (brand.name + ' Rewards') : ('Join ' + brand.name + ' Rewards') %></span>
            <span class="md-rewards__chev" aria-hidden="true">›</span>
        </a>

        <% if (user_session) { %>
        <%# Quick tile — Offers. (Rewards already has its own banner above, so
            no separate "Money" tile here — it would just point to the same
            Rewards screen.) %>
        <div class="md-tiles">
            <a class="md-tile md-tile--full" href="/offers">
                <span class="md-tile__icon" aria-hidden="true"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M9 9h.01M15 15h.01M16 8l-8 8"/><circle cx="12" cy="12" r="10"/></svg></span>
                <span class="md-tile__body"><span class="md-tile__label">Offers &amp; deals</span></span>
                <span class="md-row__chev" aria-hidden="true">›</span>
            </a>
        </div>

        <%# Your account — mirrors the desktop sidebar; every row is a real,
            responsive page. Placeholder tabs (Notifications / Settings) are
            intentionally left out on mobile. %>
        <section class="md-sec">
            <h3 class="md-sec__title">Your account</h3>
            <div class="md-card">
                <a class="md-row" href="/account?tab=addresses">
                    <span class="md-row__icon" aria-hidden="true"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s7-7.5 7-13a7 7 0 0 0-14 0c0 5.5 7 13 7 13z"/><circle cx="12" cy="9" r="2.5"/></svg></span>
                    <span class="md-row__label">Addresses</span>
                    <span class="md-row__chev" aria-hidden="true">›</span>
                </a>
                <a class="md-row" href="/account?tab=payment">
                    <span class="md-row__icon" aria-hidden="true"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="5" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/></svg></span>
                    <span class="md-row__label">Payment Methods</span>
                    <span class="md-row__chev" aria-hidden="true">›</span>
                </a>
                <a class="md-row" href="/account?tab=orders">
                    <span class="md-row__icon" aria-hidden="true"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M9 3H6a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V5a2 2 0 0 0-2-2h-3"/><rect x="9" y="2" width="6" height="4" rx="1"/><line x1="8" y1="11" x2="16" y2="11"/></svg></span>
                    <span class="md-row__label">My Orders</span>
                    <span class="md-row__chev" aria-hidden="true">›</span>
                </a>
                <a class="md-row" href="/account?tab=favourites">
                    <span class="md-row__icon" aria-hidden="true"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M20.8 4.6a5.5 5.5 0 0 0-7.8 0L12 5.7l-1-1.1a5.5 5.5 0 0 0-7.8 7.8l1 1.1L12 21l7.8-7.5 1-1.1a5.5 5.5 0 0 0 0-7.8z"/></svg></span>
                    <span class="md-row__label">Favourites</span>
                    <span class="md-row__chev" aria-hidden="true">›</span>
                </a>
            </div>
        </section>
        <% } %>

        <%# Preferences — only the row that actually does something (Veg
            filter). Appearance + personalised-ratings were removed. %>
        <section class="md-sec">
            <h3 class="md-sec__title">Preferences</h3>
            <div class="md-card">
                <a class="md-row" href="/?veg=1">
                    <span class="md-row__icon md-row__icon--veg" aria-hidden="true"><span></span></span>
                    <span class="md-row__label">Veg Mode</span>
                    <span class="md-row__chev" aria-hidden="true">›</span>
                </a>
            </div>
        </section>

        <%# More — site / help links %>
        <section class="md-sec">
            <h3 class="md-sec__title">More</h3>
            <div class="md-card">
                <a class="md-row" href="/help"><span class="md-row__label">Help centre</span><span class="md-row__chev" aria-hidden="true">›</span></a>
                <a class="md-row" href="/about"><span class="md-row__label">About</span><span class="md-row__chev" aria-hidden="true">›</span></a>
                <a class="md-row" href="/partner"><span class="md-row__label">Partner with us</span><span class="md-row__chev" aria-hidden="true">›</span></a>
                <a class="md-row" href="<%= brand.termsUrl || '/terms' %>"><span class="md-row__label">Terms</span><span class="md-row__chev" aria-hidden="true">›</span></a>
                <a class="md-row" href="<%= brand.privacyUrl || '/privacy' %>"><span class="md-row__label">Privacy</span><span class="md-row__chev" aria-hidden="true">›</span></a>
            </div>
        </section>

        <ul class="md-social" aria-label="Social media">
            <li><a href="#" aria-label="Facebook"><svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M22 12.06C22 6.5 17.52 2 12 2S2 6.5 2 12.06c0 5.02 3.66 9.19 8.44 9.94v-7.03H7.9v-2.91h2.54V9.85c0-2.5 1.49-3.89 3.77-3.89 1.09 0 2.24.2 2.24.2v2.46h-1.26c-1.24 0-1.63.77-1.63 1.56v1.88h2.78l-.44 2.91h-2.34V22c4.78-.75 8.44-4.92 8.44-9.94z"/></svg></a></li>
            <li><a href="#" aria-label="Instagram"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor"/></svg></a></li>
            <li><a href="#" aria-label="X"><svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2H21l-6.52 7.46L22 22h-6.828l-4.69-6.137L4.86 22H2.103l6.97-7.97L2 2h6.96l4.24 5.61L18.244 2z"/></svg></a></li>
        </ul>
        <p class="md-copy"><%= brand.copyright %><span class="md-build"> · v<%= ASSET_VERSION.slice(-6) %></span></p>

        <% if (user_session) { %>
            <form method="post" action="/logout" class="md-logout"><button type="submit" class="md-logout__btn">Log out</button></form>
        <% } %>

    </aside>
</div>
