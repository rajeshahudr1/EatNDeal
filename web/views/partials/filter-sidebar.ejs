<%#
  views/partials/filter-sidebar.ejs

  What:  Web-only left filter panel, rebuilt to the mockup:
           Sort by (radio) · Delivery Time · Offers · Rating ·
           Price for one · Cuisines (searchable) · Dietary Preference ·
           More filters (toggles) · Apply Filters + Reset.
  Why:   The user supplied a mockup with a full left filter rail and
         asked for an exact match. Functional filters (sort / rating /
         delivery-time / price / veg / open-now / offer) map onto the
         api query via /js/ui/filter-sidebar.js → home.js. The numeric
         counts beside each row are static placeholders (we have no
         per-facet counts endpoint yet) per the user's "static-HTML
         what we don't have" instruction.
  Used:  Included from views/site/index.ejs inside .home-shell.
         Hidden < 1024 px (mobile uses the bottom sheet).
-%>
<%#
  fc   — dynamic facet counts from the api (SiteController → facet_counts).
  badge(v) — renders the count chip ONLY when we have a real number for
  that option; null/undefined (api down, or a facet we don't compute)
  renders nothing rather than a fake placeholder.
-%>
<%
  var fc = (typeof facet_counts !== 'undefined' && facet_counts) ? facet_counts : null;
  function badge(v) { return (v === 0 || v) ? ('<b class="fsb__count">' + v + '</b>') : ''; }
  // Count-gating: hide an option ONLY when its count is explicitly 0. A null/
  // absent count (facet not computed, or api down) → keep it, so the filter
  // never disappears just because we don't have numbers. A group hides when
  // ALL its options are an explicit 0.
  function keep(v)    { return v == null || Number(v) > 0; }
  function anyKeep(a) { return (a || []).some(function (v) { return v == null || Number(v) > 0; }); }
  function dc(k) { return (fc && fc.delivery) ? fc.delivery[k] : null; }
  function rc(k) { return (fc && fc.rating)   ? fc.rating[k]   : null; }
  function pc(k) { return (fc && fc.price)    ? fc.price[k]    : null; }
%>
<aside class="fsb" aria-label="Filters">
    <header class="fsb__head">
        <h2 class="fsb__title">Filters</h2>
        <button type="button" class="fsb__clear" data-action="filters-clear-all">Clear all</button>
        <%# Hide / close control. Desktop: collapses the sidebar (a
            small Filters pill reappears to reopen). Mobile: closes the
            full-screen overlay. Rendered as an X (close) icon. %>
        <button type="button" class="fsb__hide" data-action="toggle-filters" aria-label="Close filters" title="Close filters">
            <%- include('icons', {icon:'close', w:18, h:18, sw:'2.4'}) %>
        </button>
    </header>

    <div class="fsb__scroll">

        <%# ── Sort by ── %>
        <section class="fsb__group">
            <h3 class="fsb__group-title">Sort by</h3>
            <label class="fsb__radio"><input type="radio" name="sort-web" value="relevance" checked><span>Recommended</span></label>
            <label class="fsb__radio"><input type="radio" name="sort-web" value="rating"><span>Rating: High to Low</span></label>
            <label class="fsb__radio"><input type="radio" name="sort-web" value="time"><span>Delivery Time: Low to High</span></label>
            <label class="fsb__radio"><input type="radio" name="sort-web" value="distance"><span>Distance: Low to High</span></label>
        </section>

        <%# ── Delivery time ── (only bands with count > 0) %>
        <% if (anyKeep([dc('15'), dc('30'), dc('45'), dc('60')])) { %>
        <section class="fsb__group">
            <h3 class="fsb__group-title">Delivery Time</h3>
            <% if (keep(dc('15'))) { %><label class="fsb__check"><input type="checkbox" data-filter="time-15"><span>Up to 15 min</span><%- badge(dc('15')) %></label><% } %>
            <% if (keep(dc('30'))) { %><label class="fsb__check"><input type="checkbox" data-filter="time-30"><span>15 – 30 min</span><%- badge(dc('30')) %></label><% } %>
            <% if (keep(dc('45'))) { %><label class="fsb__check"><input type="checkbox" data-filter="time-45"><span>30 – 45 min</span><%- badge(dc('45')) %></label><% } %>
            <% if (keep(dc('60'))) { %><label class="fsb__check"><input type="checkbox" data-filter="time-60"><span>45+ min</span><%- badge(dc('60')) %></label><% } %>
        </section>
        <% } %>

        <%# ── Offers ── (only when there are offers nearby) %>
        <% if (keep(fc ? fc.offer : null)) { %>
        <section class="fsb__group">
            <h3 class="fsb__group-title">Offers</h3>
            <label class="fsb__check"><input type="checkbox" data-filter="offer-discount"><span>Offers near you</span><%- badge(fc ? fc.offer : null) %></label>
        </section>
        <% } %>

        <%# ── Rating ── (only thresholds with count > 0). Floor is 3.5 —
            per user request we only surface 3.5 / 4.0 / 4.5 & above (the
            "3.0 & above" option was removed). %>
        <% if (anyKeep([rc('4.5'), rc('4.0'), rc('3.5')])) { %>
        <section class="fsb__group">
            <h3 class="fsb__group-title">Rating</h3>
            <% if (keep(rc('4.5'))) { %><label class="fsb__radio fsb__rating"><input type="radio" name="rating-web" data-filter="rating-4.5"><span class="fsb__stars">★</span><span>4.5 &amp; above</span><%- badge(rc('4.5')) %></label><% } %>
            <% if (keep(rc('4.0'))) { %><label class="fsb__radio fsb__rating"><input type="radio" name="rating-web" data-filter="rating-4.0"><span class="fsb__stars">★</span><span>4.0 &amp; above</span><%- badge(rc('4.0')) %></label><% } %>
            <% if (keep(rc('3.5'))) { %><label class="fsb__radio fsb__rating"><input type="radio" name="rating-web" data-filter="rating-3.5"><span class="fsb__stars">★</span><span>3.5 &amp; above</span><%- badge(rc('3.5')) %></label><% } %>
        </section>
        <% } %>

        <%# ── Price for one ── (only tiers with count > 0) %>
        <% if (anyKeep([pc('low'), pc('mid'), pc('high')])) { %>
        <section class="fsb__group">
            <h3 class="fsb__group-title">Price for one</h3>
            <% if (keep(pc('low')))  { %><label class="fsb__check"><input type="checkbox" data-filter="price-low"><span><%= brand.currencySymbol %> &ndash; 6</span><%- badge(pc('low')) %></label><% } %>
            <% if (keep(pc('mid')))  { %><label class="fsb__check"><input type="checkbox" data-filter="price-mid"><span><%= brand.currencySymbol %><%= brand.currencySymbol %> 6 &ndash; 12</span><%- badge(pc('mid')) %></label><% } %>
            <% if (keep(pc('high'))) { %><label class="fsb__check"><input type="checkbox" data-filter="price-high"><span><%= brand.currencySymbol %><%= brand.currencySymbol %><%= brand.currencySymbol %> 12+</span><%- badge(pc('high')) %></label><% } %>
        </section>
        <% } %>

        <%# ── Cuisines ── (dynamic list from the api categories) %>
        <% if (typeof cuisines !== 'undefined' && cuisines && cuisines.length) { %>
        <section class="fsb__group">
            <h3 class="fsb__group-title">Cuisines</h3>
            <div class="fsb__search">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="7"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                <input type="search" class="fsb__search-input" placeholder="Search cuisines" data-fsb-cuisine-search aria-label="Search cuisines">
            </div>
            <div class="fsb__cuisine-list">
                <% cuisines.slice(0, 8).forEach(function (c) { %>
                    <label class="fsb__check" data-cuisine-name="<%= (c.name||'').toLowerCase() %>">
                        <input type="checkbox" data-filter="cuisine-<%= c.searchName || (c.name||'').toLowerCase() %>">
                        <span><%= c.name %></span>
                    </label>
                <% }); %>
            </div>
        </section>
        <% } %>

        <%# ── Dietary Preference ── (only when there are veg-only places) %>
        <% if (keep(fc ? fc.veg : null)) { %>
        <section class="fsb__group">
            <h3 class="fsb__group-title">Dietary Preference</h3>
            <label class="fsb__check"><input type="checkbox" data-filter="trust-pure-veg"><span>Veg Only</span><%- badge(fc ? fc.veg : null) %></label>
        </section>
        <% } %>

        <%# ── More filters (toggles) ── %>
        <section class="fsb__group">
            <h3 class="fsb__group-title">More filters</h3>
            <label class="fsb__toggle"><span>Open Now</span><input type="checkbox" data-filter="avail-open-now"><i class="fsb__switch" aria-hidden="true"></i></label>
            <label class="fsb__toggle"><span>Top Rated</span><input type="checkbox" data-filter="rating-4.0"><i class="fsb__switch" aria-hidden="true"></i></label>
            <label class="fsb__toggle"><span>Restaurants near me</span><input type="checkbox" data-filter="dist-5"><i class="fsb__switch" aria-hidden="true"></i></label>
        </section>

        <%# ── Browse (2-level): main category (Favourites / Collections / Offers
            / Sponsored / Featured) → its items. Built from the live feed; ONLY
            items whose count > 0 are listed. Picking one narrows the whole home
            to just that set's restaurants. %>
        <% var __browse = (typeof browse_options !== 'undefined' && browse_options) ? browse_options : []; %>
        <% if (__browse.length) { %>
        <section class="fsb__group fsb__group--browse">
            <h3 class="fsb__group-title">Collections &amp; offers</h3>
            <% ['Favourites', 'Collections', 'Offers', 'Sponsored', 'Featured'].forEach(function (grp) { %>
                <% var __items = __browse.filter(function (o) { return o.group === grp; }); %>
                <% if (__items.length) { %>
                <p class="fsb__subhead"><%= grp %></p>
                <% __items.forEach(function (o) { %>
                    <label class="fsb__radio fsb__radio--browse"><input type="radio" name="browse-web" data-filter="browse-<%= o.key %>"<%= (typeof browse !== 'undefined' && browse === o.key) ? ' checked' : '' %>><span><%= o.label %></span><b class="fsb__count"><%= o.count %></b></label>
                <% }); %>
                <% } %>
            <% }); %>
        </section>
        <% } %>
    </div>

    <footer class="fsb__foot">
        <button type="button" class="fsb__apply" data-action="filters-apply">Apply Filters</button>
        <button type="button" class="fsb__reset" data-action="filters-clear-all">Reset</button>
    </footer>
</aside>
