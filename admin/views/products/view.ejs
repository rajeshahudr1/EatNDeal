<%#
  views/products/view.ejs

  Read-only product detail — all fields shown tab-by-tab (Overview / Pricing /
  Schedule / Modifiers & more, where each modifier group lists its options +
  prices). Resolves IDs → names from `meta`. Fully read-only (no Edit/Delete).
  Responsive (cards + label/value rows that stack on mobile). `product` = the
  row; `meta` = option masters.

  Used: Controllers/ProductsController.view.
-%>
<%
    var sym = fmt.currencySymbol(brand);
    var p = product || {};
    var m = meta || {};
    function nameOf(list, id) { var f = (list || []).find(function (x) { return x.id === Number(id); }); return f ? (f.name || f.label) : ''; }
    function namesOf(list, ids) { return (ids || []).map(function (id) { return nameOf(list, id); }).filter(Boolean); }
    function isImg(s) { return !!s && (String(s).indexOf('/') !== -1 || /\.[a-z0-9]{2,5}$/i.test(String(s))); }
    var VEG = { 0: 'None', 1: 'Veg', 2: 'Non-veg' };
    var STATUS = { 1: 'Available', 0: 'Unavailable', 4: 'Unavailable Today', 5: 'Unavailable Until', 3: 'Sold Out' };
    var DISCOUNT = { 3: 'None', 2: 'Percentage', 1: 'Flat' };
    function yesno(v) { return Number(v) === 1 ? 'Yes' : 'No'; }
    var sections = namesOf(m.sections, p.section_ids);
    var allergens = namesOf(m.allergens, p.allergen_ids);
    var modifiers = namesOf(m.modifiers, p.modifier_ids);
    var modGroups = p.modifier_groups || [];
%>
<div class="ly pv">

    <div class="ly__head">
        <div>
            <h2 class="ly__title">👁 <%= p.name || 'Product' %></h2>
            <p class="ly__sub">Product details</p>
        </div>
        <% if (product) { %>
        <div class="pv-headact">
            <a href="/products" class="ly-btn ly-btn--ghost ly-btn--sm">← Back</a>
        </div>
        <% } %>
    </div>

    <% if (load_error) { %>
        <div class="ly-empty"><span class="ly-empty__ic" aria-hidden="true">🏢</span><p class="ly-empty__msg"><%= load_error %></p></div>
    <% } else if (product) { %>

        <div class="pv-tabs" role="tablist">
            <button type="button" class="pv-tab is-on" data-tab="overview">Overview</button>
            <button type="button" class="pv-tab" data-tab="pricing">Pricing &amp; tax</button>
            <button type="button" class="pv-tab" data-tab="schedule">Schedule</button>
            <button type="button" class="pv-tab" data-tab="extras">Modifiers &amp; more</button>
        </div>

        <%# Overview %>
        <section class="card ly-card pv-panel" data-panel="overview">
            <div class="pv-head">
                <div class="pv-img">
                    <% if (p.image_url) { %><img src="<%= p.image_url %>" alt=""><% } else { %><span class="pv-img__ph">🍽️</span><% } %>
                </div>
                <div class="pv-headinfo">
                    <h3 class="pv-name"><%= p.name %><% if (p.suffix) { %> <span class="pv-suffix">— <%= p.suffix %></span><% } %></h3>
                    <span class="ly-tier ly-tier--<%= Number(p.status) === 1 ? 'gold' : 'bronze' %>"><%= STATUS[p.status] || p.status %></span>
                </div>
            </div>
            <div class="pv-rows">
                <div class="pv-row"><span class="pv-k">Category</span><span class="pv-v"><%= nameOf(m.categories, p.category_id) || '—' %></span></div>
                <div class="pv-row"><span class="pv-k">Veg / Non-veg</span><span class="pv-v"><%= VEG[p.veg_non_veg] || '—' %></span></div>
                <div class="pv-row"><span class="pv-k">Service size</span><span class="pv-v"><%= p.service_size || '—' %></span></div>
                <div class="pv-row"><span class="pv-k">Calories</span><span class="pv-v"><%= p.calories || '—' %></span></div>
                <div class="pv-row"><span class="pv-k">Barcode</span><span class="pv-v"><%= p.barcode || '—' %></span></div>
                <% if (Number(p.status) === 5 && p.availability_until) { %><div class="pv-row"><span class="pv-k">Unavailable until</span><span class="pv-v"><%= p.availability_until.replace('T', ' ') %></span></div><% } %>
                <div class="pv-row pv-row--full"><span class="pv-k">Description</span><span class="pv-v"><%= p.description || p.product_description || '—' %></span></div>
            </div>
            <h4 class="pv-subtitle">Options</h4>
            <div class="pv-chips">
                <% [['Show online','show_online'],['Recommended','is_recommended'],['About us','is_display_about_us'],['Alcohol','is_alchohol'],['Tobacco','is_tobacco'],['Online discount','eligible_for_online_discount'],['Collection discount','eligible_for_collection_discount'],['Allow coupons','allow_coupon'],['Excluded from free gift','excluded_for_free_gift']].forEach(function (f) { %>
                <span class="pv-chip <%= Number(p[f[1]]) === 1 ? 'is-on' : '' %>"><%= Number(p[f[1]]) === 1 ? '✓' : '✕' %> <%= f[0] %></span>
                <% }); %>
            </div>
        </section>

        <%# Pricing %>
        <section class="card ly-card pv-panel" data-panel="pricing" hidden>
            <div class="pv-rows">
                <div class="pv-row"><span class="pv-k">Normal price</span><span class="pv-v"><strong><%= sym %><%= p.price_before_tax %></strong></span></div>
                <div class="pv-row"><span class="pv-k">Online price</span><span class="pv-v"><strong><%= sym %><%= p.online_platform_price %></strong></span></div>
                <div class="pv-row"><span class="pv-k">Marketplace price</span><span class="pv-v"><strong><%= sym %><%= p.marketplace_price || '0.00' %></strong></span></div>
                <div class="pv-row"><span class="pv-k">VAT / Tax</span><span class="pv-v"><%= nameOf(m.tax, p.tax_id) || '—' %></span></div>
                <div class="pv-row"><span class="pv-k">Unit type</span><span class="pv-v"><%= nameOf(m.units, p.unit_type_id) || '—' %></span></div>
                <div class="pv-row"><span class="pv-k">Discount</span><span class="pv-v"><%= DISCOUNT[p.discount_type] || 'None' %><% if (Number(p.discount_type) !== 3 && Number(p.discount_value) > 0) { %> · <%= p.discount_value %><% } %></span></div>
                <% if (p.discount_description) { %><div class="pv-row pv-row--full"><span class="pv-k">Discount note</span><span class="pv-v"><%= p.discount_description %></span></div><% } %>
                <div class="pv-row"><span class="pv-k">Min / Max qty</span><span class="pv-v"><%= p.min_qty_for_order || 0 %> / <%= p.max_qty_for_order || 0 %></span></div>
            </div>
        </section>

        <%# Schedule %>
        <section class="card ly-card pv-panel" data-panel="schedule" hidden>
            <div class="pv-rows">
                <div class="pv-row"><span class="pv-k">When available</span><span class="pv-v"><%= p.schedule || 'No Schedule' %></span></div>
                <% if (p.schedule === 'Daily' || p.schedule === 'Weekly') { %>
                <div class="pv-row"><span class="pv-k">Start</span><span class="pv-v"><%= (p.schedule_start_date || '—') %> <%= p.schedule_start_time || '' %></span></div>
                <div class="pv-row"><span class="pv-k">End</span><span class="pv-v"><%= (p.schedule_end_date || '—') %> <%= p.schedule_end_time || '' %></span></div>
                <div class="pv-row pv-row--full"><span class="pv-k">Days</span><span class="pv-v"><% var DN = ['','Mon','Tue','Wed','Thu','Fri','Sat','Sun']; %><%= (p.schedule_days || []).map(function (d) { return DN[d]; }).filter(Boolean).join(', ') || '—' %></span></div>
                <% } else { %>
                <p class="ly-none">No schedule — this item is always available.</p>
                <% } %>
            </div>
        </section>

        <%# Extras %>
        <section class="card ly-card pv-panel" data-panel="extras" hidden>
            <h4 class="pv-subtitle">Modifier groups</h4>
            <% if (modGroups.length) { %>
            <div class="pv-mods">
                <% modGroups.forEach(function (g) { %>
                <div class="pv-mod">
                    <div class="pv-mod__head">
                        <span class="pv-mod__name">🧩 <%= g.name %></span>
                        <span class="pv-mod__meta"><%= g.options.length %> option<%= g.options.length === 1 ? '' : 's' %><% if (Number(g.max_limit) > 0) { %> · choose <%= Number(g.min_limit) > 0 ? (g.min_limit + '–') : 'up to ' %><%= g.max_limit %><% } %></span>
                    </div>
                    <% if (g.options.length) { %>
                    <ul class="pv-mod__opts">
                        <% g.options.forEach(function (o) { %>
                        <li class="pv-mod__opt">
                            <span class="pv-mod__optname"><%= o.name %></span>
                            <span class="pv-mod__optprice"><%= Number(o.price) > 0 ? ('+' + sym + o.price) : 'Free' %></span>
                        </li>
                        <% }); %>
                    </ul>
                    <% } else { %><p class="ly-none">No options in this group.</p><% } %>
                </div>
                <% }); %>
            </div>
            <% } else if (modifiers.length) { %>
            <div class="pv-chips"><% modifiers.forEach(function (n) { %><span class="pv-chip is-on">🧩 <%= n %></span><% }); %></div>
            <% } else { %><p class="ly-none">No modifier groups.</p><% } %>
            <h4 class="pv-subtitle">Sections</h4>
            <% if (sections.length) { %><div class="pv-chips"><% sections.forEach(function (n) { %><span class="pv-chip is-on">📂 <%= n %></span><% }); %></div><% } else { %><p class="ly-none">No sections.</p><% } %>
            <h4 class="pv-subtitle">Allergens</h4>
            <% if (allergens.length) { %><div class="pv-chips"><% allergens.forEach(function (n) { %><span class="pv-chip pv-chip--warn">⚠️ <%= n %></span><% }); %></div><% } else { %><p class="ly-none">No allergens listed.</p><% } %>
        </section>

    <% } %>
</div>
