<%#
  views/account/index.ejs

  What:  Signed-in customer's "My Profile" dashboard, built to the supplied
         mockup: a left sidebar of account tabs (+ Invite & Earn card) and a
         main column with the editable profile card, Update / Log Out
         actions, a stats row, and an "account safety" card.
  Used:  AuthController.accountPage (GET /account) — rendered WITH the site
         header (not bare) but with the promo strip suppressed. POSTs to
         /account → updateProfile.
  Tabs:  Dynamic where we have a real destination — My Profile (here),
         Addresses (opens the location/address book modal), Help & Support
         (/help). The rest show a "coming soon" toast (data-acct-soon).
  JS:    /js/pages/account.js (clear / CHANGE / dirty / gender dropdown /
         country picker / avatar toast / tab handlers).
-%>
<%
    var fullName = [account_user.firstname, account_user.lastname].filter(Boolean).join(' ');
    var initial  = (account_user.firstname || account_user.email || '?').charAt(0).toUpperCase();

    var dobValue = '';
    var bd = String(account_user.birthdate || '').trim();
    if (/^\d{4}-\d{2}-\d{2}$/.test(bd)) { dobValue = bd; }
    else { var m = bd.match(/^(\d{2})[\/\-](\d{2})[\/\-](\d{4})$/); if (m) { dobValue = m[3] + '-' + m[2] + '-' + m[1]; } }

    var currentDial = account_user.country_code ? '+' + account_user.country_code : '+44';
    var hasMobile   = !!account_user.contact_no;
    var hasEmail    = !!account_user.email;
    var __gender    = String(account_user.gender || '').toLowerCase();
    var __genders   = [['', 'Select'], ['male', 'Male'], ['female', 'Female'], ['other', 'Other'], ['na', 'Prefer not to say']];
    var __selG      = __genders.find(function (g) { return g[0] === __gender && g[0] !== ''; });
    var st          = (typeof account_stats !== 'undefined' && account_stats) ? account_stats : { orders: 0, favourites: 0, rewardPoints: 0, offers: 0 };
%>
<section class="acct">

    <%# Mobile-only top bar — on phones the page is a focused app screen
        (no site header / tabs / stats); this is the back + title. %>
    <header class="acct-mobilebar">
        <a class="acct-mobilebar__back" href="/" aria-label="Back">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
        </a>
        <h1 class="acct-mobilebar__title"><%= active_tab === 'profile' ? 'Your Profile' : active_tab_label %></h1>
    </header>

    <%# ── Sidebar ─────────────────────────────────────────────────── %>
    <aside class="acct-nav">
        <nav class="acct-nav__list" aria-label="Account">
            <a class="acct-nav__item<%= active_tab === 'profile' ? ' is-active' : '' %>" href="/account"<%= active_tab === 'profile' ? ' aria-current="page"' : '' %>>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="8" r="4"/><path d="M4 21c0-4 4-6 8-6s8 2 8 6"/></svg>
                <span>My Profile</span>
            </a>
            <a class="acct-nav__item<%= active_tab === 'addresses' ? ' is-active' : '' %>" href="/account?tab=addresses">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s7-7.5 7-13a7 7 0 0 0-14 0c0 5.5 7 13 7 13z"/><circle cx="12" cy="9" r="2.5"/></svg>
                <span>Addresses</span>
            </a>
            <a class="acct-nav__item<%= active_tab === 'payment' ? ' is-active' : '' %>" href="/account?tab=payment">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="5" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/></svg>
                <span>Payment Methods</span>
            </a>
            <a class="acct-nav__item<%= active_tab === 'orders' ? ' is-active' : '' %>" href="/account?tab=orders">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 3H6a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V5a2 2 0 0 0-2-2h-3"/><rect x="9" y="2" width="6" height="4" rx="1"/><line x1="8" y1="11" x2="16" y2="11"/><line x1="8" y1="15" x2="13" y2="15"/></svg>
                <span>My Orders</span>
            </a>
            <a class="acct-nav__item<%= active_tab === 'favourites' ? ' is-active' : '' %>" href="/account?tab=favourites">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20.8 4.6a5.5 5.5 0 0 0-7.8 0L12 5.7l-1-1.1a5.5 5.5 0 0 0-7.8 7.8l1 1.1L12 21l7.8-7.5 1-1.1a5.5 5.5 0 0 0 0-7.8z"/></svg>
                <span>Favourites</span>
            </a>
            <a class="acct-nav__item<%= active_tab === 'rewards' ? ' is-active' : '' %>" href="/account?tab=rewards">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="8" width="18" height="13" rx="1"/><path d="M3 12h18M12 8v13M12 8S9 3 6.5 4.5 7 8 12 8zM12 8s3-5 5.5-3.5S17 8 12 8z"/></svg>
                <span>Rewards</span>
            </a>
            <a class="acct-nav__item<%= active_tab === 'notifications' ? ' is-active' : '' %>" href="/account?tab=notifications">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 8a6 6 0 0 0-12 0c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.7 21a2 2 0 0 1-3.4 0"/></svg>
                <span>Notifications</span>
            </a>
            <a class="acct-nav__item" href="/help">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M9.1 9a3 3 0 0 1 5.8 1c0 2-3 2.5-3 2.5"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                <span>Help &amp; Support</span>
            </a>
            <a class="acct-nav__item<%= active_tab === 'settings' ? ' is-active' : '' %>" href="/account?tab=settings">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09a1.65 1.65 0 0 0-1-1.51 1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09a1.65 1.65 0 0 0 1.51-1 1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
                <span>Settings</span>
            </a>
        </nav>

        <div class="acct-invite">
            <p class="acct-invite__title">Invite &amp; Earn</p>
            <p class="acct-invite__sub">Invite your friends and earn exciting rewards</p>
            <button type="button" class="acct-invite__btn" data-acct-soon="Invite &amp; Earn">Invite Now</button>
        </div>
    </aside>

    <%# ── Main ────────────────────────────────────────────────────── %>
    <div class="acct-main">
        <header class="acct-head">
            <div class="acct-head__text">
                <h1 class="acct-head__title"><%= active_tab_label %></h1>
                <p class="acct-head__sub"><%= active_tab === 'profile' ? 'Manage your personal details and account information' : 'This section is on the way.' %></p>
            </div>
        </header>

        <% if (active_tab === 'favourites') { %>
        <%# Favourites tab — real saved-restaurants list. %>
        <% var favs = (typeof favourites !== 'undefined' && favourites) ? favourites : []; %>
        <% if (favs.length === 0) { %>
            <div class="acct-placeholder">
                <span class="acct-placeholder__icon" aria-hidden="true">
                    <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
                </span>
                <h2 class="acct-placeholder__title">No favourites yet</h2>
                <p class="acct-placeholder__sub">Tap the heart on any restaurant to save it here for quick reordering.</p>
                <a class="acct-btn acct-btn--update" href="/">Browse restaurants</a>
            </div>
        <% } else { %>
            <ul class="resto-rail acct-fav-grid" role="list">
            <% favs.forEach(function (r) { %>
                <%- include('../partials/restaurant-card', { r: r, forceFavourite: true }) %>
            <% }); %>
            </ul>
        <% } %>
        <% } else if (active_tab !== 'profile') { %>
        <%# Placeholder screen for tabs we haven't built yet — the tab still
            highlights in the sidebar so the navigation reads as "selected". %>
        <div class="acct-placeholder">
            <span class="acct-placeholder__icon" aria-hidden="true">
                <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><polyline points="12 7 12 12 15 14"/></svg>
            </span>
            <h2 class="acct-placeholder__title"><%= active_tab_label %> coming soon</h2>
            <p class="acct-placeholder__sub">We're building this section. It'll appear here when it's ready.</p>
            <% if (active_tab === 'addresses') { %>
                <button type="button" class="acct-btn acct-btn--update" data-action="open-location-modal">Manage addresses</button>
            <% } %>
        </div>
        <% } else { %>

        <form id="account-form" class="acct-card" method="post" action="/account" novalidate data-profile>
            <div class="acct-card__avatar">
                <div class="profile-avatar" data-avatar>
                    <span class="profile-avatar__circle" data-avatar-circle>
                        <% if (account_user.image) { %><img src="<%= account_user.image %>" alt="Profile photo" data-img-fallback><% } else { %><%= initial %><% } %>
                    </span>
                    <button type="button" class="profile-avatar__edit" data-action="avatar-edit" aria-label="Change photo">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 20h9"/><path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4z"/></svg>
                    </button>
                    <input type="file" accept="image/png,image/jpeg,image/webp,image/gif" data-avatar-input hidden>
                </div>
            </div>

            <div class="acct-fields">
                <%# Full Name %>
                <div class="pf-field">
                    <label class="pf-field__label" for="pf-name">Full Name</label>
                    <div class="pf-field__control">
                        <input id="pf-name" class="pf-field__input" type="text" name="name" value="<%= fullName %>" placeholder="Your full name" autocomplete="name" maxlength="120" required>
                        <button type="button" class="pf-clear" data-clear="pf-name" aria-label="Clear name">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><circle cx="12" cy="12" r="10" fill="#9ca3af"/><path d="M15 9l-6 6M9 9l6 6" stroke="#fff" stroke-width="2" stroke-linecap="round"/></svg>
                        </button>
                    </div>
                </div>

                <%# Mobile — read-only + CHANGE %>
                <div class="pf-field pf-field--lock" data-lock="mobile">
                    <label class="pf-field__label">Mobile Number</label>
                    <div class="pf-field__control">
                        <span class="pf-readonly" data-readonly><%= hasMobile ? account_user.contact_no : 'Add your mobile number' %></span>
                        <button type="button" class="pf-change" data-action="change-mobile">CHANGE</button>
                        <div class="pf-edit" data-edit hidden>
                            <button type="button" id="country-picker-trigger" class="country-chip" data-action="open-country-picker" aria-haspopup="dialog" aria-controls="country-picker" aria-label="Choose country">
                                <span class="country-chip__flag" id="country-chip-flag" aria-hidden="true">🇬🇧</span>
                                <span class="country-chip__code" id="country-chip-code"><%= currentDial %></span>
                                <svg class="country-chip__arrow" aria-hidden="true" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
                            </button>
                            <input id="pf-mobile" class="pf-field__input" type="tel" name="mobile" inputmode="numeric" pattern="[0-9]*" autocomplete="tel-national" placeholder="Mobile number" value="<%= account_user.contact_no || '' %>" minlength="6" maxlength="15">
                            <input type="hidden" name="country_iso"  id="account-country-iso"  value="GB">
                            <input type="hidden" name="country_dial" id="account-country-dial" value="<%= currentDial %>">
                        </div>
                    </div>
                </div>

                <%# Email — read-only + CHANGE %>
                <div class="pf-field pf-field--lock" data-lock="email">
                    <label class="pf-field__label">Email Address</label>
                    <div class="pf-field__control">
                        <span class="pf-readonly <%= hasEmail ? '' : 'is-empty' %>" data-readonly><%= hasEmail ? account_user.email : 'Add your email' %></span>
                        <button type="button" class="pf-change" data-action="change-email">CHANGE</button>
                        <div class="pf-edit" data-edit hidden>
                            <input id="pf-email" class="pf-field__input" type="email" name="email" value="<%= account_user.email || '' %>" placeholder="you@example.com" autocomplete="email" maxlength="180">
                        </div>
                    </div>
                </div>

                <%# Date of birth %>
                <div class="pf-field">
                    <label class="pf-field__label" for="pf-dob">Date of Birth</label>
                    <div class="pf-field__control">
                        <input id="pf-dob" class="pf-field__input pf-field__input--date" type="date" name="birthdate" value="<%= dobValue %>" max="<%= (new Date()).toISOString().slice(0,10) %>">
                        <button type="button" class="pf-clear" data-clear="pf-dob" aria-label="Clear date of birth">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><circle cx="12" cy="12" r="10" fill="#9ca3af"/><path d="M15 9l-6 6M9 9l6 6" stroke="#fff" stroke-width="2" stroke-linecap="round"/></svg>
                        </button>
                    </div>
                </div>

                <%# Gender — custom dropdown %>
                <div class="pf-field pf-field--select" data-pf-select>
                    <label class="pf-field__label" id="pf-gender-label">Gender</label>
                    <button type="button" class="pf-field__control pf-select__btn" data-pf-select-btn aria-haspopup="listbox" aria-expanded="false" aria-labelledby="pf-gender-label">
                        <span class="pf-select__value<%= __selG ? '' : ' is-placeholder' %>" data-pf-select-value><%= __selG ? __selG[1] : 'Select' %></span>
                        <svg class="pf-select__chev" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
                    </button>
                    <ul class="pf-select__menu" role="listbox" aria-labelledby="pf-gender-label" data-pf-select-menu hidden>
                        <% __genders.forEach(function (g) { if (g[0] === '') { return; } %>
                            <li class="pf-select__opt<%= g[0] === __gender ? ' is-selected' : '' %>" role="option" data-value="<%= g[0] %>" aria-selected="<%= g[0] === __gender ? 'true' : 'false' %>"><%= g[1] %></li>
                        <% }); %>
                    </ul>
                    <input type="hidden" name="gender" id="pf-gender" value="<%= __selG ? __selG[0] : '' %>">
                </div>
            </div>
        </form>

        <%# Actions %>
        <div class="acct-actions">
            <button type="submit" form="account-form" class="acct-btn acct-btn--update" data-submit>Update Profile</button>
            <form method="post" action="/logout" class="acct-logout-form"><button type="submit" class="acct-btn acct-btn--logout">Log Out</button></form>
        </div>

        <%# Stats %>
        <div class="acct-stats">
            <div class="acct-stat">
                <span class="acct-stat__icon acct-stat__icon--orders"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg></span>
                <span class="acct-stat__num"><%= st.orders %></span>
                <span class="acct-stat__label">Orders Placed</span>
            </div>
            <div class="acct-stat">
                <span class="acct-stat__icon acct-stat__icon--fav"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20.8 4.6a5.5 5.5 0 0 0-7.8 0L12 5.7l-1-1.1a5.5 5.5 0 0 0-7.8 7.8l1 1.1L12 21l7.8-7.5 1-1.1a5.5 5.5 0 0 0 0-7.8z"/></svg></span>
                <span class="acct-stat__num"><%= st.favourites %></span>
                <span class="acct-stat__label">Favourites</span>
            </div>
            <div class="acct-stat">
                <span class="acct-stat__icon acct-stat__icon--points"><svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg></span>
                <span class="acct-stat__num"><%= st.rewardPoints %></span>
                <span class="acct-stat__label">Reward Points</span>
            </div>
            <div class="acct-stat">
                <span class="acct-stat__icon acct-stat__icon--offers"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20.6 13.4 12 22l-9-9V3h10l7.6 7.6a2 2 0 0 1 0 2.8z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg></span>
                <span class="acct-stat__num"><%= st.offers %></span>
                <span class="acct-stat__label">Offers Unlocked</span>
            </div>
        </div>

        <%# Account safety %>
        <div class="acct-safe">
            <span class="acct-safe__icon"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg></span>
            <div class="acct-safe__text">
                <p class="acct-safe__title">Keep your account safe</p>
                <p class="acct-safe__sub">Enable two-factor authentication to protect your account.</p>
            </div>
            <button type="button" class="acct-safe__btn" data-acct-soon="Two-factor authentication">Enable 2FA</button>
        </div>
        <% } %>
    </div>
</section>

<%- include('../partials/country-picker') -%>
