<%#
  views/partials/mobile-search.ejs

  What:  Sticky full-width search row shown ONLY on mobile. Sits
         between the site header (logo + location chip + bell) and
         the page content. The cuisines row sticks immediately below
         this bar — so the user sees three sticky layers stacked on
         mobile:
            [ logo  ·  location  ·  bell  ]    ← header (60-68 px)
            [        🔍  search…         ]    ← this bar     (~52 px)
            [ pizza · burger · indian … ]    ← cuisines
         Desktop renders its own inline search inside the header
         (header.ejs) and hides this partial via CSS.
  Why:   On small screens the header doesn't have room for a wide
         search input alongside everything else. A dedicated row
         keeps the search field big enough to be tappable + the
         existing icon set in the header untouched.
  Used:  Included from views/_layout.ejs after the header, before
         the promo strip / page body.
-%>
<div class="mobile-search" role="search">
    <form class="mobile-search__form" data-no-loader>
        <svg class="mobile-search__icon" aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="7"/>
            <line x1="21" y1="21" x2="16.65" y2="16.65"/>
        </svg>
        <input
            type="search"
            class="mobile-search__input"
            id="site-search-mobile"
            placeholder="Search restaurants, dishes, cuisines"
            autocomplete="off"
            spellcheck="false"
            data-search-scope="home"
        >
    </form>
    <%# Filter button — opens the Swiggy-style bottom sheet at
        views/partials/filter-sheet.ejs via /js/ui/filter-sheet.js.
        Aria-haspopup so screen readers announce it as a sheet-
        opener. The data-action selector is what the JS listens for. %>
    <button
        type="button"
        class="mobile-search__filter"
        data-action="open-filters"
        aria-label="Open filters and sorting"
        aria-haspopup="dialog"
    >
        <svg aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="4"  y1="6"  x2="20" y2="6"/>
            <line x1="7"  y1="12" x2="17" y2="12"/>
            <line x1="10" y1="18" x2="14" y2="18"/>
        </svg>
    </button>
</div>
